---
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = [
  { title: 'Client-Side vs Server-Side: Why Your Data Is Safer in the Browser', slug: 'client-side-vs-server-side', date: 'June 7, 2026', excerpt: "When you use an online tool, where does your data actually go? Client-side processing keeps everything in your browser—here\'s why that matters for your privacy." },
  { title: 'JSON vs YAML vs TOML: Which Config Format Should You Use in 2026', slug: 'json-yaml-toml-comparison', date: 'June 7, 2026', excerpt: "JSON, YAML, and TOML look interchangeable until you hit a 3am bug from whitespace sensitivity or implicit type coercion. Here\'s the practical guide to picking the right format." },
  { title: 'How to Choose the Right Color Palette for Your Website', slug: 'color-palette-guide', date: 'May 21, 2026', excerpt: 'Picking colors for your website shouldn\'t feel like guessing. Here\'s how to build a color palette that looks professional, works for accessibility, and actually converts.' },
  { title: 'Loan Amortization Explained: Why Your Early Payments Barely Touch the Principal', slug: 'loan-amortization-guide', date: 'May 19, 2026', excerpt: 'You pay thousands in the first year of a loan and barely make a dent in what you owe. Here\'s why amortization works this way — and how to fight back.' },
  { title: 'Lorem Ipsum Is Dead: Why Designers Are Switching to Real Content', slug: 'lorem-ipsum-alternatives', date: 'May 19, 2026', excerpt: 'Lorem ipsum has been the default placeholder for 500 years, but it causes real problems in modern design workflows. Here\'s why real content matters and what to use instead.' },
  { title: 'URL Encoding Bugs: The Silent Killer of Web Forms', slug: 'url-encoding-bugs', date: 'May 18, 2026', excerpt: 'Ampersands, spaces, and emoji in your form data can break everything from email links to API calls. Here\'s how URL encoding works and why it keeps breaking your code.' },
  { title: 'Base64 in the Wild: 5 Places You Use It Every Day Without Knowing', slug: 'base64-real-world', date: 'May 17, 2026', excerpt: 'Base64 encoding is hiding in your emails, your images, your URLs, and your authentication headers. Here\'s where it appears, why it exists, and when it\'s a problem.' },
  { title: 'XML Sitemaps: The SEO Feature Most Websites Get Wrong', slug: 'sitemap-seo-guide', date: 'May 16, 2026', excerpt: 'Having a sitemap.xml isn\'t enough. Most sitemaps have errors that hurt your SEO — from stale URLs to missing lastmod dates. Here\'s how to fix yours.' },
  { title: 'The Restaurant Tip Calculator Nobody Asked For But Everyone Needs', slug: 'tip-calculator-tricks', date: 'May 15, 2026', excerpt: 'Tipping etiquette is a mess. Different countries, different expectations, different math. Here\'s how to tip without overthinking it — or undertipping.' },
  { title: 'BMI Alternatives: 5 Better Ways to Measure Your Health', slug: 'bmi-alternatives', date: 'May 14, 2026', excerpt: 'BMI has been the default health metric for decades, but it was never designed for individuals. Here are 5 measurements that tell you more about your actual health.' },
  { title: 'AdSense RPM: Why Your Earnings Per Pageview Are Lower Than You Think', slug: 'adsense-optimization-guide', date: 'May 12, 2026', excerpt: 'Your AdSense RPM looks decent until you realize how much disappears to invalid traffic, ad blockers, and viewability thresholds. Here\'s what\'s really going on.' },
  { title: '7 Surprising Ways People Use Age Calculators (That Aren\'t Just Birthdays)', slug: 'age-calculator-uses', date: 'May 10, 2026', excerpt: 'Age calculators seem simple, but people use them for everything from visa applications to retirement planning to sports eligibility. Here are the real use cases.' },
  { title: 'What Computer Can Run Local AI Models? Check Before You Build', slug: 'local-ai-hardware-guide', date: 'May 20, 2026', excerpt: 'Want to run AI models locally? VRAM is the single most important spec. Here is exactly what GPU, RAM, and storage you need — and how to check your system before downloading a 40GB model.' },
  { title: 'Crypto Tax Guide: What You Owe When You Sell', slug: 'crypto-tax-guide', date: 'May 19, 2026', excerpt: 'A practical guide to cryptocurrency taxes — what counts as a taxable event, how to calculate your gains, and the mistakes that cost people thousands in penalties.' },
  { title: 'The robots.txt Mistakes That Can Kill Your SEO', slug: 'robots-txt-mistakes', date: 'May 17, 2026', excerpt: 'Common robots.txt errors that silently destroy your search rankings, from blocking CSS to accidentally disallowing your entire site.' },
  { title: 'Why Your Social Media Links Look Broken (And How OG Images Fix It)', slug: 'og-image-guide', date: 'May 15, 2026', excerpt: 'Learn why your links look terrible when shared on social media and how Open Graph images can transform your social presence and click-through rates.' },
  { title: '5 Password Myths That Are Still Getting People Hacked in 2026', slug: 'password-myths', date: 'May 13, 2026', excerpt: 'Outdated password advice is everywhere. These 5 myths are still making people vulnerable to attacks — and what you should do instead.' },
  { title: 'The Math Behind "70% Off": How Stores Manipulate Discount Numbers', slug: 'discount-shopping-math', date: 'May 11, 2026', excerpt: 'Retailers use psychological pricing tricks and misleading discount math to make you spend more. Here\'s how to see through the numbers.' },
  { title: 'How to Calculate Your Mortgage Payment: A Complete Guide', slug: 'how-to-calculate-mortgage-payment', date: 'May 8, 2026', excerpt: 'Understanding your mortgage payment is the first step to smart homeownership. This guide breaks down every component of a mortgage payment and shows you how to calculate it accurately.' },
  { title: 'JSON Formatting Best Practices for Developers', slug: 'json-formatting-best-practices', date: 'May 7, 2026', excerpt: 'Properly formatted JSON is essential for debugging, API development, and team collaboration. Learn the best practices that will save you hours of frustration.' },
  { title: 'The Ultimate Guide to Meta Tags for SEO in 2026', slug: 'meta-tags-seo-guide', date: 'May 6, 2026', excerpt: 'Meta tags remain one of the most important on-page SEO factors. This comprehensive guide covers every meta tag you need, from basic SEO to Open Graph and Twitter Cards.' },
  { title: 'Password Security: How to Create and Manage Strong Passwords', slug: 'password-security-guide', date: 'May 5, 2026', excerpt: 'Password breaches are still the #1 security threat. Learn how to generate unbreakable passwords, why password managers are essential, and what passkeys mean for the future.' },
  { title: 'Understanding Compound Interest: The Eighth Wonder of the World', slug: 'compound-interest-guide', date: 'May 4, 2026', excerpt: 'Compound interest can make you rich — or keep you in debt. This guide explains how it works, how to calculate it, and strategies to make it work in your favor.' },
  { title: 'QR Code Technology Explained: How It Works and Best Practices', slug: 'qr-code-technology-guide', date: 'May 3, 2026', excerpt: 'QR codes are everywhere, but most people don\'t know how they actually work. Discover the technology behind QR codes, error correction levels, and design best practices.' },
  { title: 'ROI Calculation Methods: Simple vs Annualized Returns', slug: 'roi-calculation-methods', date: 'May 2, 2026', excerpt: 'Not all ROI calculations are equal. Learn the difference between simple ROI and annualized returns, when to use each, and the common pitfalls that lead to misleading numbers.' },
  { title: 'BMI Calculator: What Your Number Really Means', slug: 'bmi-calculator-guide', date: 'May 1, 2026', excerpt: 'BMI is widely used but often misunderstood. This guide explains what BMI measures, its limitations, when it\'s useful, and what better alternatives exist for assessing health.' },
];
---

<BaseLayout title="Blog" description="Articles and guides about web tools, finance calculators, SEO, and developer productivity.">
  <section class="blog-list">
    <nav class="breadcrumb">
      <a href="/">Home</a> <span class="breadcrumb-sep">›</span> <span>Blog</span>
    </nav>
    <h1>📖 Blog</h1>
    <p class="subtitle">Guides, tutorials, and insights about our tools and the problems they solve.</p>
    
    {posts.map((post) => (
      <a href={`/blog/${post.slug}`} class="blog-card">
        <h2>{post.title}</h2>
        <p>{post.excerpt}</p>
        <div class="blog-card-meta">{post.date}</div>
      </a>
    ))}
  </section>
</BaseLayout>
