<BaseLayout title="Lorem Ipsum Is Dead: Why Designers Are Switching to Real Content" description="Lorem ipsum has been the default placeholder text for 500 years, but it's causing real problems in modern design workflows. Here's why real content matters and what to use instead." structuredData={structuredData}>
  <article class="blog-post">
    <nav class="breadcrumb">
