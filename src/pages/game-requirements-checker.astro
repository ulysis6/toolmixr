---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "Game Requirements Checker - Can Your PC Run AAA Games?";
const pageUrl = "https://toolmixr.com/game-requirements-checker";

const structuredData = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": pageTitle,
    "url": pageUrl,
    "description": "Check if your PC can run AAA games like GTA VI, Monster Hunter Wilds, Black Myth: Wukong, and more. Compare your GPU, CPU, and RAM against minimum and recommended system requirements.",
    "applicationCategory": "GameApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What happens if I only meet minimum requirements?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Meeting minimum requirements means the game will run, but you'll likely need to play on low settings at 30 FPS or below. You may experience stuttering, long loading times, and reduced visual quality. For a comfortable experience, aim for recommended specs or better."
        }
      },
      {
        "@type": "Question",
        "name": "Can I run a game if my GPU is below minimum but I have more RAM?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Unfortunately, no. RAM cannot compensate for an insufficient GPU. The GPU handles rendering the game's graphics, and if it doesn't meet minimum requirements, the game may not launch or will be unplayably slow regardless of how much RAM you have. Each component (GPU, CPU, RAM) must independently meet the game's requirements."
        }
      },
      {
        "@type": "Question",
        "name": "How accurate are these system requirements?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "System requirements are based on official publisher specifications and community testing. They typically target 30 FPS at minimum specs and 60 FPS at recommended specs, usually at 1080p resolution. Actual performance may vary based on drivers, background processes, and specific game scenes."
        }
      },
      {
        "@type": "Question",
        "name": "Does this checker account for upscaling technologies like DLSS?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "This checker uses official system requirements without DLSS/FSR adjustments. In practice, upscaling technologies like DLSS, FSR, or XeSS can significantly improve performance, potentially allowing you to run games smoothly on hardware below the recommended tier. If your GPU supports DLSS or FSR, you may get better results than shown here."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://toolmixr.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": pageTitle,
        "item": pageUrl
      }
    ]
  }
]);
