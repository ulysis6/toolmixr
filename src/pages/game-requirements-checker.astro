      var gpuMeetsMin = (gpuVram === 0) || (gpuTier >= g.minGpu);
      var gpuMeetsRec = (gpuVram === 0) || (gpuTier >= g.recGpu);
      var cpuMeetsMin = (cpuScore === 0) || (cpuScore >= g.minCpu);
      var cpuMeetsRec = (cpuScore === 0) || (cpuScore >= g.recCpu);
      var ramMeetsMin = ram >= g.minRam;
      var ramMeetsRec = ram >= g.recRam;

      var status, statusClass, statusIcon;
      var gpuStatus, cpuStatus, ramStatus;

      // Component-level status
      if (gpuMeetsRec) { gpuStatus = '<span style="color:#10B981;">✅</span>'; }
