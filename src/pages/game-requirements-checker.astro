      else if (cpuMeetsMin) { cpuStatus = '<span style="color:#F59E0B;">⚠️</span>'; }
      else { cpuStatus = '<span style="color:#EF4444;">❌</span>'; }

      if (ramMeetsRec) { ramStatus = '<span style="color:#10B981;">✅</span>'; }
      else if (ramMeetsMin) { ramStatus = '<span style="color:#F59E0B;">⚠️</span>'; }
      else { ramStatus = '<span style="color:#EF4444;">❌</span>'; }

      // Overall status
      if (gpuMeetsMin && cpuMeetsMin && ramMeetsMin) {
        if (gpuMeetsRec && cpuMeetsRec && ramMeetsRec) {
          status = "Can Run";
          statusClass = "color:#10B981;font-weight:600;";
          statusIcon = "✅";
        } else {
          status = "May Run";
          statusClass = "color:#F59E0B;font-weight:600;";
          statusIcon = "⚠️";
        }
      } else {
        status = "Cannot Run";
        statusClass = "color:#EF4444;font-weight:600;";
        statusIcon = "❌";
      }

      var tr = document.createElement('tr');
      tr.style.borderBottom = '1px solid var(--border)';
      tr.innerHTML = '<td style="padding:10px 12px;font-weight:500;">' + g.name + '</td>' +
        '<td style="padding:10px 12px;text-align:center;">' + gpuStatus + '</td>' +
        '<td style="padding:10px 12px;text-align:center;">' + cpuStatus + '</td>' +
        '<td style="padding:10px 12px;text-align:center;">' + ramStatus + '</td>' +
        '<td style="padding:10px 12px;text-align:center;' + statusClass + '">' + statusIcon + ' ' + status + '</td>';
      tbody.appendChild(tr);
    }

    document.getElementById('gameResult').style.display = 'block';
  }
</script>
</BaseLayout>
