---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "ROI Calculator";
const pageUrl = "https://toolmixr.com/roi-calculator";

const structuredData = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": pageTitle,
    "url": pageUrl,
    "description": "Free online ROI calculator to measure investment return on investment. Calculate ROI percentage, net profit, and annualized return rate instantly.",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is ROI (Return on Investment)?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "ROI is a performance metric used to evaluate the profitability of an investment. It measures the gain or loss generated relative to the amount invested. A positive ROI means the investment profited; a negative ROI indicates a loss."
        }
      },
      {
        "@type": "Question",
        "name": "How to calculate annualized ROI?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Annualized ROI adjusts the return to a yearly rate, allowing comparison of investments held for different periods. Formula: Annualized ROI = ((1 + ROI%)^(1/years) - 1) x 100. For example, 50% return over 2 years = ((1.50)^(0.5) - 1) x 100 = 22.47% annually."
        }
      },
      {
        "@type": "Question",
        "name": "What is a good ROI?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A \"good\" ROI depends on the investment type and risk tolerance. For stock market investments, 7-10% annually is considered solid. Real estate typically aims for 8-12%. Realistic expectations vary by asset class: stocks 6-10%, bonds 2-5%, real estate 8-12%."
        }
      },
      {
        "@type": "Question",
        "name": "Should I include additional costs in ROI calculation?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, including all costs (transaction fees, taxes, maintenance, holding costs) gives a more accurate picture of actual returns. Many investors overlook these, leading to overestimated profits."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://toolmixr.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": pageTitle,
        "item": pageUrl
      }
    ]
  }
]);
---

<BaseLayout 
  title={pageTitle} 
  description="Free online ROI calculator to measure investment return on investment. Calculate ROI percentage, net profit, and annualized return rate instantly."
  structuredData={structuredData}
>
  <section class="tool-page">
  <nav class="breadcrumb">
    <a href="/">Home</a> <span class="breadcrumb-sep">›</span> <span>ROI Calculator</span>
  </nav>
  <div class="tool-header">
    <h1>📈 ROI Calculator</h1>
    <div class="share-bar">
      <a class="share-btn share-twitter" href="#" onclick="shareTwitter(event)" title="Share on Twitter">𝕏</a>
      <a class="share-btn share-facebook" href="#" onclick="shareFacebook(event)" title="Share on Facebook">f</a>
      <a class="share-btn share-linkedin" href="#" onclick="shareLinkedIn(event)" title="Share on LinkedIn">in</a>
      <a class="share-btn share-reddit" href="#" onclick="shareReddit(event)" title="Share on Reddit">R</a>
      <button class="share-btn share-copy" onclick="copyPageLink(event)" title="Copy link">🔗</button>
    </div>
  </div>
  <p class="subtitle">Calculate return on investment and annualized ROI for your investments</p>
    
    <div class="tool-box">
      <div class="form-group">
        <label for="investmentAmount">Investment Amount ($)</label>
        <input type="number" id="investmentAmount" value="10000" min="0" step="100" oninput="calculateROI()" />
      </div>
      
      <div class="form-group">
        <label for="finalValue">Final Value / Selling Price ($)</label>
        <input type="number" id="finalValue" value="15000" min="0" step="100" oninput="calculateROI()" />
      </div>
      
      <div class="form-group">
        <label for="additionalCosts">Additional Costs ($) <span style="font-weight:400;color:var(--text-secondary);font-size:12px;">(e.g., fees, taxes, repairs)</span></label>
        <input type="number" id="additionalCosts" value="0" min="0" step="50" oninput="calculateROI()" />
      </div>
      
      <div class="form-group">
        <label for="holdingPeriod">Holding Period (Years)</label>
        <input type="number" id="holdingPeriod" value="2" min="0.1" max="100" step="0.1" oninput="calculateROI()" />
      </div>
      
      <div style="display:flex;gap:12px;margin-top:20px;">
        <button class="btn btn-primary" onclick="calculateROI()">Calculate ROI</button>
      </div>
      
      <div id="result" style="display:none;margin-top:24px;">
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;">
          <div style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:20px;text-align:center;">
            <div style="font-size:13px;color:var(--text-secondary);margin-bottom:4px;">ROI</div>
            <div style="font-size:32px;font-weight:700;color:var(--primary);" id="roiPercent">0%</div>
          </div>
          <div style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:20px;text-align:center;">
            <div style="font-size:13px;color:var(--text-secondary);margin-bottom:4px;">Net Profit</div>
            <div style="font-size:32px;font-weight:700;color:#10B981;" id="netProfit">$0</div>
          </div>
          <div style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:20px;text-align:center;">
            <div style="font-size:13px;color:var(--text-secondary);margin-bottom:4px;">Annualized ROI</div>
            <div style="font-size:32px;font-weight:700;color:#F59E0B;" id="annualizedROI">0%</div>
          </div>
        </div>
        
        <div style="margin-top:24px;padding:16px;background:#F3F4F6;border-radius:var(--radius);font-size:13px;">
          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px;">
            <div><strong>Total Investment:</strong> <span id="totalInvestment">$0</span></div>
            <div><strong>Total Return:</strong> <span id="totalReturn">$0</span></div>
            <div><strong>ROI Formula:</strong> ((Final - Cost) / Cost) x 100</div>
          </div>
        </div>
      </div>
    

    <section class="guide">
      <h2>How to Use the ROI Calculator</h2>
      <p>The ROI (Return on Investment) calculator helps you measure the profitability of any investment. Whether you're evaluating stocks, real estate, business ventures, or cryptocurrency, understanding your actual return is crucial for making informed financial decisions.</p>
      
      <h3>Step-by-Step Guide</h3>
      <ol>
        <li><strong>Enter your initial investment</strong> — This is the total amount you put into the investment at the start. Include the purchase price or initial capital.</li>
        <li><strong>Enter the final value</strong> — This is what the investment is worth today, or what you sold it for. For current investments, use the current market value.</li>
        <li><strong>Add additional costs</strong> — Include transaction fees, broker commissions, taxes paid, maintenance costs, or any other expenses related to the investment.</li>
        <li><strong>Set the holding period</strong> — Enter how long you held the investment in years. Use decimals for partial years (e.g., 1.5 for 18 months).</li>
        <li><strong>Click Calculate ROI</strong> — The tool will show your ROI percentage, net profit, and annualized ROI for easy comparison across different investments.</li>
      </ol>
      
      <h3>Tips & Best Practices</h3>
      <ul>
        <li><strong>Include all costs</strong> — For accurate ROI, always include transaction fees, taxes, holding costs, and any other expenses. This gives you the true picture of returns.</li>
        <li><strong>Use annualized ROI for comparison</strong> — A 50% return over 2 years equals about 22.5% annualized. This lets you fairly compare investments held for different time periods.</li>
        <li><strong>Past performance does not equal future results</strong> — Historical ROI doesn't guarantee future returns. Always consider market conditions and your risk tolerance.</li>
        <li><strong>Compare similar investments</strong> — Annualized ROI allows you to fairly compare a 5-year real estate investment with a 2-year stock investment.</li>
      </ul>
    </section>
    <section class="faq">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>What is ROI (Return on Investment)?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>ROI is a performance metric used to evaluate the profitability of an investment. It measures the gain or loss generated relative to the amount invested. A positive ROI means the investment profited; a negative ROI indicates a loss.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>How to calculate annualized ROI?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>Annualized ROI adjusts the return to a yearly rate, allowing comparison of investments held for different periods. Formula: Annualized ROI = ((1 + ROI%)^(1/years) - 1) x 100. For example, 50% return over 2 years = ((1.50)^(0.5) - 1) x 100 = 22.47% annually.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>What is a good ROI?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>A "good" ROI depends on the investment type and risk tolerance. For stock market investments, 7-10% annually is considered solid. Real estate typically aims for 8-12%. Realistic expectations vary by asset class: stocks 6-10%, bonds 2-5%, real estate 8-12%.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>Should I include additional costs in ROI calculation?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>Yes, including all costs (transaction fees, taxes, maintenance, holding costs) gives a more accurate picture of actual returns. Many investors overlook these, leading to overestimated profits.</p>
        </div>
      </div>
    </section>

    <section class="related-tools">
      <h2>Related Tools</h2>
      <div class="related-tools-grid">
        <a href="/compound-interest-calculator" class="related-tool-card">
          <span class="related-icon">🏦</span>
          <span class="related-name">Compound Interest Calculator</span>
        </a>
        <a href="/mortgage-calculator" class="related-tool-card">
          <span class="related-icon">🏠</span>
          <span class="related-name">Mortgage Calculator</span>
        </a>
        <a href="/crypto-profit-calculator" class="related-tool-card">
          <span class="related-icon">🪙</span>
          <span class="related-name">Crypto Profit Calculator</span>
        </a>
        <a href="/loan-calculator" class="related-tool-card">
          <span class="related-icon">💰</span>
          <span class="related-name">Loan Calculator</span>
        </a>
      </div>
    </section>
  </section>

  <script is:inline>
    function calculateROI() {
      var investment = parseFloat(document.getElementById('investmentAmount').value) || 0;
      var finalValue = parseFloat(document.getElementById('finalValue').value) || 0;
      var additionalCosts = parseFloat(document.getElementById('additionalCosts').value) || 0;
      var years = parseFloat(document.getElementById('holdingPeriod').value) || 1;
      
      var totalInvestment = investment + additionalCosts;
      var netProfit = finalValue - totalInvestment;
      var roi = investment > 0 ? (netProfit / investment) * 100 : 0;
      
      var annualizedROI = 0;
      if (years > 0 && roi > -100) {
        annualizedROI = (Math.pow((finalValue / totalInvestment), (1 / years)) - 1) * 100;
      }
      
      document.getElementById('roiPercent').textContent = roi.toFixed(2) + '%';
      document.getElementById('roiPercent').style.color = roi >= 0 ? '#10B981' : '#EF4444';
      
      document.getElementById('netProfit').textContent = (netProfit >= 0 ? '$' : '-$') + formatNumber(Math.abs(Math.round(netProfit)));
      document.getElementById('netProfit').style.color = netProfit >= 0 ? '#10B981' : '#EF4444';
      
      document.getElementById('annualizedROI').textContent = annualizedROI.toFixed(2) + '%';
      document.getElementById('annualizedROI').style.color = annualizedROI >= 0 ? '#F59E0B' : '#EF4444';
      
      document.getElementById('totalInvestment').textContent = '$' + formatNumber(Math.round(totalInvestment));
      document.getElementById('totalReturn').textContent = '$' + formatNumber(Math.round(finalValue));
      
      document.getElementById('result').style.display = 'block';
    }
    
    function formatNumber(num) {
      return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    }
    
    calculateROI();
  </script>
</BaseLayout>
