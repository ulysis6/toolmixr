---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "Discount Calculator";
const pageUrl = "https://toolmixr.com/discount-calculator";

const structuredData = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": pageTitle,
    "url": pageUrl,
    "description": "Free online discount calculator to calculate sale price, amount saved, and final price with tax. Find out how much you are really saving.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do I calculate a discount?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Discount calculation: Final Price = Original Price x (1 - Discount%). For example, 25% off $100: $100 x (1 - 0.25) = $100 x 0.75 = $75. The amount saved = Original Price x Discount%. So $100 x 0.25 = $25 saved."
        }
      },
      {
        "@type": "Question",
        "name": "How do I calculate sale price with tax?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "First calculate the discounted price, then add tax: Final = Discounted Price x (1 + Tax Rate). For example, $75 item with 8% tax: $75 x 1.08 = $81. Total paid = $81, total tax = $6."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between markdown and discount?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "In practice, these terms are used interchangeably. Technically, a \"markdown\" usually refers to a price reduction from the original MSRP (suggested price), while a \"discount\" often implies a promotional reduction from the current selling price. Both result in paying less."
        }
      },
      {
        "@type": "Question",
        "name": "How do stores calculate \"X% off plus an additional Y%\"?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "This is a common marketing trick. \"Extra 20% off sale items\" means the discount applies sequentially. 30% off + extra 20%: Price = Original x 0.70 x 0.80 = 56% of original. This is NOT 50% off. Always calculate the final price, not just add percentages."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://toolmixr.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": pageTitle,
        "item": pageUrl
      }
    ]
  }
]);
---

<BaseLayout 
  title={pageTitle} 
  description="Free online discount calculator to calculate sale price, amount saved, and final price with tax. Find out how much you are really saving."
  structuredData={structuredData}
>
  <section class="tool-page">
  <nav class="breadcrumb">
    <a href="/">Home</a> <span class="breadcrumb-sep">›</span> <span>Discount Calculator</span>
  </nav>
  <div class="tool-header">
    <h1>🏷️ Discount Calculator</h1>
    <div class="share-bar">
      <a class="share-btn share-twitter" href="#" onclick="shareTwitter(event)" title="Share on Twitter">𝕏</a>
      <a class="share-btn share-facebook" href="#" onclick="shareFacebook(event)" title="Share on Facebook">f</a>
      <a class="share-btn share-linkedin" href="#" onclick="shareLinkedIn(event)" title="Share on LinkedIn">in</a>
      <a class="share-btn share-reddit" href="#" onclick="shareReddit(event)" title="Share on Reddit">R</a>
      <button class="share-btn share-copy" onclick="copyPageLink(event)" title="Copy link">🔗</button>
    </div>
  </div>
  <p class="subtitle">Calculate sale prices, savings, and final cost including tax</p>
    
    <div class="tool-box">
      <div class="form-group">
        <label for="originalPrice">Original Price ($)</label>
        <input type="number" id="originalPrice" value="149.99" min="0" step="0.01" oninput="calculateDiscount()" />
      </div>
      
      <div class="form-group">
        <label for="discountPercent">Discount: <span id="discountPercentVal">25</span>%</label>
        <input type="range" id="discountPercent" min="5" max="90" value="25" oninput="document.getElementById('discountPercentVal').textContent=this.value;calculateDiscount()" style="width:100%;" />
        <div style="display:flex;justify-content:space-between;font-size:12px;color:var(--text-secondary);margin-top:4px;">
          <span>5%</span>
          <span>20%</span>
          <span>40%</span>
          <span>60%</span>
          <span>80%</span>
        </div>
      </div>
      
      <div style="display:flex;gap:8px;margin-bottom:20px;">
        <button class="btn btn-secondary quick-discount" onclick="setDiscount(10)" style="padding:6px 12px;font-size:12px;">10%</button>
        <button class="btn btn-secondary quick-discount" onclick="setDiscount(20)" style="padding:6px 12px;font-size:12px;">20%</button>
        <button class="btn btn-primary quick-discount" onclick="setDiscount(25)" style="padding:6px 12px;font-size:12px;border:1px solid var(--primary);">25%</button>
        <button class="btn btn-secondary quick-discount" onclick="setDiscount(50)" style="padding:6px 12px;font-size:12px;">50%</button>
        <button class="btn btn-secondary quick-discount" onclick="setDiscount(70)" style="padding:6px 12px;font-size:12px;">70%</button>
      </div>
      
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;padding:16px;background:var(--bg);border-radius:var(--radius);">
        <input type="checkbox" id="includeTax" onchange="calculateDiscount()" />
        <label for="includeTax" style="margin-bottom:0;font-weight:400;">Include sales tax</label>
        <div class="form-group" id="taxSection" style="display:none;flex:1;margin-bottom:0;">
          <input type="number" id="taxRate" value="8.25" min="0" max="25" step="0.25" oninput="calculateDiscount()" placeholder="Tax %" style="width:100px;" />
        </div>
      </div>
      
      <div id="result" style="margin-top:24px;">
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:16px;">
          <div style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:20px;text-align:center;">
            <div style="font-size:13px;color:var(--text-secondary);margin-bottom:4px;">You Save</div>
            <div style="font-size:28px;font-weight:700;color:#10B981;" id="savings">$0.00</div>
          </div>
          <div style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:20px;text-align:center;">
            <div style="font-size:13px;color:var(--text-secondary);margin-bottom:4px;">Sale Price</div>
            <div style="font-size:28px;font-weight:700;color:var(--primary);" id="salePrice">$0.00</div>
            <div style="text-decoration:line-through;font-size:12px;color:var(--text-secondary);" id="originalPriceDisplay">$0.00</div>
          </div>
          <div style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:20px;text-align:center;" id="taxResultContainer">
            <div style="font-size:13px;color:var(--text-secondary);margin-bottom:4px;">Final Price (with tax)</div>
            <div style="font-size:28px;font-weight:700;color:#F59E0B;" id="finalPrice">$0.00</div>
          </div>
        </div>
        
        <div style="margin-top:24px;padding:16px;background:#F3F4F6;border-radius:var(--radius);">
          <h3 style="font-size:14px;margin-bottom:12px;">How discount was calculated</h3>
          <div id="calculation" style="font-size:13px;line-height:1.8;"></div>
        </div>
        
        <div style="margin-top:16px;padding:16px;background:var(--bg);border-radius:var(--radius);font-size:13px;">
          <h3 style="font-size:14px;margin-bottom:12px;">💡 Related Calculations</h3>
          <div style="display:grid;gap:8px;color:var(--text-secondary);">
            <div id="doubleDiscount">If doubled (50% off): -</div>
            <div id="tripleDiscount">Triple coupon ($10+$10+$10): -</div>
            <div id="pricePerUnit">Price per $100 spent: -</div>
          </div>
        </div>
      </div>
    

    <section class="guide">
      <h2>How to Use the Discount Calculator</h2>
      <p>Calculate sale prices, savings, and final costs instantly. See exactly how much you're saving and what you'll pay after the discount — with optional sales tax calculation. Perfect for smart shopping and comparing deals.</p>
      
      <h3>Step-by-Step Guide</h3>
      <ol>
        <li><strong>Enter the original price</strong> — This is the full, regular price before any discounts.</li>
        <li><strong>Set the discount percentage</strong> — Use the slider or enter the discount percentage directly. Common discounts range from 10% to 50%.</li>
        <li><strong>Add sales tax (optional)</strong> — Enter your local sales tax rate to see the final amount you'll pay at checkout.</li>
        <li><strong>Review the results</strong> — See the sale price, amount saved, and final price including tax.</li>
      </ol>
      
      <h3>Tips & Best Practices</h3>
      <ul>
        <li><strong>Stacked discounts do not add</strong> — 50% off then another 50% off does NOT equal 100% off. It equals 75% off (0.50 times 0.50 = 0.25 remaining, so 75% savings).</li>
        <li><strong>Compare final prices, not percentages</strong> — A 30% discount on a $20 item ($6 savings) is worse than 20% off a $100 item ($20 savings).</li>
        <li><strong>Price per unit matters</strong> — When comparing bulk deals, always calculate the per-unit price to find the true best deal.</li>
        <li><strong>Watch for fake discounts</strong> — Some retailers raise prices before a "sale." Tools like camelcamelcamel can help verify if a deal is actually good.</li>
      </ul>
    </section>
    <section class="faq">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>How do I calculate a discount?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>Discount calculation: Final Price = Original Price x (1 - Discount%). For example, 25% off $100: $100 x (1 - 0.25) = $100 x 0.75 = $75. The amount saved = Original Price x Discount%. So $100 x 0.25 = $25 saved.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>How do I calculate sale price with tax?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>First calculate the discounted price, then add tax: Final = Discounted Price x (1 + Tax Rate). For example, $75 item with 8% tax: $75 x 1.08 = $81. Total paid = $81, total tax = $6.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>What is the difference between markdown and discount?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>In practice, these terms are used interchangeably. Technically, a "markdown" usually refers to a price reduction from the original MSRP (suggested price), while a "discount" often implies a promotional reduction from the current selling price. Both result in paying less.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>How do stores calculate "X% off plus an additional Y%"?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>This is a common marketing trick. "Extra 20% off sale items" means the discount applies sequentially. 30% off + extra 20%: Price = Original x 0.70 x 0.80 = 56% of original. This is NOT 50% off. Always calculate the final price, not just add percentages.</p>
        </div>
      </div>
    </section>

    <section class="related-tools">
      <h2>Related Tools</h2>
      <div class="related-tools-grid">
        <a href="/percentage-calculator" class="related-tool-card">
          <span class="related-icon">🔣</span>
          <span class="related-name">Percentage Calculator</span>
        </a>
        <a href="/tip-calculator" class="related-tool-card">
          <span class="related-icon">🧾</span>
          <span class="related-name">Tip Calculator</span>
        </a>
        <a href="/roi-calculator" class="related-tool-card">
          <span class="related-icon">📈</span>
          <span class="related-name">ROI Calculator</span>
        </a>
        <a href="/loan-calculator" class="related-tool-card">
          <span class="related-icon">💰</span>
          <span class="related-name">Loan Calculator</span>
        </a>
      </div>
    </section>
  </section>

  <script is:inline>
    function setDiscount(percent) {
      document.getElementById('discountPercent').value = percent;
      document.getElementById('discountPercentVal').textContent = percent;
      
      var buttons = document.querySelectorAll('.quick-discount');
      for (var i = 0; i < buttons.length; i++) {
        buttons[i].className = 'btn btn-secondary quick-discount';
        buttons[i].style.border = '1px solid var(--border)';
      }
      event.target.className = 'btn btn-primary quick-discount';
      event.target.style.border = '1px solid var(--primary)';
      
      calculateDiscount();
    }
    
    function calculateDiscount() {
      var originalPrice = parseFloat(document.getElementById('originalPrice').value) || 0;
      var discountPercent = parseInt(document.getElementById('discountPercent').value) || 0;
      var includeTax = document.getElementById('includeTax').checked;
      var taxRate = parseFloat(document.getElementById('taxRate').value) || 0;
      
      document.getElementById('taxSection').style.display = includeTax ? 'flex' : 'none';
      document.getElementById('taxResultContainer').style.display = includeTax ? 'block' : 'none';
      
      if (originalPrice <= 0) {
        document.getElementById('savings').textContent = '$0.00';
        document.getElementById('salePrice').textContent = '$0.00';
        document.getElementById('originalPriceDisplay').textContent = '$0.00';
        document.getElementById('finalPrice').textContent = '$0.00';
        return;
      }
      
      var discountDecimal = discountPercent / 100;
      var savings = originalPrice * discountDecimal;
      var salePrice = originalPrice - savings;
      var taxAmount = includeTax ? salePrice * (taxRate / 100) : 0;
      var finalPrice = salePrice + taxAmount;
      
      document.getElementById('savings').textContent = '$' + formatCurrency(savings);
      document.getElementById('salePrice').textContent = '$' + formatCurrency(salePrice);
      document.getElementById('originalPriceDisplay').textContent = '$' + formatCurrency(originalPrice);
      document.getElementById('finalPrice').textContent = '$' + formatCurrency(finalPrice);
      
      var calculation = '';
      calculation += '$' + formatCurrency(originalPrice) + ' x ' + discountPercent + '% off<br>';
      calculation += '= $' + formatCurrency(originalPrice) + ' - $' + formatCurrency(savings) + '<br>';
      calculation += '= <strong>$' + formatCurrency(salePrice) + '</strong>';
      if (includeTax) {
        calculation += '<br><br>+$' + formatCurrency(taxAmount) + ' tax (' + taxRate + '%)';
        calculation += '<br>= $' + formatCurrency(finalPrice);
      }
      document.getElementById('calculation').innerHTML = calculation;
      
      var doubleDiscount = originalPrice * 0.5;
      document.getElementById('doubleDiscount').textContent = 'If doubled (50% off): $' + formatCurrency(doubleDiscount);
      
      var tripleDiscount = Math.max(0, originalPrice - 30);
      document.getElementById('tripleDiscount').textContent = 'Triple coupon ($10+$10+$10): $' + formatCurrency(tripleDiscount);
      
      var pricePerUnit = 100 / salePrice;
      document.getElementById('pricePerUnit').textContent = 'Price per $100 spent: $' + formatCurrency(100) + ' gets you $' + formatCurrency(pricePerUnit * 100) + ' value';
    }
    
    function formatCurrency(amount) {
      return amount.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    }
    
    calculateDiscount();
  </script>
</BaseLayout>
