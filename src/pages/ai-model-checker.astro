<script is:inline>
  var models = [
    { name: "Phi-4-Mini 3.8B", minVram: 3, recVram: 4, minRam: 8, quant: "Q4", notes: "Reasoning on any hardware" },
    { name: "Qwen 3.5-4B", minVram: 3, recVram: 5, minRam: 8, quant: "Q4", notes: "Lightweight coding" },
    { name: "Gemma 4 4B", minVram: 4, recVram: 6, minRam: 8, quant: "Q4", notes: "Google's entry model" },
    { name: "Llama 3.1 8B", minVram: 5, recVram: 8, minRam: 16, quant: "Q4", notes: "Good starter model" },
    { name: "Qwen 3.5-9B", minVram: 6, recVram: 8, minRam: 16, quant: "Q4", notes: "Best value, multilingual" },
    { name: "Gemma 4 9B", minVram: 6, recVram: 10, minRam: 16, quant: "Q4", notes: "Recommended starter" },
    { name: "Codestral 22B", minVram: 12, recVram: 16, minRam: 16, quant: "Q4", notes: "Code specialist" },
    { name: "Mistral Small 24B", minVram: 13, recVram: 16, minRam: 16, quant: "Q4", notes: "General assistant" },
    { name: "Gemma 4 27B (MoE)", minVram: 14, recVram: 18, minRam: 16, quant: "Q4", notes: "MoE, 4B active" },
    { name: "Qwen 3.6-27B", minVram: 17, recVram: 24, minRam: 32, quant: "Q4", notes: "Coding specialist (2026)" },
    { name: "Gemma 4 31B", minVram: 20, recVram: 24, minRam: 32, quant: "Q4", notes: "Max Gemma quality" },
    { name: "Qwen 3.6-35B-A3B (MoE)", minVram: 21, recVram: 24, minRam: 32, quant: "Q4", notes: "MoE, 3B active (2026)" },
    { name: "Llama 4 Scout", minVram: 61, recVram: 80, minRam: 64, quant: "Q4", notes: "Needs multi-GPU" },
    { name: "DeepSeek V4 Flash", minVram: 80, recVram: 160, minRam: 128, quant: "Q4", notes: "Expert / datacenter" },
    { name: "FLUX.2 Klein 4B", minVram: 8, recVram: 13, minRam: 16, quant: "N/A", notes: "Fast image gen (2026)" },
    { name: "FLUX.1 Dev", minVram: 8, recVram: 17, minRam: 16, quant: "N/A", notes: "Quality image gen" },
    { name: "SDXL", minVram: 6, recVram: 12, minRam: 16, quant: "N/A", notes: "Mainstream image gen" },
    { name: "Whisper Large V3 Turbo", minVram: 4, recVram: 6, minRam: 16, quant: "N/A", notes: "Speech to text" }
  ];

  function updateGpuInfo() {
    // no-op for now
  }

  function checkModels() {
    var gpuSelect = document.getElementById('gpuSelect');
    var vram = parseInt(gpuSelect.options[gpuSelect.selectedIndex].value);
    var gpuName = gpuSelect.options[gpuSelect.selectedIndex].text;
    var ram = parseInt(document.getElementById('ramSelect').value);
    var ramName = ram + ' GB';

    document.getElementById('resultGpu').textContent = gpuName;
    document.getElementById('resultRam').textContent = ramName;

    var tbody = document.getElementById('resultBody');
    tbody.innerHTML = '';

    for (var i = 0; i < models.length; i++) {
      var m = models[i];
      var status, statusClass, statusIcon;

      var vramMeetsMin = (vram === 0) || (vram >= m.minVram);
      var vramMeetsRec = (vram === 0) || (vram >= m.recVram);
      var ramMeetsMin = ram >= m.minRam;

      if (vramMeetsMin && vramMeetsRec && ramMeetsMin) {
        status = "Can Run";
        statusClass = "color:#10B981;font-weight:600;";
        statusIcon = "✅";
      } else if (vramMeetsMin && ramMeetsMin) {
        status = "May Run (Slow)";
        statusClass = "color:#F59E0B;font-weight:600;";
        statusIcon = "⚠️";
      } else {
        status = "Cannot Run";
        statusClass = "color:#EF4444;font-weight:600;";
        statusIcon = "❌";
      }

      var tr = document.createElement('tr');
      tr.style.borderBottom = '1px solid var(--border)';
      tr.innerHTML = '<td style="padding:10px 12px;">' + m.name + '</td>' +
        '<td style="padding:10px 12px;text-align:center;">' + m.quant + '</td>' +
        '<td style="padding:10px 12px;text-align:center;">' + m.minVram + 'GB</td>' +
        '<td style="padding:10px 12px;text-align:center;">' + m.recVram + 'GB</td>' +
        '<td style="padding:10px 12px;text-align:center;">' + m.minRam + 'GB</td>' +
        '<td style="padding:10px 12px;">' + m.notes + '</td>' +
        '<td style="padding:10px 12px;text-align:center;' + statusClass + '">' + statusIcon + ' ' + status + '</td>';
      tbody.appendChild(tr);
    }

    document.getElementById('result').style.display = 'block';
  }
</script>
</BaseLayout>
