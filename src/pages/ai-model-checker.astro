---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "AI Model Checker - Can Your PC Run Local LLMs?";
const pageUrl = "https://toolmixr.com/ai-model-checker";

const structuredData = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": pageTitle,
    "url": pageUrl,
    "description": "Check if your GPU and RAM can run local AI models like Qwen 3.6, Gemma 4, Llama 4, DeepSeek V4, and more. Compare your hardware against VRAM and RAM requirements for popular LLMs and image generation models.",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Can I run LLMs on a Mac with Apple Silicon?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes! Apple Silicon Macs (M1/M2/M3/M4/M5) use unified memory, which means the GPU can access all available RAM as VRAM. This makes them surprisingly capable for running local LLMs. An M5 Pro with 64GB unified memory can comfortably run Qwen 3.6-27B or Gemma 4 27B MoE at Q4 quantization. Even the base M5 with 16GB unified memory handles smaller models well."
        }
      },
      {
        "@type": "Question",
        "name": "What does quantization (Q4, FP16) mean?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Quantization reduces model precision to save memory. Q4 (4-bit) uses about 25% of the original model size, making it the most popular format for local inference. FP16 (16-bit) uses about 50% and provides better quality but requires much more VRAM. For most users, Q4 quantized models offer the best balance of quality and performance — quality retention is typically 95-98%."
        }
      },
      {
        "@type": "Question",
        "name": "Why does my GPU matter more than RAM for LLMs?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "LLM inference is heavily dependent on VRAM (GPU memory) because the entire model must be loaded into GPU memory for fast inference. While you can offload layers to system RAM, this dramatically slows down generation speed — often to 1-2 tokens per second versus 20-100+ with full GPU loading. Having enough VRAM to load the entire model ensures smooth, fast text generation."
        }
      },
      {
        "@type": "Question",
        "name": "What is MoE and why does it matter for VRAM?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Mixture of Experts (MoE) models like Qwen 3.6-35B-A3B have many total parameters but only activate a fraction per token (e.g., 3B out of 35B). This means faster inference speed, but all parameters still need to be loaded into VRAM. MoE models give you the knowledge of a larger model at the speed of a smaller one — but you still need VRAM for the full parameter set."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://toolmixr.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": pageTitle,
        "item": pageUrl
      }
    ]
  }
]);
