---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Open Graph Image Generator" 
  description="Free online Open Graph image preview and generator. See how your links will look when shared on Facebook, Twitter, and LinkedIn."
>
  <section class="tool-page">
    <h1>🖼️ Open Graph Image Generator</h1>
    <p class="subtitle">Preview and generate OG images for social media sharing</p>
    
    <div class="tool-box">
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <div class="form-group" style="flex:1;min-width:200px;">
          <label for="ogTitle">Title *</label>
          <input type="text" id="ogTitle" placeholder="Your Page Title" maxlength="80" oninput="updatePreview()" />
        </div>
      </div>
      
      <div class="form-group">
        <label for="ogDesc">Description</label>
        <input type="text" id="ogDesc" placeholder="Brief description of your page" maxlength="200" oninput="updatePreview()" />
        </div>
      
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <div class="form-group" style="flex:1;min-width:200px;">
          <label for="ogDomain">Domain</label>
          <input type="text" id="ogDomain" placeholder="example.com" oninput="updatePreview()" />
        </div>
        <div class="form-group" style="flex:1;min-width:200px;">
          <label for="ogBg">Background Color</label>
          <input type="color" id="ogBg" value="#4F46E5" onchange="updatePreview()" style="width:100%;height:38px;border:1px solid var(--border);border-radius:var(--radius);cursor:pointer;" />
        </div>
      </div>
      
      <h3 style="margin:20px 0 12px;font-size:15px;">Preview</h3>
      
      <!-- Facebook/Twitter Card Preview -->
      <div style="border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;max-width:500px;">
        <div id="ogImagePreview" style="background:#4F46E5;padding:40px 30px;min-height:120px;display:flex;align-items:center;justify-content:center;">
          <div style="text-align:center;color:white;">
            <div id="previewTitle" style="font-size:24px;font-weight:800;line-height:1.3;"></div>
          </div>
        </div>
        <div style="background:#f0f0f0;padding:10px 14px;">
          <div id="previewDomain" style="font-size:12px;color:#65676c;text-transform:uppercase;"></div>
          <div id="previewTitle2" style="font-size:15px;font-weight:600;color:#050505;margin-top:2px;"></div>
          <div id="previewDesc" style="font-size:13px;color:#65676c;margin-top:2px;"></div>
        </div>
      </div>
      
      <div style="margin-top:16px;">
        <h3 style="font-size:15px;margin-bottom:8px;">OG Meta Tags</h3>
        <div class="output-box" id="output" style="display:block;">
          <button class="copy-btn" onclick="copyOutput()">Copy</button>
          <pre id="code"></pre>
        </div>
      </div>
    </div>
    
    <section class="faq">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <h3>What is an Open Graph image?</h3>
        <p>An Open Graph (OG) image is the preview image that appears when your link is shared on social media platforms like Facebook, Twitter, LinkedIn, and Slack. The recommended size is 1200×630 pixels.</p>
      </div>
      <div class="faq-item">
        <h3>Why is my OG image not showing?</h3>
        <p>Social platforms cache OG data aggressively. After updating your tags, use Facebook's Sharing Debugger or Twitter's Card Validator to force a re-scrape. Also ensure your image URL is publicly accessible and uses HTTPS.</p>
      </div>
      <div class="faq-item">
        <h3>What are the ideal OG image dimensions?</h3>
        <p>1200×630 pixels is the standard for Facebook and LinkedIn. Twitter's summary_large_image cards also use this ratio. Always use images at least 600×315 as a minimum.</p>
      </div>
    </section>
  </section>

  <script is:inline>
    function updatePreview() {
      var title = document.getElementById('ogTitle').value;
      var desc = document.getElementById('ogDesc').value;
      var domain = document.getElementById('ogDomain').value;
      var bg = document.getElementById('ogBg').value;
      
      document.getElementById('previewTitle').textContent = title || 'Your Title Here';
      document.getElementById('previewDomain').textContent = domain || 'example.com';
      document.getElementById('previewTitle2').textContent = title || 'Your Title Here';
      document.getElementById('previewDesc').textContent = desc || '';
      document.getElementById('ogImagePreview').style.background = bg;
      
      var tags = [];
      tags.push('<meta property="og:type" content="website">');
      if (title) tags.push('<meta property="og:title" content="' + title + '">');
      if (desc) tags.push('<meta property="og:description" content="' + desc + '">');
      tags.push('<meta property="og:image" content="YOUR_IMAGE_URL_HERE">');
      tags.push('<meta property="og:image:width" content="1200">');
      tags.push('<meta property="og:image:height" content="630">');
      tags.push('\n<!-- Twitter Card -->');
      tags.push('<meta name="twitter:card" content="summary_large_image">');
      if (title) tags.push('<meta name="twitter:title" content="' + title + '">');
      if (desc) tags.push('<meta name="twitter:description" content="' + desc + '">');
      tags.push('<meta name="twitter:image" content="YOUR_IMAGE_URL_HERE">');
      
      document.getElementById('code').textContent = tags.join('\n');
    }
    
    updatePreview();
    
    function copyOutput() {
      var code = document.getElementById('code').textContent;
      navigator.clipboard.writeText(code).then(function() {
        document.querySelector('.copy-btn').textContent = 'Copied!';
        setTimeout(function() { document.querySelector('.copy-btn').textContent = 'Copy'; }, 2000);
      });
    }
  </script>
</BaseLayout>
