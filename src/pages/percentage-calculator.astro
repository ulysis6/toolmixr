---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "Percentage Calculator";
const pageUrl = "https://toolmixr.com/percentage-calculator";

const structuredData = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": pageTitle,
    "url": pageUrl,
    "description": "Free online percentage calculator with three modes: find X% of Y, calculate what percent X is of Y, and calculate percentage change between two values.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How to calculate X% of Y?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Formula: X% of Y = (X / 100) x Y. For example, 25% of 200 = (25 / 100) x 200 = 0.25 x 200 = 50. In decimal form: multiply the percentage (as decimal) by the total."
        }
      },
      {
        "@type": "Question",
        "name": "How to find what percent X is of Y?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Formula: (X / Y) x 100. For example, what percent is 30 of 150? (30 / 150) x 100 = 0.2 x 100 = 20%. So 30 is 20% of 150."
        }
      },
      {
        "@type": "Question",
        "name": "What is percentage change?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Percentage change shows how much a value has increased or decreased relative to the original. Formula: ((New - Original) / Original) x 100. A positive result is an increase; negative is a decrease. Example: $50 to $75 = ((75 - 50) / 50) x 100 = 50% increase."
        }
      },
      {
        "@type": "Question",
        "name": "What's the difference between percentage points and percent?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Percentage points measure absolute difference between two percentages. Percent measures relative change. If interest rates go from 5% to 7%, that's a 2 percentage point increase, but a 40% relative increase (2/5 x 100). Use percentage points for comparing rates, percent for measuring growth."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://toolmixr.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": pageTitle,
        "item": pageUrl
      }
    ]
  }
]);
---

<BaseLayout 
  title={pageTitle} 
  description="Free online percentage calculator with three modes: find X% of Y, calculate what percent X is of Y, and calculate percentage change between two values."
  structuredData={structuredData}
>
  <section class="tool-page">
    <h1>🔣 Percentage Calculator</h1>
    <p class="subtitle">Calculate percentages three different ways - pick your calculation mode</p>
    
    <div class="tool-box">
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:20px;" id="modeButtons">
        <button class="btn btn-primary action-btn" onclick="setMode(this, 'whatIs')" style="border:1px solid var(--primary);">X% of Y = ?</button>
        <button class="btn btn-secondary action-btn" onclick="setMode(this, 'whatPercent')">X is what % of Y?</button>
        <button class="btn btn-secondary action-btn" onclick="setMode(this, 'change')">% Change</button>
      </div>
      
      <div id="whatIsSection">
        <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;">
          <div class="form-group" style="flex:1;min-width:120px;margin-bottom:0;">
            <input type="number" id="whatIsX" placeholder="X" value="25" oninput="calculateWhatIs()" style="text-align:center;font-size:18px;" />
          </div>
          <div style="font-size:24px;font-weight:bold;color:var(--text-secondary);">% of</div>
          <div class="form-group" style="flex:1;min-width:120px;margin-bottom:0;">
            <input type="number" id="whatIsY" placeholder="Y" value="200" oninput="calculateWhatIs()" style="text-align:center;font-size:18px;" />
          </div>
          <div style="font-size:24px;font-weight:bold;color:var(--text-secondary);">=</div>
          <div class="form-group" style="flex:1;min-width:120px;margin-bottom:0;">
            <input type="text" id="whatIsResult" readonly style="text-align:center;font-size:18px;font-weight:bold;background:var(--bg);" />
          </div>
        </div>
      </div>
      
      <div id="whatPercentSection" style="display:none;">
        <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;">
          <div class="form-group" style="flex:1;min-width:120px;margin-bottom:0;">
            <input type="number" id="whatPercentX" placeholder="X" oninput="calculateWhatPercent()" style="text-align:center;font-size:18px;" />
          </div>
          <div style="font-size:24px;font-weight:bold;color:var(--text-secondary);">is what % of</div>
          <div class="form-group" style="flex:1;min-width:120px;margin-bottom:0;">
            <input type="number" id="whatPercentY" placeholder="Y" oninput="calculateWhatPercent()" style="text-align:center;font-size:18px;" />
          </div>
          <div style="font-size:24px;font-weight:bold;color:var(--text-secondary);">=</div>
          <div class="form-group" style="flex:1;min-width:120px;margin-bottom:0;">
            <input type="text" id="whatPercentResult" readonly style="text-align:center;font-size:18px;font-weight:bold;background:var(--bg);" />
          </div>
        </div>
      </div>
      
      <div id="changeSection" style="display:none;">
        <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;">
          <div class="form-group" style="flex:1;min-width:120px;margin-bottom:0;">
            <input type="number" id="changeFrom" placeholder="From" oninput="calculateChange()" style="text-align:center;font-size:18px;" />
          </div>
          <div style="font-size:24px;font-weight:bold;color:var(--text-secondary);">→</div>
          <div class="form-group" style="flex:1;min-width:120px;margin-bottom:0;">
            <input type="number" id="changeTo" placeholder="To" oninput="calculateChange()" style="text-align:center;font-size:18px;" />
          </div>
          <div style="font-size:24px;font-weight:bold;color:var(--text-secondary);">=</div>
          <div class="form-group" style="flex:1;min-width:120px;margin-bottom:0;">
            <input type="text" id="changeResult" readonly style="text-align:center;font-size:18px;font-weight:bold;background:var(--bg);" />
          </div>
        </div>
      </div>
      
      <div id="examplesSection" style="margin-top:24px;padding:16px;background:var(--bg);border-radius:var(--radius);">
        <h3 style="font-size:14px;margin-bottom:8px;">Quick Examples</h3>
        <div id="examples" style="font-size:13px;color:var(--text-secondary);"></div>
      </div>
    </div>
    
    <section class="faq">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <h3>How to calculate X% of Y?</h3>
        <p>Formula: X% of Y = (X / 100) x Y. For example, 25% of 200 = (25 / 100) x 200 = 0.25 x 200 = 50. In decimal form: multiply the percentage (as decimal) by the total.</p>
      </div>
      <div class="faq-item">
        <h3>How to find what percent X is of Y?</h3>
        <p>Formula: (X / Y) x 100. For example, what percent is 30 of 150? (30 / 150) x 100 = 0.2 x 100 = 20%. So 30 is 20% of 150.</p>
      </div>
      <div class="faq-item">
        <h3>What is percentage change?</h3>
        <p>Percentage change shows how much a value has increased or decreased relative to the original. Formula: ((New - Original) / Original) x 100. A positive result is an increase; negative is a decrease. Example: $50 to $75 = ((75 - 50) / 50) x 100 = 50% increase.</p>
      </div>
      <div class="faq-item">
        <h3>What's the difference between percentage points and percent?</h3>
        <p>Percentage points measure absolute difference between two percentages. Percent measures relative change. If interest rates go from 5% to 7%, that's a 2 percentage point increase, but a 40% relative increase (2/5 x 100). Use percentage points for comparing rates, percent for measuring growth.</p>
      </div>
    </section>

    <section class="related-tools">
      <h2>Related Tools</h2>
      <div class="related-tools-grid">
        <a href="/discount-calculator" class="related-tool-card">
          <span class="related-icon">🏷️</span>
          <span class="related-name">Discount Calculator</span>
        </a>
        <a href="/tip-calculator" class="related-tool-card">
          <span class="related-icon">🧾</span>
          <span class="related-name">Tip Calculator</span>
        </a>
        <a href="/bmi-calculator" class="related-tool-card">
          <span class="related-icon">⚖️</span>
          <span class="related-name">BMI Calculator</span>
        </a>
        <a href="/roi-calculator" class="related-tool-card">
          <span class="related-icon">📈</span>
          <span class="related-name">ROI Calculator</span>
        </a>
      </div>
    </section>
  </section>

  <script is:inline>
    var currentMode = 'whatIs';
    
    function setMode(btn, mode) {
      currentMode = mode;
      var btns = document.querySelectorAll('.action-btn');
      for (var i = 0; i < btns.length; i++) {
        btns[i].className = 'btn btn-secondary action-btn';
      }
      btn.className = 'btn btn-primary action-btn';
      btn.style.border = '1px solid var(--primary)';
      
      document.getElementById('whatIsSection').style.display = mode === 'whatIs' ? 'block' : 'none';
      document.getElementById('whatPercentSection').style.display = mode === 'whatPercent' ? 'block' : 'none';
      document.getElementById('changeSection').style.display = mode === 'change' ? 'block' : 'none';
      
      updateExamples();
    }
    
    function calculateWhatIs() {
      var x = parseFloat(document.getElementById('whatIsX').value);
      var y = parseFloat(document.getElementById('whatIsY').value);
      if (!isNaN(x) && !isNaN(y) && y !== 0) {
        var result = (x / 100) * y;
        document.getElementById('whatIsResult').value = formatNumber(result);
      } else {
        document.getElementById('whatIsResult').value = '';
      }
    }
    
    function calculateWhatPercent() {
      var x = parseFloat(document.getElementById('whatPercentX').value);
      var y = parseFloat(document.getElementById('whatPercentY').value);
      if (!isNaN(x) && !isNaN(y) && y !== 0) {
        var result = (x / y) * 100;
        document.getElementById('whatPercentResult').value = formatNumber(result) + '%';
      } else {
        document.getElementById('whatPercentResult').value = '';
      }
    }
    
    function calculateChange() {
      var from = parseFloat(document.getElementById('changeFrom').value);
      var to = parseFloat(document.getElementById('changeTo').value);
      if (!isNaN(from) && !isNaN(to) && from !== 0) {
        var change = ((to - from) / Math.abs(from)) * 100;
        var sign = change >= 0 ? '+' : '';
        document.getElementById('changeResult').value = sign + formatNumber(change) + '%';
      } else {
        document.getElementById('changeResult').value = '';
      }
    }
    
    function updateExamples() {
      var examples = {
        whatIs: [
          '15% of 80 = 12',
          '20% of 150 = 30',
          '8% of 500 = 40',
          '12.5% of 200 = 25'
        ],
        whatPercent: [
          '25 of 100 = 25%',
          '15 of 60 = 25%',
          '40 of 200 = 20%',
          '7 of 28 = 25%'
        ],
        change: [
          '100 → 125 = +25%',
          '80 → 60 = -25%',
          '50 → 75 = +50%',
          '200 → 150 = -25%'
        ]
      };
      document.getElementById('examples').innerHTML = examples[currentMode].map(function(e) { return '<div>' + e + '</div>'; }).join('');
    }
    
    function formatNumber(num) {
      var n = parseFloat(num);
      if (isNaN(n)) return '';
      return n.toLocaleString('en-US', { maximumFractionDigits: 4 });
    }
    
    calculateWhatIs();
    updateExamples();
  </script>
</BaseLayout>
