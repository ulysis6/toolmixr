  <script is:inline>
    var compressedFiles = [];

    function formatSize(bytes) {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
      return (bytes / 1048576).toFixed(2) + ' MB';
    }

    function updateQuality(val) {
      document.getElementById('qualityVal').textContent = val;
      if (compressedFiles.length > 0) recompressAll();
    }

    function setupDropZone() {
      var dropZone = document.getElementById('dropZone');
      var fileInput = document.getElementById('fileInput');

      dropZone.addEventListener('click', function() {
        fileInput.click();
      });

      dropZone.addEventListener('dragover', function(e) {
        e.preventDefault();
        dropZone.classList.add('drag-over');
      });

      dropZone.addEventListener('dragleave', function(e) {
        e.preventDefault();
        dropZone.classList.remove('drag-over');
      });

      dropZone.addEventListener('drop', function(e) {
        e.preventDefault();
        dropZone.classList.remove('drag-over');
        handleFiles(e.dataTransfer.files);
      });

      fileInput.addEventListener('change', function() {
        handleFiles(this.files);
        this.value = '';
      });
    }

    function handleFiles(files) {
      for (var i = 0; i < files.length; i++) {
        var file = files[i];
        if (file.type === 'image/jpeg' || file.type === 'image/png' || file.type === 'image/webp') {
          compressFile(file);
        }
      }
    }

    function compressFile(file) {
      var quality = parseInt(document.getElementById('qualitySlider').value) / 100;
      var reader = new FileReader();
      reader.onload = function(e) {
        var img = new Image();
        img.onload = function() {
          var canvas = document.createElement('canvas');
          canvas.width = img.naturalWidth;
          canvas.height = img.naturalHeight;
          var ctx = canvas.getContext('2d');
          ctx.drawImage(img, 0, 0);

          var mimeType = file.type;
          if (mimeType === 'image/jpg') mimeType = 'image/jpeg';
          var isPng = (mimeType === 'image/png');

          if (isPng) {
            // PNG compression via color quantization (like TinyPNG)
            // Merges similar colors so DEFLATE works better
            var imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
            var data = imageData.data;
            var step = Math.max(1, Math.round((1 - quality) * 32));
            if (step > 1) {
              for (var i = 0; i < data.length; i += 4) {
                data[i] = Math.round(data[i] / step) * step;
                data[i + 1] = Math.round(data[i + 1] / step) * step;
                data[i + 2] = Math.round(data[i + 2] / step) * step;
              }
            }
            ctx.putImageData(imageData, 0, 0);
            canvas.toBlob(function(blob) {
              compressedFiles.push({
                name: file.name, originalSize: file.size, compressedSize: blob ? blob.size : 0,
                blob: blob, previewUrl: e.target.result, width: img.naturalWidth, height: img.naturalHeight, isPng: true
              });
              renderResults();
            }, 'image/png');
          } else {
            // JPG/WebP: native quality parameter
            canvas.toBlob(function(blob) {
              compressedFiles.push({
                name: file.name, originalSize: file.size, compressedSize: blob ? blob.size : 0,
                blob: blob, previewUrl: e.target.result, width: img.naturalWidth, height: img.naturalHeight, isPng: false
              });
              renderResults();
            }, mimeType, quality);
          }
        };
        img.src = e.target.result;
      };
      reader.readAsDataURL(file);
    }

    function recompressAll() {
      var quality = parseInt(document.getElementById('qualitySlider').value) / 100;
      var pending = compressedFiles.length;
      if (pending === 0) return;
      for (var i = 0; i < compressedFiles.length; i++) {
        (function(index) {
          var entry = compressedFiles[index];
          var img = new Image();
          img.onload = function() {
            var canvas = document.createElement('canvas');
            canvas.width = img.naturalWidth;
            canvas.height = img.naturalHeight;
            var ctx = canvas.getContext('2d');
            ctx.drawImage(img, 0, 0);
            if (entry.isPng) {
              var imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
              var data = imageData.data;
              var step = Math.max(1, Math.round((1 - quality) * 32));
              if (step > 1) {
                for (var j = 0; j < data.length; j += 4) {
                  data[j] = Math.round(data[j] / step) * step;
                  data[j + 1] = Math.round(data[j + 1] / step) * step;
                  data[j + 2] = Math.round(data[j + 2] / step) * step;
                }
              }
              ctx.putImageData(imageData, 0, 0);
              canvas.toBlob(function(blob) {
                compressedFiles[index].compressedSize = blob ? blob.size : 0;
                compressedFiles[index].blob = blob;
                pending--;
                if (pending === 0) renderResults();
              }, 'image/png');
            } else {
              var mimeType = entry.name.match(/\.webp$/i) ? 'image/webp' : 'image/jpeg';
              canvas.toBlob(function(blob) {
                compressedFiles[index].compressedSize = blob ? blob.size : 0;
                compressedFiles[index].blob = blob;
                pending--;
                if (pending === 0) renderResults();
              }, mimeType, quality);
            }
          };
          img.src = entry.previewUrl;
        })(i);
      }
    }

    function renderResults() {
      var area = document.getElementById('resultArea');
      area.style.display = 'block';

      var totalOriginal = 0;
      var totalCompressed = 0;
      for (var i = 0; i < compressedFiles.length; i++) {
        totalOriginal += compressedFiles[i].originalSize;
        totalCompressed += compressedFiles[i].compressedSize;
      }
      var totalRatio = totalOriginal > 0 ? ((1 - totalCompressed / totalOriginal) * 100).toFixed(1) : 0;
      document.getElementById('summaryBar').textContent =
        compressedFiles.length + ' image' + (compressedFiles.length !== 1 ? 's' : '') +
        ' | Original: ' + formatSize(totalOriginal) +
        ' → Compressed: ' + formatSize(totalCompressed) +
        ' | Saved: ' + totalRatio + '%';

      var listHtml = '';
      for (var i = 0; i < compressedFiles.length; i++) {
        var entry = compressedFiles[i];
        var ratio = entry.originalSize > 0 ? ((1 - entry.compressedSize / entry.originalSize) * 100).toFixed(1) : 0;
        var ratioClass = parseFloat(ratio) >= 50 ? 'ratio-great' : 'ratio-good';
        listHtml += '<div class="image-item">' +
          '<img class="image-item-preview" src="' + entry.previewUrl + '" alt="' + entry.name + '" />' +
          '<div class="image-item-info">' +
            '<div class="image-item-name">' + entry.name + '</div>' +
            '<div class="image-item-sizes">' +
              formatSize(entry.originalSize) + ' → ' + formatSize(entry.compressedSize) +
              ' <span class="image-item-ratio ' + ratioClass + '">-' + ratio + '%</span>' +
            '</div>' +
          '</div>' +
          '<div class="image-item-action">' +
            '<button class="btn btn-secondary" onclick="downloadOne(' + i + ')" style="font-size:13px;padding:6px 14px;">💾 Save</button>' +
          '</div>' +
        '</div>';
      }
      document.getElementById('imageList').innerHTML = listHtml;
    }

    function downloadOne(index) {
      var entry = compressedFiles[index];
      if (!entry.blob) return;
      var url = URL.createObjectURL(entry.blob);
      var a = document.createElement('a');
      a.href = url;
      a.download = entry.name.replace(/(\.[^.]+)$/, '-compressed$1');
      a.click();
      URL.revokeObjectURL(url);
    }

    function downloadAll() {
      for (var i = 0; i < compressedFiles.length; i++) {
        (function(index) {
          setTimeout(function() { downloadOne(index); }, index * 300);
        })(i);
      }
    }

    function downloadAsZip() {
      if (compressedFiles.length === 0) return;
      var pairs = [];
      for (var i = 0; i < compressedFiles.length; i++) {
        pairs.push({ name: compressedFiles[i].name.replace(/(\.[^.]+)$/, '-compressed$1'), blob: compressedFiles[i].blob });
      }
      createZip(pairs);
    }

    function createZip(files) {
      var LOCAL_FILE_HEADER = '\x50\x4b\x03\x04';
      var CENTRAL_DIR_HEADER = '\x50\x4b\x01\x02';
      var END_RECORD = '\x50\x4b\x05\x06';
      var textEncoder = new TextEncoder();
      var centralDir = [];
      var offset = 0;
      var fileEntries = [];

      for (var i = 0; i < files.length; i++) {
        var fileName = textEncoder.encode(files[i].name);
        var blob = files[i].blob;
        fileEntries.push({ name: fileName, blob: blob });
      }

      var processed = 0;
      var localHeaders = [];

      function processNext() {
        if (processed >= fileEntries.length) {
          buildZip();
          return;
        }
        var entry = fileEntries[processed];
        var reader = new FileReader();
        reader.onload = function(e) {
          var data = new Uint8Array(e.target.result);
          var crc = crc32(data);
          var nameBytes = entry.name;
          var localHeader = new Uint8Array(30 + nameBytes.length + data.length);

          localHeader.set(textEncoder.encode(LOCAL_FILE_HEADER), 0);
          var view = new DataView(localHeader.buffer);
          view.setUint16(4, 20, true);
          view.setUint16(8, 0, true);
          view.setUint16(10, 0, true);
          view.setUint16(12, 0, true);
          view.setUint32(14, crc, true);
          view.setUint32(18, data.length, true);
          view.setUint32(22, data.length, true);
          view.setUint16(26, nameBytes.length, true);
          view.setUint16(28, 0, true);
          localHeader.set(nameBytes, 30);
          localHeader.set(data, 30 + nameBytes.length);

          centralDir.push({
            name: nameBytes,
            crc: crc,
            size: data.length,
            offset: offset
          });

          localHeaders.push(localHeader);
          offset += localHeader.length;
          processed++;
          processNext();
        };
        reader.readAsArrayBuffer(entry.blob);
      }

      function buildZip() {
        var parts = [];
        for (var i = 0; i < localHeaders.length; i++) {
          parts.push(localHeaders[i]);
        }
        var centralOffset = offset;
        var centralSize = 0;
        for (var i = 0; i < centralDir.length; i++) {
          var cd = centralDir[i];
          var cdEntry = new Uint8Array(46 + cd.name.length);
          var view = new DataView(cdEntry.buffer);
          cdEntry.set(textEncoder.encode(CENTRAL_DIR_HEADER), 0);
          view.setUint16(4, 20, true);
          view.setUint16(6, 20, true);
          view.setUint16(10, 0, true);
          view.setUint16(12, 0, true);
          view.setUint16(14, 0, true);
          view.setUint32(16, cd.crc, true);
          view.setUint32(20, cd.size, true);
          view.setUint32(24, cd.size, true);
          view.setUint16(28, cd.name.length, true);
          view.setUint16(30, 0, true);
          view.setUint16(32, 0, true);
          view.setUint16(34, 0, true);
          view.setUint16(36, 0, true);
          view.setUint32(38, 0, true);
          view.setUint32(42, cd.offset, true);
          cdEntry.set(cd.name, 46);
          parts.push(cdEntry);
          centralSize += cdEntry.length;
        }

        var endRecord = new Uint8Array(22);
        var ev = new DataView(endRecord.buffer);
        endRecord.set(textEncoder.encode(END_RECORD), 0);
        ev.setUint16(4, 0, true);
        ev.setUint16(6, 0, true);
        ev.setUint16(8, centralDir.length, true);
        ev.setUint16(10, centralDir.length, true);
        ev.setUint32(12, centralSize, true);
        ev.setUint32(16, centralOffset, true);
        ev.setUint16(20, 0, true);
        parts.push(endRecord);

        var totalLen = 0;
        for (var i = 0; i < parts.length; i++) totalLen += parts[i].length;
        var result = new Uint8Array(totalLen);
        var pos = 0;
        for (var i = 0; i < parts.length; i++) {
          result.set(parts[i], pos);
          pos += parts[i].length;
        }

        var zipBlob = new Blob([result], { type: 'application/zip' });
        var url = URL.createObjectURL(zipBlob);
        var a = document.createElement('a');
        a.href = url;
        a.download = 'compressed-images.zip';
        a.click();
        URL.revokeObjectURL(url);
      }

      processNext();
    }

    function crc32(data) {
      var crc = 0xFFFFFFFF;
      for (var i = 0; i < data.length; i++) {
        crc = crc ^ data[i];
        for (var j = 0; j < 8; j++) {
          if (crc & 1) {
            crc = (crc >>> 1) ^ 0xEDB88320;
          } else {
            crc = crc >>> 1;
          }
        }
      }
      return (crc ^ 0xFFFFFFFF) >>> 0;
    }

    function clearAll() {
      compressedFiles = [];
      document.getElementById('resultArea').style.display = 'none';
      document.getElementById('imageList').innerHTML = '';
      document.getElementById('summaryBar').textContent = '';
    }

    setupDropZone();
  </script>
</BaseLayout>
