---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "Word Counter";
const pageUrl = "https://toolmixr.com/word-counter";

const structuredData = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": pageTitle,
    "url": pageUrl,
    "description": "Free online word counter. Count words, characters, sentences, and paragraphs instantly. Perfect for writers and content creators.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How does the word counter work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Simply type or paste your text into the box above. The tool instantly counts words, characters, sentences, and paragraphs in real-time as you type."
        }
      },
      {
        "@type": "Question",
        "name": "Does the word counter store my text?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. All processing happens in your browser. Your text is never sent to any server. Your data stays completely private."
        }
      },
      {
        "@type": "Question",
        "name": "How is reading time calculated?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Reading time is estimated based on an average reading speed of 225 words per minute, which is the typical speed for adult readers of English content."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://toolmixr.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": pageTitle,
        "item": pageUrl
      }
    ]
  }
]);
---

<BaseLayout 
  title={pageTitle} 
  description="Free online word counter. Count words, characters, sentences, and paragraphs instantly. Perfect for writers and content creators."
  structuredData={structuredData}
>
  <section class="tool-page">
  <nav class="breadcrumb">
    <a href="/">Home</a> <span class="breadcrumb-sep">›</span> <span>Word Counter</span>
  </nav>
  <div class="tool-header">
    <h1>📝 Word Counter</h1>
    <div class="share-bar">
      <a class="share-btn share-twitter" href="#" onclick="shareTwitter(event)" title="Share on Twitter">𝕏</a>
      <a class="share-btn share-facebook" href="#" onclick="shareFacebook(event)" title="Share on Facebook">f</a>
      <a class="share-btn share-linkedin" href="#" onclick="shareLinkedIn(event)" title="Share on LinkedIn">in</a>
      <a class="share-btn share-reddit" href="#" onclick="shareReddit(event)" title="Share on Reddit">R</a>
      <button class="share-btn share-copy" onclick="copyPageLink(event)" title="Copy link">🔗</button>
    </div>
  </div>
  <p class="subtitle">Count words, characters, sentences, and paragraphs instantly</p>
    
    <div class="tool-box">
      <div class="form-group">
        <textarea id="textInput" rows="10" placeholder="Type or paste your text here..." oninput="countWords()"></textarea>
      </div>
      
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:16px;margin-top:20px;">
        <div style="text-align:center;padding:16px;background:var(--bg);border-radius:var(--radius);">
          <div style="font-size:28px;font-weight:800;color:var(--primary);" id="wordCount">0</div>
          <div style="font-size:13px;color:var(--text-secondary);">Words</div>
        </div>
        <div style="text-align:center;padding:16px;background:var(--bg);border-radius:var(--radius);">
          <div style="font-size:28px;font-weight:800;color:var(--primary);" id="charCount">0</div>
          <div style="font-size:13px;color:var(--text-secondary);">Characters</div>
        </div>
        <div style="text-align:center;padding:16px;background:var(--bg);border-radius:var(--radius);">
          <div style="font-size:28px;font-weight:800;color:var(--primary);" id="charNoSpace">0</div>
          <div style="font-size:13px;color:var(--text-secondary);">No Spaces</div>
        </div>
        <div style="text-align:center;padding:16px;background:var(--bg);border-radius:var(--radius);">
          <div style="font-size:28px;font-weight:800;color:var(--primary);" id="sentenceCount">0</div>
          <div style="font-size:13px;color:var(--text-secondary);">Sentences</div>
        </div>
        <div style="text-align:center;padding:16px;background:var(--bg);border-radius:var(--radius);">
          <div style="font-size:28px;font-weight:800;color:var(--primary);" id="paraCount">0</div>
          <div style="font-size:13px;color:var(--text-secondary);">Paragraphs</div>
        </div>
        <div style="text-align:center;padding:16px;background:var(--bg);border-radius:var(--radius);">
          <div style="font-size:28px;font-weight:800;color:var(--primary);" id="readTime">0</div>
          <div style="font-size:13px;color:var(--text-secondary);">Min Read</div>
        </div>
      </div>
      
      <div style="margin-top:16px;">
        <button class="btn btn-secondary" onclick="clearText()">Clear</button>
      </div>
    </div>
    
    <section class="guide">
      <h2>How to Use the Word Counter</h2>
      <p>Count words, characters, sentences, and paragraphs instantly as you type or paste text. Perfect for writers, students, content creators, and anyone who needs to track text length. All counting happens in your browser — your text is never sent to any server.</p>
      
      <h3>Step-by-Step Guide</h3>
      <ol>
        <li><strong>Type or paste your text</strong> — Simply start typing or paste existing text into the text area. Counts update in real-time as you type.</li>
        <li><strong>Review the statistics</strong> — Instantly see word count, character count (with and without spaces), sentence count, and paragraph count.</li>
        <li><strong>Check reading time</strong> — See estimated reading time based on 225 words per minute (average reading speed).</li>
        <li><strong>Track keyword density</strong> — See how many times specific words appear (if you search for them).</li>
      </ol>
      
      <h3>Tips & Best Practices</h3>
      <ul>
        <li><strong>SEO blog posts</strong> — Most SEO experts recommend 1,500-2,500 words for competitive blog posts. Longer, comprehensive content often ranks better.</li>
        <li><strong>Reading speed varies</strong> — 225 wpm is the average. Technical content may be read slower (about 200 wpm), while easy content faster (about 250 wpm).</li>
        <li><strong>Headings do not count as paragraphs</strong> — Only text separated by blank lines counts as paragraphs. Use this to structure your content.</li>
        <li><strong>Social media limits</strong> — Twitter: 280 characters, Instagram: 2,200 characters, Facebook: 63,206 characters. Use character counts to optimize posts.</li>
      </ul>
    </section>
    
    <section class="faq">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>How does the word counter work?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>Simply type or paste your text into the box above. The tool instantly counts words, characters, sentences, and paragraphs in real-time as you type.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>Does the word counter store my text?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>No. All processing happens in your browser. Your text is never sent to any server. Your data stays completely private.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>How is reading time calculated?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>Reading time is estimated based on an average reading speed of 225 words per minute, which is the typical speed for adult readers of English content.</p>
        </div>
      </div>
    </section>

    <section class="related-tools">
      <h2>Related Tools</h2>
      <div class="related-tools-grid">
        <a href="/lorem-ipsum-generator" class="related-tool-card">
          <span class="related-icon">📄</span>
          <span class="related-name">Lorem Ipsum Generator</span>
        </a>
        <a href="/json-formatter" class="related-tool-card">
          <span class="related-icon">{}</span>
          <span class="related-name">JSON Formatter</span>
        </a>
        <a href="/password-generator" class="related-tool-card">
          <span class="related-icon">🔑</span>
          <span class="related-name">Password Generator</span>
        </a>
        <a href="/base64-encoder-decoder" class="related-tool-card">
          <span class="related-icon">🔐</span>
          <span class="related-name">Base64 Encoder/Decoder</span>
        </a>
      </div>
    </section>
  </section>

  <script is:inline>
    function countWords() {
      var text = document.getElementById('textInput').value;
      var words = text.trim() ? text.trim().split(/\s+/).length : 0;
      var chars = text.length;
      var charsNoSpace = text.replace(/\s/g, '').length;
      var sentences = text.trim() ? text.split(/[.!?]+/).filter(function(s){return s.trim()}).length : 0;
      var paragraphs = text.trim() ? text.split(/\n\n+/).filter(function(p){return p.trim()}).length : 0;
      var readTime = Math.ceil(words / 225);
      
      document.getElementById('wordCount').textContent = words;
      document.getElementById('charCount').textContent = chars;
      document.getElementById('charNoSpace').textContent = charsNoSpace;
      document.getElementById('sentenceCount').textContent = sentences;
      document.getElementById('paraCount').textContent = paragraphs;
      document.getElementById('readTime').textContent = readTime;
    }
    
    function clearText() {
      document.getElementById('textInput').value = '';
      countWords();
    }
  </script>
</BaseLayout>
