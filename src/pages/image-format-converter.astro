  <script is:inline>
    var uploadedFiles = [];
    var convertedFiles = [];

    function formatSize(bytes) {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
      return (bytes / 1048576).toFixed(2) + ' MB';
    }

    function getFormatExt(mimeType) {
      if (mimeType === 'image/png') return '.png';
      if (mimeType === 'image/webp') return '.webp';
      return '.jpg';
    }

    function getFormatClass(mimeType) {
      if (mimeType === 'image/png') return 'format-png';
      if (mimeType === 'image/webp') return 'format-webp';
      return 'format-jpg';
    }

    function getFormatLabel(mimeType) {
      if (mimeType === 'image/png') return 'PNG';
      if (mimeType === 'image/webp') return 'WebP';
      return 'JPG';
    }

    function updateJpgQualityVisibility() {
      var format = document.getElementById('targetFormat').value;
      var group = document.getElementById('jpgQualityGroup');
      group.style.display = (format === 'image/png') ? 'none' : '';
    }

    function setupDropZone() {
      var dropZone = document.getElementById('dropZone');
      var fileInput = document.getElementById('fileInput');

      dropZone.addEventListener('click', function() {
        fileInput.click();
      });

      dropZone.addEventListener('dragover', function(e) {
        e.preventDefault();
        dropZone.classList.add('drag-over');
      });

      dropZone.addEventListener('dragleave', function(e) {
        e.preventDefault();
        dropZone.classList.remove('drag-over');
      });

      dropZone.addEventListener('drop', function(e) {
        e.preventDefault();
        dropZone.classList.remove('drag-over');
        addFiles(e.dataTransfer.files);
      });

      fileInput.addEventListener('change', function() {
        addFiles(this.files);
        this.value = '';
      });
    }

    function addFiles(files) {
      for (var i = 0; i < files.length; i++) {
        var file = files[i];
        if (file.type === 'image/jpeg' || file.type === 'image/png' || file.type === 'image/webp') {
          uploadedFiles.push(file);
        }
      }
      renderFileList();
    }

    function renderFileList() {
      var list = document.getElementById('fileList');
      if (uploadedFiles.length === 0) {
        list.innerHTML = '';
        return;
      }
      var html = '';
      for (var i = 0; i < uploadedFiles.length; i++) {
        var f = uploadedFiles[i];
        var srcFormat = getFormatLabel(f.type);
        var srcClass = getFormatClass(f.type);
        html += '<div class="file-pending">' +
          '<span class="format-badge ' + srcClass + '">' + srcFormat + '</span>' +
          '<span class="file-pending-name">' + f.name + '</span>' +
          '<span style="font-size:13px;color:var(--text-secondary);">' + formatSize(f.size) + '</span>' +
          '<button class="file-pending-remove" onclick="removeFile(' + i + ')" title="Remove">✕</button>' +
        '</div>';
      }
      list.innerHTML = html;
    }

    function removeFile(index) {
      uploadedFiles.splice(index, 1);
      renderFileList();
    }

    function convertAll() {
      if (uploadedFiles.length === 0) {
        alert('Please upload at least one image first.');
        return;
      }
      convertedFiles = [];
      var targetFormat = document.getElementById('targetFormat').value;
      var quality = parseInt(document.getElementById('jpgQuality').value) / 100;
      var pending = uploadedFiles.length;

      for (var i = 0; i < uploadedFiles.length; i++) {
        (function(index) {
          var file = uploadedFiles[index];
          var reader = new FileReader();
          reader.onload = function(e) {
            var img = new Image();
            img.onload = function() {
              var canvas = document.createElement('canvas');
              canvas.width = img.naturalWidth;
              canvas.height = img.naturalHeight;
              var ctx = canvas.getContext('2d');

              if (targetFormat === 'image/jpeg') {
                ctx.fillStyle = '#FFFFFF';
                ctx.fillRect(0, 0, canvas.width, canvas.height);
              }

              ctx.drawImage(img, 0, 0);

              var outputQuality = targetFormat === 'image/png' ? undefined : quality;
              canvas.toBlob(function(blob) {
                var newName = file.name.replace(/\.[^.]+$/, '') + getFormatExt(targetFormat);
                convertedFiles.push({
                  name: newName,
                  originalName: file.name,
                  originalSize: file.size,
                  convertedSize: blob ? blob.size : 0,
                  originalType: file.type,
                  targetType: targetFormat,
                  blob: blob,
                  previewUrl: e.target.result
                });
                pending--;
                if (pending === 0) renderResults();
              }, targetFormat, outputQuality);
            };
            img.src = e.target.result;
          };
          reader.readAsDataURL(file);
        })(i);
      }
    }

    function renderResults() {
      var area = document.getElementById('resultArea');
      area.style.display = 'block';

      var totalOriginal = 0;
      var totalConverted = 0;
      for (var i = 0; i < convertedFiles.length; i++) {
        totalOriginal += convertedFiles[i].originalSize;
        totalConverted += convertedFiles[i].convertedSize;
      }
      var diff = totalConverted - totalOriginal;
      var diffLabel = diff > 0 ? '+' + formatSize(diff) : '-' + formatSize(Math.abs(diff));
      document.getElementById('summaryBar').textContent =
        convertedFiles.length + ' image' + (convertedFiles.length !== 1 ? 's' : '') +
        ' converted | Original: ' + formatSize(totalOriginal) +
        ' → Converted: ' + formatSize(totalConverted) +
        ' (' + diffLabel + ')';

      var listHtml = '';
      for (var i = 0; i < convertedFiles.length; i++) {
        var entry = convertedFiles[i];
        var srcClass = getFormatClass(entry.originalType);
        var dstClass = getFormatClass(entry.targetType);
        listHtml += '<div class="image-item">' +
          '<img class="image-item-preview" src="' + entry.previewUrl + '" alt="' + entry.name + '" />' +
          '<div class="image-item-info">' +
            '<div class="image-item-name">' + entry.name + '</div>' +
            '<div class="image-item-detail">' +
              '<span class="format-badge ' + srcClass + '">' + getFormatLabel(entry.originalType) + '</span>' +
              ' <span class="arrow-icon">→</span> ' +
              '<span class="format-badge ' + dstClass + '">' + getFormatLabel(entry.targetType) + '</span>' +
              ' &nbsp; ' + formatSize(entry.originalSize) + ' → ' + formatSize(entry.convertedSize) +
            '</div>' +
          '</div>' +
          '<div class="image-item-action">' +
            '<button class="btn btn-secondary" onclick="downloadOne(' + i + ')" style="font-size:13px;padding:6px 14px;">💾 Save</button>' +
          '</div>' +
        '</div>';
      }
      document.getElementById('convertedList').innerHTML = listHtml;
    }

    function downloadOne(index) {
      var entry = convertedFiles[index];
      if (!entry.blob) return;
      var url = URL.createObjectURL(entry.blob);
      var a = document.createElement('a');
      a.href = url;
      a.download = entry.name;
      a.click();
      URL.revokeObjectURL(url);
    }

    function downloadAll() {
      for (var i = 0; i < convertedFiles.length; i++) {
        (function(index) {
          setTimeout(function() { downloadOne(index); }, index * 300);
        })(i);
      }
    }

    function downloadAsZip() {
      if (convertedFiles.length === 0) return;
      var pairs = [];
      for (var i = 0; i < convertedFiles.length; i++) {
        pairs.push({ name: convertedFiles[i].name, blob: convertedFiles[i].blob });
      }
      createZip(pairs);
    }

    function createZip(files) {
      var LOCAL_FILE_HEADER = '\x50\x4b\x03\x04';
      var CENTRAL_DIR_HEADER = '\x50\x4b\x01\x02';
      var END_RECORD = '\x50\x4b\x05\x06';
      var textEncoder = new TextEncoder();
      var centralDir = [];
      var offset = 0;
      var fileEntries = [];

      for (var i = 0; i < files.length; i++) {
        var fileName = textEncoder.encode(files[i].name);
        var blob = files[i].blob;
        fileEntries.push({ name: fileName, blob: blob });
      }

      var processed = 0;
      var localHeaders = [];

      function processNext() {
        if (processed >= fileEntries.length) {
          buildZip();
          return;
        }
        var entry = fileEntries[processed];
        var reader = new FileReader();
        reader.onload = function(e) {
          var data = new Uint8Array(e.target.result);
          var crc = crc32(data);
          var nameBytes = entry.name;
          var localHeader = new Uint8Array(30 + nameBytes.length + data.length);

          localHeader.set(textEncoder.encode(LOCAL_FILE_HEADER), 0);
          var view = new DataView(localHeader.buffer);
          view.setUint16(4, 20, true);
          view.setUint16(8, 0, true);
          view.setUint16(10, 0, true);
          view.setUint16(12, 0, true);
          view.setUint32(14, crc, true);
          view.setUint32(18, data.length, true);
          view.setUint32(22, data.length, true);
          view.setUint16(26, nameBytes.length, true);
          view.setUint16(28, 0, true);
          localHeader.set(nameBytes, 30);
          localHeader.set(data, 30 + nameBytes.length);

          centralDir.push({
            name: nameBytes,
            crc: crc,
            size: data.length,
            offset: offset
          });

          localHeaders.push(localHeader);
          offset += localHeader.length;
          processed++;
          processNext();
        };
        reader.readAsArrayBuffer(entry.blob);
      }

      function buildZip() {
        var parts = [];
        for (var i = 0; i < localHeaders.length; i++) {
          parts.push(localHeaders[i]);
        }
        var centralOffset = offset;
        var centralSize = 0;
        for (var i = 0; i < centralDir.length; i++) {
          var cd = centralDir[i];
          var cdEntry = new Uint8Array(46 + cd.name.length);
          var view = new DataView(cdEntry.buffer);
          cdEntry.set(textEncoder.encode(CENTRAL_DIR_HEADER), 0);
          view.setUint16(4, 20, true);
          view.setUint16(6, 20, true);
          view.setUint16(10, 0, true);
          view.setUint16(12, 0, true);
          view.setUint16(14, 0, true);
          view.setUint32(16, cd.crc, true);
          view.setUint32(20, cd.size, true);
          view.setUint32(24, cd.size, true);
          view.setUint16(28, cd.name.length, true);
          view.setUint16(30, 0, true);
          view.setUint16(32, 0, true);
          view.setUint16(34, 0, true);
          view.setUint16(36, 0, true);
          view.setUint32(38, 0, true);
          view.setUint32(42, cd.offset, true);
          cdEntry.set(cd.name, 46);
          parts.push(cdEntry);
          centralSize += cdEntry.length;
        }

        var endRecord = new Uint8Array(22);
        var ev = new DataView(endRecord.buffer);
        endRecord.set(textEncoder.encode(END_RECORD), 0);
        ev.setUint16(4, 0, true);
        ev.setUint16(6, 0, true);
        ev.setUint16(8, centralDir.length, true);
        ev.setUint16(10, centralDir.length, true);
        ev.setUint32(12, centralSize, true);
        ev.setUint32(16, centralOffset, true);
        ev.setUint16(20, 0, true);
        parts.push(endRecord);

        var totalLen = 0;
        for (var i = 0; i < parts.length; i++) totalLen += parts[i].length;
        var result = new Uint8Array(totalLen);
        var pos = 0;
        for (var i = 0; i < parts.length; i++) {
          result.set(parts[i], pos);
          pos += parts[i].length;
        }

        var zipBlob = new Blob([result], { type: 'application/zip' });
        var url = URL.createObjectURL(zipBlob);
        var a = document.createElement('a');
        a.href = url;
        a.download = 'converted-images.zip';
        a.click();
        URL.revokeObjectURL(url);
      }

      processNext();
    }

    function crc32(data) {
      var crc = 0xFFFFFFFF;
      for (var i = 0; i < data.length; i++) {
        crc = crc ^ data[i];
        for (var j = 0; j < 8; j++) {
          if (crc & 1) {
            crc = (crc >>> 1) ^ 0xEDB88320;
          } else {
            crc = crc >>> 1;
          }
        }
      }
      return (crc ^ 0xFFFFFFFF) >>> 0;
    }

    function clearAll() {
      uploadedFiles = [];
      convertedFiles = [];
      document.getElementById('fileList').innerHTML = '';
      document.getElementById('resultArea').style.display = 'none';
      document.getElementById('convertedList').innerHTML = '';
      document.getElementById('summaryBar').textContent = '';
    }

    updateJpgQualityVisibility();
    setupDropZone();
  </script>
</BaseLayout>
