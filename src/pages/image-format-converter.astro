    .drop-hint { color: var(--text-secondary); font-size: 13px; font-weight: 400; }
    .summary-bar {
      background: #EEF2FF;
      color: #3730A3;
      padding: 12px 20px;
      border-radius: var(--radius);
      margin-bottom: 20px;
