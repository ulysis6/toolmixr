  <style is:global>
    .privacy-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: #ECFDF5;
      color: #065F46;
      padding: 8px 16px;
      border-radius: 20px;
      font-size: 14px;
      font-weight: 600;
      margin-bottom: 20px;
      border: 1px solid #A7F3D0;
    }
    [data-theme="dark"] .privacy-badge {
      background: rgba(16, 185, 129, 0.15);
      color: #34D399;
      border-color: rgba(16, 185, 129, 0.3);
    }
    .drop-zone {
      border: 2px dashed var(--border);
      border-radius: var(--radius);
      padding: 48px 24px;
      text-align: center;
      cursor: pointer;
      transition: all 0.2s;
      margin-bottom: 24px;
      background: var(--bg);
    }
    .drop-zone:hover, .drop-zone.drag-over {
      border-color: var(--primary);
      background: rgba(79, 70, 229, 0.05);
    }
    [data-theme="dark"] .drop-zone:hover, [data-theme="dark"] .drop-zone.drag-over {
      background: rgba(129, 140, 248, 0.08);
    }
