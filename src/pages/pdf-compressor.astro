  <!-- PDF.js and pdf-lib from CDN -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
  <script src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>

  <script is:inline>
    // Set PDF.js worker
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

    var compressedPdfs = [];
    var isProcessing = false;

    function formatSize(bytes) {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
      return (bytes / 1048576).toFixed(2) + ' MB';
    }

    function updateQuality(val) {
      document.getElementById('qualityVal').textContent = val;
    }

    function setupDropZone() {
      var dropZone = document.getElementById('dropZone');
      var fileInput = document.getElementById('fileInput');

      dropZone.addEventListener('click', function() {
        if (!isProcessing) fileInput.click();
      });

      dropZone.addEventListener('dragover', function(e) {
        e.preventDefault();
        dropZone.classList.add('drag-over');
      });

      dropZone.addEventListener('dragleave', function(e) {
        e.preventDefault();
        dropZone.classList.remove('drag-over');
      });

      dropZone.addEventListener('drop', function(e) {
        e.preventDefault();
        dropZone.classList.remove('drag-over');
        if (!isProcessing) handleFiles(e.dataTransfer.files);
      });

      fileInput.addEventListener('change', function() {
        handleFiles(this.files);
        this.value = '';
      });
    }

    function handleFiles(files) {
      for (var i = 0; i < files.length; i++) {
        var file = files[i];
        if (file.type === 'application/pdf' || file.name.toLowerCase().endsWith('.pdf')) {
          compressPdf(file);
        }
      }
    }

    function showProgress(fileName, totalPages) {
      var progressArea = document.getElementById('progressArea');
      progressArea.style.display = 'block';
      document.getElementById('progressBar').textContent = 'Processing: ' + fileName + ' (' + totalPages + ' pages)';
      var details = document.getElementById('progressDetails');
      details.innerHTML = '';
      for (var i = 0; i < totalPages; i++) {
        var div = document.createElement('div');
        div.className = 'progress-page';
        div.id = 'progress-page-' + i;
        div.innerHTML = '<span class="spinner"></span> Page ' + (i + 1) + '...';
        details.appendChild(div);
      }
    }

    function updatePageProgress(pageIndex, status) {
      var el = document.getElementById('progress-page-' + pageIndex);
      if (!el) return;
      if (status === 'done') {
        el.className = 'progress-page done';
        el.innerHTML = '<span class="spinner"></span> Page ' + (pageIndex + 1) + ' ✓';
      } else if (status === 'error') {
        el.className = 'progress-page';
        el.style.color = '#EF4444';
        el.innerHTML = '<span style="color:#EF4444;">✗</span> Page ' + (pageIndex + 1) + ' failed';
      }
    }

    async function compressPdf(file) {
      if (isProcessing) return;
      isProcessing = true;

      var quality = parseInt(document.getElementById('qualitySlider').value) / 100;

      try {
        // Read the file as ArrayBuffer
        var arrayBuffer = await file.arrayBuffer();

        // Load the PDF with PDF.js
        var pdfDoc = await pdfjsLib.getDocument({ data: arrayBuffer.slice(0) }).promise;
        var numPages = pdfDoc.numPages;

        showProgress(file.name, numPages);

        // Render each page to canvas, then to JPEG blob
        var pageBlobs = [];
        for (var i = 1; i <= numPages; i++) {
          try {
            var page = await pdfDoc.getPage(i);
            var viewport = page.getViewport({ scale: 1.5 }); // 150 DPI equivalent

            var canvas = document.createElement('canvas');
            canvas.width = viewport.width;
            canvas.height = viewport.height;
            var ctx = canvas.getContext('2d');

            // White background (important for transparent/translucent content)
            ctx.fillStyle = 'white';
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            var renderContext = {
              canvasContext: ctx,
              viewport: viewport
            };
            await page.render(renderContext).promise;

            // Convert canvas to JPEG blob
            var blob = await new Promise(function(resolve) {
              canvas.toBlob(function(b) { resolve(b); }, 'image/jpeg', quality);
            });
            pageBlobs.push(blob);
            updatePageProgress(i - 1, 'done');
          } catch (pageErr) {
            updatePageProgress(i - 1, 'error');
            // Push a small empty blob so indices stay aligned
            var emptyBlob = new Blob([], { type: 'image/jpeg' });
            pageBlobs.push(emptyBlob);
          }
        }

        // Now rebuild PDF using pdf-lib
        var newPdf = await PDFLib.PDFDocument.create();

        for (var j = 0; j < pageBlobs.length; j++) {
          try {
            var jpgImageBytes = await pageBlobs[j].arrayBuffer();
            var jpgImage = await newPdf.embedJpg(jpgImageBytes);
            var pageDims = jpgImage.scale(1);
            var newPage = newPdf.addPage([pageDims.width, pageDims.height]);
            newPage.drawImage(jpgImage, {
              x: 0,
              y: 0,
              width: pageDims.width,
              height: pageDims.height
            });
          } catch (embedErr) {
            // Skip failed pages
          }
        }

        var pdfBytes = await newPdf.save();
        var compressedBlob = new Blob([pdfBytes], { type: 'application/pdf' });

        // Store result
        var result = {
          name: file.name.replace(/\.pdf$/i, '-compressed.pdf'),
          originalSize: file.size,
          compressedSize: compressedBlob.size,
          blob: compressedBlob,
          numPages: numPages,
          originalName: file.name
        };
        compressedPdfs.push(result);

        // Hide progress, show result
        document.getElementById('progressArea').style.display = 'none';
        renderResults();

      } catch (err) {
        document.getElementById('progressArea').style.display = 'none';
        alert('Error processing PDF: ' + err.message);
      } finally {
        isProcessing = false;
      }
    }

    function renderResults() {
      var area = document.getElementById('resultArea');
      area.style.display = 'block';

      var totalOriginal = 0;
      var totalCompressed = 0;
      for (var i = 0; i < compressedPdfs.length; i++) {
        totalOriginal += compressedPdfs[i].originalSize;
        totalCompressed += compressedPdfs[i].compressedSize;
      }
      var totalRatio = totalOriginal > 0 ? ((1 - totalCompressed / totalOriginal) * 100).toFixed(1) : 0;
      document.getElementById('summaryBar').textContent =
        compressedPdfs.length + ' PDF' + (compressedPdfs.length !== 1 ? 's' : '') +
        ' | Original: ' + formatSize(totalOriginal) +
        ' → Compressed: ' + formatSize(totalCompressed) +
        ' | Saved: ' + totalRatio + '%';

      var listHtml = '';
      for (var i = 0; i < compressedPdfs.length; i++) {
        var entry = compressedPdfs[i];
        var ratio = entry.originalSize > 0 ? ((1 - entry.compressedSize / entry.originalSize) * 100).toFixed(1) : 0;
        var ratioClass = parseFloat(ratio) >= 50 ? 'ratio-great' : 'ratio-good';
        var ratioDisplay = parseFloat(ratio) > 0 ? ' <span class="pdf-item-ratio ' + ratioClass + '">-' + ratio + '%</span>' : '';
        listHtml += '<div class="pdf-item">' +
          '<div class="pdf-item-icon">📄</div>' +
          '<div class="pdf-item-info">' +
            '<div class="pdf-item-name">' + entry.originalName + '</div>' +
            '<div class="pdf-item-sizes">' +
              formatSize(entry.originalSize) + ' → ' + formatSize(entry.compressedSize) +
              ratioDisplay +
            '</div>' +
          '</div>' +
        '</div>';
      }
      document.getElementById('pdfList').innerHTML = listHtml;

      // Update download button text
      var btn = document.getElementById('downloadBtn');
      if (compressedPdfs.length === 1) {
        btn.textContent = '💾 Download ' + compressedPdfs[0].name;
      } else {
        btn.textContent = '💾 Download All (' + compressedPdfs.length + ' PDFs)';
      }
    }

    function downloadCompressed() {
      if (compressedPdfs.length === 0) return;
      if (compressedPdfs.length === 1) {
        // Single file download
        var entry = compressedPdfs[0];
        var url = URL.createObjectURL(entry.blob);
        var a = document.createElement('a');
        a.href = url;
        a.download = entry.name;
        a.click();
        URL.revokeObjectURL(url);
      } else {
        // Multiple files - download each with a slight delay
        for (var i = 0; i < compressedPdfs.length; i++) {
          (function(index) {
            setTimeout(function() {
              var entry = compressedPdfs[index];
              var url = URL.createObjectURL(entry.blob);
              var a = document.createElement('a');
              a.href = url;
              a.download = entry.name;
              a.click();
              URL.revokeObjectURL(url);
            }, index * 500);
          })(i);
        }
      }
    }

    function clearAll() {
      compressedPdfs = [];
      document.getElementById('resultArea').style.display = 'none';
      document.getElementById('progressArea').style.display = 'none';
      document.getElementById('pdfList').innerHTML = '';
      document.getElementById('summaryBar').textContent = '';
      document.getElementById('progressBar').textContent = '';
      document.getElementById('progressDetails').innerHTML = '';
    }

    setupDropZone();
  </script>
</BaseLayout>
