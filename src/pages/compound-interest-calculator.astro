---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "Compound Interest Calculator";
const pageUrl = "https://toolmixr.com/compound-interest-calculator";

const structuredData = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": pageTitle,
    "url": pageUrl,
    "description": "Free compound interest calculator to see how your investments grow over time. Calculate final amount with compound interest from principal, rate, and frequency.",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is compound interest?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Compound interest is interest calculated on both the initial principal and the accumulated interest from previous periods. Often called \"interest on interest,\" it causes your money to grow exponentially over time rather than linearly."
        }
      },
      {
        "@type": "Question",
        "name": "How does compounding frequency affect returns?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The more frequently interest compounds, the higher your returns. Daily compounding yields more than monthly, which yields more than annually. On a $10,000 investment at 7% for 20 years: annual = $38,697, monthly = $40,994, daily = $41,215. The difference seems small but grows with larger amounts."
        }
      },
      {
        "@type": "Question",
        "name": "What is the Rule of 72?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A quick mental math shortcut: divide 72 by your annual interest rate to estimate years to double your money. At 6% interest, 72/6 = 12 years to double. At 9%, 72/9 = 8 years. This approximation works best for rates between 4% and 12%."
        }
      },
      {
        "@type": "Question",
        "name": "Why is starting early so important?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Thanks to compounding, time is your greatest asset. $5,000 invested at age 25 at 7% annually becomes ~$52,000 by age 65. Waiting until 35 to invest the same amount yields only ~$26,000. That's 20 extra years making a 2x difference!"
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://toolmixr.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": pageTitle,
        "item": pageUrl
      }
    ]
  }
]);
---

<BaseLayout 
  title={pageTitle} 
  description="Free compound interest calculator to see how your investments grow over time. Calculate final amount with compound interest from principal, rate, and frequency."
  structuredData={structuredData}
>
  <section class="tool-page">
    <h1>🏦 Compound Interest Calculator</h1>
    <p class="subtitle">See the power of compound interest and watch your money grow exponentially</p>
    <div class="share-bar">
      <span class="share-label">Share:</span>
      <a class="share-btn share-twitter" href="#" onclick="shareTwitter(event)" title="Share on Twitter">𝕏</a>
      <a class="share-btn share-facebook" href="#" onclick="shareFacebook(event)" title="Share on Facebook">f</a>
      <a class="share-btn share-linkedin" href="#" onclick="shareLinkedIn(event)" title="Share on LinkedIn">in</a>
      <a class="share-btn share-reddit" href="#" onclick="shareReddit(event)" title="Share on Reddit">R</a>
      <button class="share-btn share-copy" onclick="copyPageLink(event)" title="Copy link">🔗</button>
    </div>
    
    <div class="tool-box">
      <div class="form-group">
        <label for="principal">Initial Principal ($)</label>
        <input type="number" id="principal" value="10000" min="0" step="100" oninput="calculateCompound()" />
      </div>
      
      <div class="form-group">
        <label for="rate">Annual Interest Rate (%)</label>
        <input type="number" id="rate" value="7" min="0" max="100" step="0.1" oninput="calculateCompound()" />
      </div>
      
      <div class="form-group">
        <label for="frequency">Compounding Frequency</label>
        <select id="frequency" onchange="calculateCompound()">
          <option value="1">Annually (1x per year)</option>
          <option value="4">Quarterly (4x per year)</option>
          <option value="12" selected>Monthly (12x per year)</option>
          <option value="365">Daily (365x per year)</option>
        </select>
      </div>
      
      <div class="form-group">
        <label for="years">Investment Period (Years)</label>
        <input type="number" id="years" value="20" min="1" max="100" step="1" oninput="calculateCompound()" />
      </div>
      
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;padding:16px;background:var(--bg);border-radius:var(--radius);">
        <input type="checkbox" id="monthlyContribution" onchange="calculateCompound()" />
        <label for="monthlyContribution" style="margin-bottom:0;font-weight:400;">Add monthly contribution</label>
      </div>
      
      <div id="contributionSection" style="display:none;">
        <div class="form-group">
          <label for="monthlyAmount">Monthly Contribution ($)</label>
          <input type="number" id="monthlyAmount" value="500" min="0" step="50" oninput="calculateCompound()" />
        </div>
      </div>
      
      <div style="display:flex;gap:12px;margin-top:20px;">
        <button class="btn btn-primary" onclick="calculateCompound()">Calculate</button>
      </div>
      
      <div id="result" style="display:none;margin-top:24px;">
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;">
          <div style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:20px;text-align:center;">
            <div style="font-size:13px;color:var(--text-secondary);margin-bottom:4px;">Final Amount</div>
            <div style="font-size:28px;font-weight:700;color:var(--primary);" id="finalAmount">$0</div>
          </div>
          <div style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:20px;text-align:center;">
            <div style="font-size:13px;color:var(--text-secondary);margin-bottom:4px;">Total Interest Earned</div>
            <div style="font-size:28px;font-weight:700;color:#10B981;" id="totalInterest">$0</div>
          </div>
          <div style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:20px;text-align:center;">
            <div style="font-size:13px;color:var(--text-secondary);margin-bottom:4px;">Total Contributions</div>
            <div style="font-size:28px;font-weight:700;color:#F59E0B;" id="totalContributions">$0</div>
          </div>
        </div>
        
        <div style="margin-top:24px;">
          <h3 style="font-size:16px;margin-bottom:12px;">Balance Breakdown</h3>
          <div style="display:flex;align-items:center;gap:16px;">
            <div style="flex:1;">
              <div style="display:flex;justify-content:space-between;margin-bottom:4px;font-size:13px;">
                <span>Contributions: <span id="contribPercent">0</span>%</span>
                <span id="contribAmount">$0</span>
              </div>
              <div style="display:flex;justify-content:space-between;margin-bottom:4px;font-size:13px;">
                <span>Interest: <span id="interestPercent">0</span>%</span>
                <span id="interestEarned">$0</span>
              </div>
              <div style="height:24px;border-radius:12px;overflow:hidden;display:flex;background:#E5E7EB;">
                <div id="contribBar" style="background:#F59E0B;height:100%;transition:width 0.3s;"></div>
                <div id="interestBar" style="background:#10B981;height:100%;transition:width 0.3s;"></div>
              </div>
            </div>
          </div>
          <div style="display:flex;gap:16px;margin-top:8px;font-size:12px;color:var(--text-secondary);">
            <span style="display:flex;align-items:center;gap:4px;"><span style="width:12px;height:12px;background:#F59E0B;border-radius:2px;"></span> Contributions</span>
            <span style="display:flex;align-items:center;gap:4px;"><span style="width:12px;height:12px;background:#10B981;border-radius:2px;"></span> Interest</span>
          </div>
        </div>
        
        <div id="growthChart" style="margin-top:24px;padding:16px;background:var(--bg);border-radius:var(--radius);">
          <h4 style="font-size:14px;margin-bottom:12px;">Growth Over Time</h4>
          <div id="chartBars" style="display:flex;align-items:flex-end;gap:4px;height:150px;"></div>
          <div id="chartLabels" style="display:flex;gap:4px;font-size:11px;color:var(--text-secondary);margin-top:8px;"></div>
        </div>
      </div>
    

    <section class="guide">
      <h2>How to Use the Compound Interest Calculator</h2>
      <p>Compound interest is called the eighth wonder of the world by Albert Einstein — and for good reason. Unlike simple interest (which only earns on the principal), compound interest earns on both your principal AND previously accumulated interest. This creates exponential growth over time, which is why starting early is so powerful.</p>
      
      <h3>Step-by-Step Guide</h3>
      <ol>
        <li><strong>Enter your initial principal</strong> — This is the starting amount of your investment or savings. Even small starting amounts can grow significantly over time.</li>
        <li><strong>Set the annual interest rate</strong> — Enter the expected annual return rate. Historical stock market average is about 7% after inflation; savings accounts might earn 3-5%.</li>
        <li><strong>Choose compounding frequency</strong> — Options include annually, quarterly, monthly, or daily. More frequent compounding results in slightly higher returns.</li>
        <li><strong>Enter the number of years</strong> — How long will you let your money grow? Longer time periods dramatically increase final amounts thanks to compounding.</li>
        <li><strong>Add regular contributions (optional)</strong> — Enter monthly contributions to see how much more you can accumulate. Regular investing is more powerful than you might think.</li>
        <li><strong>Review the results</strong> — See your total amount, total contributions, and interest earned. The growth chart shows how your money compounds over time.</li>
      </ol>
      
      <h3>Tips & Best Practices</h3>
      <ul>
        <li><strong>Higher frequency equals more returns</strong> — Daily compounding earns slightly more than monthly, which earns more than annual. On $10,000 at 7% for 20 years: daily earns $41,215 vs. annual earns $38,697.</li>
        <li><strong>Regular contributions dramatically increase results</strong> — Adding $500/month to $10,000 at 7% for 20 years yields about $298,000 — nearly double what $10,000 alone would grow to.</li>
        <li><strong>Start early — time is your greatest asset</strong> — $5,000 invested at age 25 at 7% becomes about $52,000 by 65. The same $5,000 invested at 35 becomes only about $26,000.</li>
        <li><strong>Use the Rule of 72</strong> — Divide 72 by your annual rate to estimate years to double. At 8%, your money doubles roughly every 9 years.</li>
      </ul>
    </section>
    <section class="faq">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <h3>What is compound interest?</h3>
        <p>Compound interest is interest calculated on both the initial principal and the accumulated interest from previous periods. Often called "interest on interest," it causes your money to grow exponentially over time rather than linearly.</p>
      </div>
      <div class="faq-item">
        <h3>How does compounding frequency affect returns?</h3>
        <p>The more frequently interest compounds, the higher your returns. Daily compounding yields more than monthly, which yields more than annually. On a $10,000 investment at 7% for 20 years: annual = $38,697, monthly = $40,994, daily = $41,215. The difference seems small but grows with larger amounts.</p>
      </div>
      <div class="faq-item">
        <h3>What is the Rule of 72?</h3>
        <p>A quick mental math shortcut: divide 72 by your annual interest rate to estimate years to double your money. At 6% interest, 72/6 = 12 years to double. At 9%, 72/9 = 8 years. This approximation works best for rates between 4% and 12%.</p>
      </div>
      <div class="faq-item">
        <h3>Why is starting early so important?</h3>
        <p>Thanks to compounding, time is your greatest asset. $5,000 invested at age 25 at 7% annually becomes ~$52,000 by age 65. Waiting until 35 to invest the same amount yields only ~$26,000. That's 20 extra years making a 2x difference!</p>
      </div>
    </section>

    <section class="related-tools">
      <h2>Related Tools</h2>
      <div class="related-tools-grid">
        <a href="/roi-calculator" class="related-tool-card">
          <span class="related-icon">📈</span>
          <span class="related-name">ROI Calculator</span>
        </a>
        <a href="/mortgage-calculator" class="related-tool-card">
          <span class="related-icon">🏠</span>
          <span class="related-name">Mortgage Calculator</span>
        </a>
        <a href="/loan-calculator" class="related-tool-card">
          <span class="related-icon">💰</span>
          <span class="related-name">Loan Calculator</span>
        </a>
        <a href="/adsense-revenue-calculator" class="related-tool-card">
          <span class="related-icon">💵</span>
          <span class="related-name">AdSense Revenue Calculator</span>
        </a>
      </div>
    </section>
  </section>

  <script is:inline>
    function calculateCompound() {
      var principal = parseFloat(document.getElementById('principal').value) || 0;
      var rate = parseFloat(document.getElementById('rate').value) || 0;
      var frequency = parseInt(document.getElementById('frequency').value) || 12;
      var years = parseInt(document.getElementById('years').value) || 1;
      var monthlyContrib = document.getElementById('monthlyContribution').checked;
      
      var contribSection = document.getElementById('contributionSection');
      if (monthlyContrib) {
        contribSection.style.display = 'block';
      } else {
        contribSection.style.display = 'none';
      }
      
      var monthlyAmount = monthlyContrib ? (parseFloat(document.getElementById('monthlyAmount').value) || 0) : 0;
      
      var n = frequency;
      var r = rate / 100;
      var t = years;
      
      var finalAmount;
      if (r === 0) {
        finalAmount = principal + (monthlyAmount * 12 * t);
      } else {
        var compounded = principal * Math.pow(1 + r / n, n * t);
        if (monthlyAmount > 0) {
          var contribPerPeriod = monthlyAmount * 12 / n;
          finalAmount = compounded + contribPerPeriod * ((Math.pow(1 + r / n, n * t) - 1) / (r / n));
        } else {
          finalAmount = compounded;
        }
      }
      
      var totalContributions = principal + (monthlyAmount * 12 * t);
      var totalInterest = finalAmount - totalContributions;
      
      document.getElementById('finalAmount').textContent = '$' + formatNumber(Math.round(finalAmount));
      document.getElementById('totalInterest').textContent = '$' + formatNumber(Math.round(totalInterest));
      document.getElementById('totalContributions').textContent = '$' + formatNumber(Math.round(totalContributions));
      
      var contribPercent = Math.round((totalContributions / finalAmount) * 100);
      var interestPercent = 100 - contribPercent;
      
      document.getElementById('contribPercent').textContent = contribPercent;
      document.getElementById('interestPercent').textContent = interestPercent;
      document.getElementById('contribAmount').textContent = '$' + formatNumber(Math.round(totalContributions));
      document.getElementById('interestEarned').textContent = '$' + formatNumber(Math.round(totalInterest));
      
      document.getElementById('contribBar').style.width = contribPercent + '%';
      document.getElementById('interestBar').style.width = interestPercent + '%';
      
      // Chart
      var chartBars = document.getElementById('chartBars');
      var chartLabels = document.getElementById('chartLabels');
      chartBars.innerHTML = '';
      chartLabels.innerHTML = '';
      
      var intervals = Math.min(10, years);
      var step = years / intervals;
      var maxValue = finalAmount;
      
      for (var i = 0; i <= intervals; i++) {
        var year = Math.round(i * step);
        var value;
        if (r === 0) {
          value = principal + (monthlyAmount * 12 * year);
        } else {
          var compounded = principal * Math.pow(1 + r / n, n * year);
          if (monthlyAmount > 0) {
            var contribPerPeriod = monthlyAmount * 12 / n;
            value = compounded + contribPerPeriod * ((Math.pow(1 + r / n, n * year) - 1) / (r / n));
          } else {
            value = compounded;
          }
        }
        var height = (value / maxValue) * 100;
        var bar = document.createElement('div');
        bar.style.cssText = 'flex:1;background:var(--primary);border-radius:4px 4px 0 0;min-height:4px;transition:height 0.3s;height:' + height + '%;';
        chartBars.appendChild(bar);
        
        var label = document.createElement('div');
        label.style.cssText = 'flex:1;text-align:center;';
        label.textContent = 'Y' + year;
        chartLabels.appendChild(label);
      }
      
      document.getElementById('result').style.display = 'block';
    }
    
    function formatNumber(num) {
      return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    }
    
    calculateCompound();
  </script>
</BaseLayout>
