---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "Meta Tag Generator";
const pageUrl = "https://toolmixr.com/meta-tag-generator";

const structuredData = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": pageTitle,
    "url": pageUrl,
    "description": "Free online meta tag generator. Create SEO-friendly HTML meta tags, Open Graph tags, and Twitter Card tags for your website.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are meta tags?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Meta tags are HTML elements that provide metadata about a web page. They sit in the head section of your HTML and tell search engines and social media platforms what your page is about, how to display it, and whether to index it."
        }
      },
      {
        "@type": "Question",
        "name": "Why are Open Graph tags important?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Open Graph tags control how your content appears when shared on Facebook, LinkedIn, and other social platforms. Without them, social platforms may choose random images or text, making your shares look unprofessional."
        }
      },
      {
        "@type": "Question",
        "name": "How long should my meta description be?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Google typically displays 120-160 characters of a meta description. Aim for 150-160 characters to ensure your full message appears in search results without being cut off."
        }
      },
      {
        "@type": "Question",
        "name": "Do keywords meta tags still matter?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Google has not used the keywords meta tag for ranking since 2009. However, some smaller search engines and tools may still reference it, so it does not hurt to include relevant keywords."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://toolmixr.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": pageTitle,
        "item": pageUrl
      }
    ]
  }
]);
---

<BaseLayout 
  title={pageTitle} 
  description="Free online meta tag generator. Create SEO-friendly HTML meta tags, Open Graph tags, and Twitter Card tags for your website."
  structuredData={structuredData}
>
  <section class="tool-page">
  <nav class="breadcrumb">
    <a href="/">Home</a> <span class="breadcrumb-sep">›</span> <span>Meta Tag Generator</span>
  </nav>
  <div class="tool-header">
    <h1>🏷️ Meta Tag Generator</h1>
    <div class="share-bar">
      <a class="share-btn share-twitter" href="#" onclick="shareTwitter(event)" title="Share on Twitter">𝕏</a>
      <a class="share-btn share-facebook" href="#" onclick="shareFacebook(event)" title="Share on Facebook">f</a>
      <a class="share-btn share-linkedin" href="#" onclick="shareLinkedIn(event)" title="Share on LinkedIn">in</a>
      <a class="share-btn share-reddit" href="#" onclick="shareReddit(event)" title="Share on Reddit">R</a>
      <button class="share-btn share-copy" onclick="copyPageLink(event)" title="Copy link">🔗</button>
    </div>
  </div>
  <p class="subtitle">Generate perfect HTML meta tags for SEO, Open Graph, and Twitter Cards</p>
    
    <div class="tool-box">
      <div class="form-group">
        <label for="title">Page Title *</label>
        <input type="text" id="title" placeholder="e.g. Best Online Tools for Web Developers" maxlength="70" />
        <small style="color:var(--text-secondary);font-size:12px;">Recommended: 50-60 characters</small>
      </div>
      
      <div class="form-group">
        <label for="description">Meta Description *</label>
        <textarea id="description" rows="3" placeholder="Briefly describe your page content..." maxlength="160"></textarea>
        <small style="color:var(--text-secondary);font-size:12px;">Recommended: 120-160 characters</small>
      </div>
      
      <div class="form-group">
        <label for="keywords">Keywords</label>
        <input type="text" id="keywords" placeholder="e.g. web tools, SEO, meta tags" />
        <small style="color:var(--text-secondary);font-size:12px;">Comma-separated keywords</small>
      </div>
      
      <div class="form-group">
        <label for="url">Page URL</label>
        <input type="url" id="url" placeholder="https://example.com/page" />
      </div>
      
      <div class="form-group">
        <label for="image">OG Image URL</label>
        <input type="url" id="image" placeholder="https://example.com/image.jpg" />
      </div>
      
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <div class="form-group" style="flex:1;min-width:200px;">
          <label for="type">OG Type</label>
          <select id="type">
            <option value="website">Website</option>
            <option value="article">Article</option>
            <option value="product">Product</option>
          </select>
        </div>
        <div class="form-group" style="flex:1;min-width:200px;">
          <label for="robots">Robots</label>
          <select id="robots">
            <option value="index, follow">Index, Follow</option>
            <option value="noindex, follow">No Index, Follow</option>
            <option value="index, nofollow">Index, No Follow</option>
            <option value="noindex, nofollow">No Index, No Follow</option>
          </select>
        </div>
        <div class="form-group" style="flex:1;min-width:200px;">
          <label for="viewport">Viewport</label>
          <input type="text" id="viewport" value="width=device-width, initial-scale=1.0" />
        </div>
      </div>
      
      <div style="display:flex;gap:12px;margin-top:8px;">
        <button class="btn btn-primary" onclick="generateMeta()">Generate Tags</button>
        <button class="btn btn-secondary" onclick="copyOutput()">📋 Copy</button>
      </div>
      
      <div class="output-box" id="output" style="display:none;">
        <button class="copy-btn" onclick="copyOutput()">Copy</button>
        <pre id="code"></pre>
      </div>
    </div>
    
    <section class="guide">
      <h2>How to Use the Meta Tag Generator</h2>
      <p>Create complete HTML meta tags for your web pages including SEO title and description, Open Graph tags for social media, and Twitter Card tags. Well-crafted meta tags significantly improve how your pages appear in search results and social shares.</p>
      
      <h3>Step-by-Step Guide</h3>
      <ol>
        <li><strong>Enter your page title</strong> — This appears in browser tabs and search results. Keep it under 60 characters for full display. Include your brand name when appropriate.</li>
        <li><strong>Write your meta description</strong> — This is the snippet shown in search results. Aim for 120-160 characters, include a call-to-action, and naturally incorporate your target keyword.</li>
        <li><strong>Add keywords (optional)</strong> — While Google ignores keywords meta tags, some tools still use them. Include 5-10 relevant keywords, comma-separated.</li>
        <li><strong>Enter page URL</strong> — Your canonical URL. This helps search engines understand the authoritative version of your page.</li>
        <li><strong>Add OG image URL</strong> — The image that appears when your page is shared on Facebook, LinkedIn, etc. Recommended size: 1200x630 pixels.</li>
        <li><strong>Configure remaining options</strong> — Set OG type (website, article, etc.), robots directives, and viewport settings.</li>
        <li><strong>Generate and copy</strong> — Click Generate, then copy the code and paste it into the <code>&lt;head&gt;</code> section of your HTML.</li>
      </ol>
      
      <h3>Tips & Best Practices</h3>
      <ul>
        <li><strong>Title under 60 characters</strong> — Longer titles get truncated in search results. Front-load important keywords.</li>
        <li><strong>Unique descriptions for each page</strong> — Don't duplicate descriptions across pages. Each page should have a unique, descriptive summary.</li>
        <li><strong>Always include Open Graph tags</strong> — Social platforms will choose random content without OG tags. Control your brand image on social media.</li>
        <li><strong>Use compelling descriptions</strong> — Include a benefit or call-to-action in your description to improve click-through rates from search results.</li>
      </ul>
    </section>
    
    <section class="faq">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>What are meta tags?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>Meta tags are HTML elements that provide metadata about a web page. They sit in the head section of your HTML and tell search engines and social media platforms what your page is about, how to display it, and whether to index it.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>Why are Open Graph tags important?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>Open Graph tags control how your content appears when shared on Facebook, LinkedIn, and other social platforms. Without them, social platforms may choose random images or text, making your shares look unprofessional.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>How long should my meta description be?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>Google typically displays 120-160 characters of a meta description. Aim for 150-160 characters to ensure your full message appears in search results without being cut off.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>Do keywords meta tags still matter?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>Google has not used the keywords meta tag for ranking since 2009. However, some smaller search engines and tools may still reference it, so it doesn't hurt to include relevant keywords.</p>
        </div>
      </div>
    </section>

    <section class="related-tools">
      <h2>Related Tools</h2>
      <div class="related-tools-grid">
        <a href="/og-image-generator" class="related-tool-card">
          <span class="related-icon">🖼️</span>
          <span class="related-name">OG Image Generator</span>
        </a>
        <a href="/robots-txt-generator" class="related-tool-card">
          <span class="related-icon">🤖</span>
          <span class="related-name">Robots.txt Generator</span>
        </a>
        <a href="/sitemap-generator" class="related-tool-card">
          <span class="related-icon">🗺️</span>
          <span class="related-name">Sitemap Generator</span>
        </a>
        <a href="/json-formatter" class="related-tool-card">
          <span class="related-icon">{}</span>
          <span class="related-name">JSON Formatter</span>
        </a>
      </div>
    </section>
  </section>

  <script is:inline>
    function generateMeta() {
      var title = document.getElementById('title').value.trim();
      var desc = document.getElementById('description').value.trim();
      var keywords = document.getElementById('keywords').value.trim();
      var url = document.getElementById('url').value.trim();
      var image = document.getElementById('image').value.trim();
      var type = document.getElementById('type').value;
      var robots = document.getElementById('robots').value;
      var viewport = document.getElementById('viewport').value.trim();
      
      var tags = [];
      tags.push('<meta charset="UTF-8">');
      if (viewport) tags.push('<meta name="viewport" content="' + viewport + '">');
      if (title) tags.push('<title>' + title + '</title>');
      if (desc) tags.push('<meta name="description" content="' + desc + '">');
      if (keywords) tags.push('<meta name="keywords" content="' + keywords + '">');
      tags.push('<meta name="robots" content="' + robots + '">');
      
      if (url) {
        tags.push('\n<!-- Open Graph -->');
        tags.push('<meta property="og:type" content="' + type + '">');
        tags.push('<meta property="og:url" content="' + url + '">');
        if (title) tags.push('<meta property="og:title" content="' + title + '">');
        if (desc) tags.push('<meta property="og:description" content="' + desc + '">');
        if (image) tags.push('<meta property="og:image" content="' + image + '">');
      }
      
      if (title || url) {
        tags.push('\n<!-- Twitter Card -->');
        tags.push('<meta name="twitter:card" content="summary_large_image">');
        if (title) tags.push('<meta name="twitter:title" content="' + title + '">');
        if (desc) tags.push('<meta name="twitter:description" content="' + desc + '">');
        if (image) tags.push('<meta name="twitter:image" content="' + image + '">');
      }
      
      document.getElementById('output').style.display = 'block';
      document.getElementById('code').textContent = tags.join('\n');
    }
    
    function copyOutput() {
      var code = document.getElementById('code').textContent;
      navigator.clipboard.writeText(code).then(function() {
        document.querySelector('.copy-btn').textContent = 'Copied!';
        setTimeout(function() { document.querySelector('.copy-btn').textContent = 'Copy'; }, 2000);
      });
    }
  </script>
</BaseLayout>
