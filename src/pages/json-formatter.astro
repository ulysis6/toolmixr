---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="JSON Formatter" 
  description="Free online JSON formatter, validator, and beautifier. Format messy JSON into readable code instantly."
>
  <section class="tool-page">
    <h1>{`{}`} JSON Formatter & Validator</h1>
    <p class="subtitle">Format, validate, and beautify JSON data instantly</p>
    
    <div class="tool-box">
      <div class="form-group">
        <label for="jsonInput">Paste your JSON here</label>
        <textarea id="jsonInput" rows="10" placeholder='{"key": "value", "array": [1, 2, 3]}'></textarea>
      </div>
      
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <button class="btn btn-primary" onclick="formatJSON()">Format / Beautify</button>
        <button class="btn btn-secondary" onclick="minifyJSON()">Minify</button>
        <button class="btn btn-secondary" onclick="validateJSON()">Validate Only</button>
        <button class="btn btn-secondary" onclick="copyOutput()">📋 Copy</button>
      </div>
      
      <div id="status" style="margin-top:16px;font-weight:600;"></div>
      
      <div class="output-box" id="output" style="display:none;margin-top:16px;">
        <button class="copy-btn" onclick="copyOutput()">Copy</button>
        <pre id="code"></pre>
      </div>
    </div>
    
    <section class="faq">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <h3>What is JSON?</h3>
        <p>JSON (JavaScript Object Notation) is a lightweight data format used to exchange data between servers and web applications. It's human-readable and easy for machines to parse.</p>
      </div>
      <div class="faq-item">
        <h3>Why format JSON?</h3>
        <p>Minified JSON saves space but is hard to read. Formatting adds indentation and line breaks, making it much easier to debug and understand the structure of your data.</p>
      </div>
      <div class="faq-item">
        <h3>Is my JSON data safe?</h3>
        <p>Yes. All formatting happens in your browser. Your JSON data is never sent to any server.</p>
      </div>
    </section>
  </section>

  <script is:inline>
    function formatJSON() {
      var input = document.getElementById('jsonInput').value.trim();
      var status = document.getElementById('status');
      if (!input) { status.textContent = '⚠️ Please paste some JSON first.'; status.style.color = '#F59E0B'; return; }
      try {
        var parsed = JSON.parse(input);
        var formatted = JSON.stringify(parsed, null, 2);
        showOutput(formatted);
        status.textContent = '✅ Valid JSON — Formatted successfully!';
        status.style.color = '#10B981';
      } catch (e) {
        status.textContent = '❌ Invalid JSON: ' + e.message;
        status.style.color = '#EF4444';
      }
    }
    
    function minifyJSON() {
      var input = document.getElementById('jsonInput').value.trim();
      var status = document.getElementById('status');
      try {
        var parsed = JSON.parse(input);
        var minified = JSON.stringify(parsed);
        showOutput(minified);
        status.textContent = '✅ Minified successfully!';
        status.style.color = '#10B981';
      } catch (e) {
        status.textContent = '❌ Invalid JSON: ' + e.message;
        status.style.color = '#EF4444';
      }
    }
    
    function validateJSON() {
      var input = document.getElementById('jsonInput').value.trim();
      var status = document.getElementById('status');
      try {
        JSON.parse(input);
        status.textContent = '✅ Valid JSON!';
        status.style.color = '#10B981';
      } catch (e) {
        status.textContent = '❌ Invalid JSON: ' + e.message;
        status.style.color = '#EF4444';
      }
    }
    
    function showOutput(text) {
      document.getElementById('output').style.display = 'block';
      document.getElementById('code').textContent = text;
    }
    
    function copyOutput() {
      var code = document.getElementById('code').textContent;
      navigator.clipboard.writeText(code).then(function() {
        document.querySelector('.copy-btn').textContent = 'Copied!';
        setTimeout(function() { document.querySelector('.copy-btn').textContent = 'Copy'; }, 2000);
      });
    }
  </script>
</BaseLayout>
