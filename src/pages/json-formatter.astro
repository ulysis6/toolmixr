---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "JSON Formatter & Validator - Beautify JSON Online Free";
const pageUrl = "https://toolmixr.com/json-formatter";

const structuredData = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": pageTitle,
    "url": pageUrl,
    "description": "Free online JSON formatter, validator, and beautifier. Format messy JSON into readable code instantly.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is JSON?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "JSON (JavaScript Object Notation) is a lightweight data format used to exchange data between servers and web applications. It is human-readable and easy for machines to parse."
        }
      },
      {
        "@type": "Question",
        "name": "Why format JSON?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Minified JSON saves space but is hard to read. Formatting adds indentation and line breaks, making it much easier to debug and understand the structure of your data."
        }
      },
      {
        "@type": "Question",
        "name": "Is my JSON data safe?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. All formatting happens in your browser. Your JSON data is never sent to any server."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://toolmixr.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": pageTitle,
        "item": pageUrl
      }
    ]
  }

import AffiliateBanner from '../components/AffiliateBanner.astro';]);
---

<BaseLayout 
  title={pageTitle} 
  description="Free online JSON formatter, validator, and beautifier. Format messy JSON into readable code instantly."
  structuredData={structuredData}
>
  <section class="tool-page">
  <nav class="breadcrumb">
    <a href="/">Home</a> <span class="breadcrumb-sep">›</span> <span>JSON Formatter</span>
  </nav>
  <div class="tool-header">
    <h1>&#123;&#125; JSON Formatter & Validator</h1>
    <div class="share-bar">
      <a class="share-btn share-twitter" href="#" onclick="shareTwitter(event)" title="Share on Twitter">𝕏</a>
      <a class="share-btn share-facebook" href="#" onclick="shareFacebook(event)" title="Share on Facebook">f</a>
      <a class="share-btn share-linkedin" href="#" onclick="shareLinkedIn(event)" title="Share on LinkedIn">in</a>
      <a class="share-btn share-reddit" href="#" onclick="shareReddit(event)" title="Share on Reddit">R</a>
      <button class="share-btn share-copy" onclick="copyPageLink(event)" title="Copy link">🔗</button>
    </div>
  </div>
  <p class="subtitle">Format, validate, and beautify JSON data instantly</p>
    
    <div class="tool-box">
      <div class="form-group">
        <label for="jsonInput">Paste your JSON here</label>
        <textarea id="jsonInput" rows="10" placeholder="Paste JSON: key-value pairs, arrays, objects..."></textarea>
      </div>
      
      <div style="display:flex;gap:12px;flex-wrap:wrap;">
        <button class="btn btn-primary" onclick="formatJSON()">Format / Beautify</button>
        <button class="btn btn-secondary" onclick="minifyJSON()">Minify</button>
        <button class="btn btn-secondary" onclick="validateJSON()">Validate Only</button>
        <button class="btn btn-secondary" onclick="copyOutput()">📋 Copy</button>
      </div>
      
      <div id="status" style="margin-top:16px;font-weight:600;"></div>
      
      <div class="output-box" id="output" style="display:none;margin-top:16px;">
        <button class="copy-btn" onclick="copyOutput()">Copy</button>
        <pre id="code"></pre>
      </div>
    

    <AffiliateBanner />
    
    <section class="guide">
      <h2>JSON: The Universal Data Format</h2>
      <p>JSON (JavaScript Object Notation) is the dominant data format for web APIs, configuration files, and data storage. If you work with web development, mobile apps, or backend services, you'll deal with JSON daily. Understanding it deeply — not just superficially — will save you countless hours of debugging.</p>
      
      <h3>The JSON Syntax Rules</h3>
      <p>JSON has strict rules that catch many beginners:</p>
      <ul>
        <li><strong>Keys must be strings</strong>: Always in double quotes. &#123;"name": "John"&#125; not &#123;name: "John"&#125;</li>
        <li><strong>Values can be</strong>: strings, numbers, booleans, arrays, objects, null</li>
        <li><strong>No trailing commas</strong>: &#123;"name": "John",&#125; is invalid. Remove the comma.</li>
        <li><strong>No comments</strong>: JSON doesn't support comments. Use a separate schema or documentation file.</li>
        <li><strong>No single quotes</strong>: Always use double quotes for strings</li>
      </ul>

      <h3>Common JSON Mistakes</h3>
      <p>The most common errors I see:</p>
      <pre><code>// Wrong: trailing comma
&#123;"name": "John",&#125;

// Wrong: single quotes
&#123;'name': 'John'&#125;

// Wrong: unquoted key
&#123;name: "John"&#125;

// Wrong: comment (invalid in JSON)
&#123;
  "name": "John",  // this is invalid
  "age": 30
&#125;</code></pre>

      <h3>JSON vs. XML: When to Use Which</h3>
      <p>Both are data formats, but with different strengths:</p>
      <ul>
        <li><strong>JSON</strong>: More compact, maps directly to JavaScript objects, easier to parse, preferred for web APIs</li>
        <li><strong>XML</strong>: Supports comments, namespaces, schemas, metadata, better for documents with complex hierarchical metadata</li>
      </ul>
      <p>For web APIs in 2024, JSON dominates. XML is still used in enterprise systems and specific industries (finance, legal) but is declining.</p>

      <h3>Handling Large JSON Files</h3>
      <p>When JSON files get large (10MB+), standard editors struggle. Solutions:</p>
      <ul>
        <li><strong>jq</strong>: Command-line JSON processor. <code>cat file.json | jq '.'</code> to format, <code>jq '.key' file.json</code> to extract</li>
        <li><strong>Stream parsing</strong>: Libraries like JSONStream for Node.js handle large files without loading entirely into memory</li>
        <li><strong>Online formatters</strong>: Work for files up to ~10MB; beyond that, use local tools</li>
      </ul>

      <h3>JSON Schema: Validating Structure</h3>
      <p>For APIs and data pipelines, validate JSON structure with JSON Schema:</p>
      <pre><code>&#123;
  "type": "object",
  "required": ["id", "email"],
  "properties": &#123;
    "id": &#123; "type": "integer" &#125;,
    "email": &#123; "type": "string", "format": "email" &#125;,
    "name": &#123; "type": "string" &#125;
  &#125;
&#125;</code></pre>
      <p>Tools like Ajv (for JavaScript) or jsonschema (for Python) integrate schema validation into your build pipeline or API validation layer.</p>

      <h3>Step-by-Step Guide</h3>
      <ol>
        <li><strong>Paste your JSON</strong> — Copy and paste any JSON data into the input area. It can be minified (no spaces) or already formatted.</li>
        <li><strong>Choose your action</strong> — Click "Format / Beautify" to add proper indentation, "Minify" to remove all whitespace, or "Validate Only" to check syntax.</li>
        <li><strong>Review the output</strong> — See formatted JSON with syntax highlighting, or error messages if the JSON is invalid.</li>
        <li><strong>Copy the result</strong> — Click the copy button to copy the formatted output to your clipboard.</li>
      </ol>
      
      <h3>Tips & Best Practices</h3>
      <ul>
        <li><strong>Use 2 or 4 space indentation</strong> — 2 spaces is more common in JavaScript; 4 spaces in Python. Choose based on your project's conventions.</li>
        <li><strong>Validate before sending</strong> — Always validate JSON before sending to an API. Catch errors early instead of debugging cryptic API error messages.</li>
        <li><strong>Minify for production</strong> — Smaller files load faster. Minify JSON in production to reduce bandwidth and improve performance.</li>
        <li><strong>Common JSON errors</strong> — Trailing commas, single quotes (use double quotes), unquoted keys (keys must be quoted), and missing brackets are the most common mistakes.</li>
      </ul>
    </section>
    <section class="faq">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>What is JSON?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>JSON (JavaScript Object Notation) is a lightweight data format used to exchange data between servers and web applications. It's human-readable and easy for machines to parse.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>Why format JSON?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>Minified JSON saves space but is hard to read. Formatting adds indentation and line breaks, making it much easier to debug and understand the structure of your data.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>Is my JSON data safe?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>Yes. All formatting happens in your browser. Your JSON data is never sent to any server.</p>
        </div>
      </div>
    </section>

    <section class="related-tools">
      <h2>Related Tools</h2>
      <div class="related-tools-grid">
        <a href="/base64-encoder-decoder" class="related-tool-card">
          <span class="related-icon">🔐</span>
          <span class="related-name">Base64 Encoder/Decoder</span>
        </a>
        <a href="/url-encoder-decoder" class="related-tool-card">
          <span class="related-icon">🔗</span>
          <span class="related-name">URL Encoder/Decoder</span>
        </a>
        <a href="/word-counter" class="related-tool-card">
          <span class="related-icon">📝</span>
          <span class="related-name">Word Counter</span>
        </a>
        <a href="/sitemap-generator" class="related-tool-card">
          <span class="related-icon">🗺️</span>
          <span class="related-name">Sitemap Generator</span>
        </a>
      </div>
    </section>
  </section>

  <script is:inline>
    function formatJSON() {
      var input = document.getElementById('jsonInput').value.trim();
      var status = document.getElementById('status');
      if (!input) { status.textContent = '⚠️ Please paste some JSON first.'; status.style.color = '#F59E0B'; return; }
      try {
        var parsed = JSON.parse(input);
        var formatted = JSON.stringify(parsed, null, 2);
        showOutput(formatted);
        status.textContent = '✅ Valid JSON — Formatted successfully!';
        status.style.color = '#10B981';
      } catch (e) {
        status.textContent = '❌ Invalid JSON: ' + e.message;
        status.style.color = '#EF4444';
      }
    }
    
    function minifyJSON() {
      var input = document.getElementById('jsonInput').value.trim();
      var status = document.getElementById('status');
      try {
        var parsed = JSON.parse(input);
        var minified = JSON.stringify(parsed);
        showOutput(minified);
        status.textContent = '✅ Minified successfully!';
        status.style.color = '#10B981';
      } catch (e) {
        status.textContent = '❌ Invalid JSON: ' + e.message;
        status.style.color = '#EF4444';
      }
    }
    
    function validateJSON() {
      var input = document.getElementById('jsonInput').value.trim();
      var status = document.getElementById('status');
      try {
        JSON.parse(input);
        status.textContent = '✅ Valid JSON!';
        status.style.color = '#10B981';
      } catch (e) {
        status.textContent = '❌ Invalid JSON: ' + e.message;
        status.style.color = '#EF4444';
      }
    }
    
    function showOutput(text) {
      document.getElementById('output').style.display = 'block';
      document.getElementById('code').textContent = text;
    }
    
    function copyOutput() {
      var code = document.getElementById('code').textContent;
      if (!code) return;
      navigator.clipboard.writeText(code).then(function() {
        document.querySelector('.copy-btn').textContent = 'Copied!';
        setTimeout(function() { document.querySelector('.copy-btn').textContent = 'Copy'; }, 2000);
      });
    }
  </script>
</BaseLayout>
