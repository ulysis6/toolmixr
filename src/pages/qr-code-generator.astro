---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "QR Code Generator - Create QR Codes for URLs & Text Free";
const pageUrl = "https://toolmixr.com/qr-code-generator";

const structuredData = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": pageTitle,
    "url": pageUrl,
    "description": "Free online QR code generator. Create QR codes for URLs, text, WiFi, email, and more. Download as PNG.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is a QR code?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A QR (Quick Response) code is a two-dimensional barcode that can store URLs, text, contact info, and other data. Scan it with a smartphone camera to instantly access the encoded information."
        }
      },
      {
        "@type": "Question",
        "name": "Is there a limit to QR code content?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "QR codes can store up to ~4,000 characters, but shorter content creates smaller, more scannable codes. For best results, keep URLs short and use URL shorteners if needed."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://toolmixr.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": pageTitle,
        "item": pageUrl
      }
    ]
  }
]);
---

<BaseLayout 
  title={pageTitle} 
  description="Free online QR code generator. Create QR codes for URLs, text, WiFi, email, and more. Download as PNG."
  structuredData={structuredData}
>
  <section class="tool-page">
  <nav class="breadcrumb">
    <a href="/">Home</a> <span class="breadcrumb-sep">›</span> <span>QR Code Generator</span>
  </nav>
  <div class="tool-header">
    <h1>📱 QR Code Generator</h1>
    <div class="share-bar">
      <a class="share-btn share-twitter" href="#" onclick="shareTwitter(event)" title="Share on Twitter">𝕏</a>
      <a class="share-btn share-facebook" href="#" onclick="shareFacebook(event)" title="Share on Facebook">f</a>
      <a class="share-btn share-linkedin" href="#" onclick="shareLinkedIn(event)" title="Share on LinkedIn">in</a>
      <a class="share-btn share-reddit" href="#" onclick="shareReddit(event)" title="Share on Reddit">R</a>
      <button class="share-btn share-copy" onclick="copyPageLink(event)" title="Copy link">🔗</button>
    </div>
  </div>
  <p class="subtitle">Create QR codes for URLs, text, WiFi, and more</p>
    
    <div class="tool-box">
      <div class="form-group">
        <label for="qrType">Content Type</label>
        <select id="qrType" onchange="updatePlaceholder()">
          <option value="url">URL</option>
          <option value="text">Plain Text</option>
          <option value="wifi">WiFi</option>
          <option value="email">Email</option>
        </select>
      </div>
      
      <div id="urlFields">
        <div class="form-group">
          <label for="urlInput">URL</label>
          <input type="url" id="urlInput" placeholder="https://example.com" />
        </div>
      </div>
      
      <div id="textFields" style="display:none;">
        <div class="form-group">
          <label for="textInput">Text</label>
          <textarea id="textInput" rows="3" placeholder="Enter your text here..."></textarea>
        </div>
      </div>
      
      <div id="wifiFields" style="display:none;">
        <div class="form-group">
          <label for="wifiSSID">Network Name (SSID)</label>
          <input type="text" id="wifiSSID" placeholder="MyWiFi" />
        </div>
        <div style="display:flex;gap:12px;flex-wrap:wrap;">
          <div class="form-group" style="flex:1;min-width:160px;">
            <label for="wifiPass">Password</label>
            <input type="text" id="wifiPass" placeholder="password123" />
          </div>
          <div class="form-group" style="flex:1;min-width:160px;">
            <label for="wifiEnc">Encryption</label>
            <select id="wifiEnc">
              <option value="WPA">WPA/WPA2</option>
              <option value="WEP">WEP</option>
              <option value="">None</option>
            </select>
          </div>
        </div>
      </div>
      
      <div id="emailFields" style="display:none;">
        <div class="form-group">
          <label for="emailAddr">Email Address</label>
          <input type="email" id="emailAddr" placeholder="hello@example.com" />
        </div>
        <div class="form-group">
          <label for="emailSubject">Subject (optional)</label>
          <input type="text" id="emailSubject" placeholder="Hello" />
        </div>
      </div>
      
      <div class="form-group">
        <label for="qrSize">Size: <span id="sizeVal">256</span>px</label>
        <input type="range" id="qrSize" min="128" max="512" value="256" step="64" oninput="document.getElementById('sizeVal').textContent=this.value" style="width:100%;" />
      </div>
      
      <div style="display:flex;gap:12px;">
        <button class="btn btn-primary" onclick="generateQR()">Generate QR Code</button>
      </div>
      
      <div id="qrResult" style="display:none;margin-top:24px;text-align:center;">
        <div style="background:white;padding:24px;border-radius:var(--radius);display:inline-block;">
          <img id="qrImage" alt="QR Code" style="display:block;" />
        </div>
        <div style="margin-top:16px;">
          <button class="btn btn-secondary" onclick="downloadQR()">💾 Download PNG</button>
        </div>
      </div>
    

    <section class="guide">
      <h2>QR Codes: The Technology Behind the Black-and-White Squares</h2>
      <p>QR codes were invented in 1994 for tracking Toyota vehicles and sat in relative obscurity for 25 years. Then 2020 happened, and suddenly everyone needed contactless solutions. Understanding how QR codes actually work helps you create ones that scan reliably and understand why some fail.</p>
      
      <h3>How QR Codes Store Data</h3>
      <p>QR codes are two-dimensional barcodes made of black and white modules arranged in a grid. The three large squares in the corners (position markers) help scanners orient and locate the code. The smaller alignment pattern helps correct for perspective distortion.</p>
      <p>Data is encoded in the remaining modules, with error correction built in using Reed-Solomon codes — the same technology used in CDs, DVDs, and satellite transmissions.</p>

      <h3>Error Correction: Why QR Codes Can Be Partially Damaged</h3>
      <p>This is the clever part. QR codes can recover from damage thanks to error correction levels:</p>
      <ul>
        <li><strong>L (Low)</strong>: ~7% recovery — Maximum data capacity, minimal redundancy</li>
        <li><strong>M (Medium)</strong>: ~15% recovery — Good balance for most uses</li>
        <li><strong>Q (Quartile)</strong>: ~25% recovery — Good for industrial or outdoor use</li>
        <li><strong>H (High)</strong>: ~30% recovery — Use when adding logos or custom designs</li>
      </ul>
      <p>Higher error correction means more of the code can be damaged or covered while still scanning, but it requires more modules for the same data.</p>

      <h3>Data Capacity by Version</h3>
      <p>QR codes come in 40 versions (sizes), from 21x21 modules to 177x177 modules. Capacity depends on what you're encoding:</p>
      <ul>
        <li><strong>Numeric only</strong>: Up to 7,089 characters (Version 40)</li>
        <li><strong>Alphanumeric</strong>: Up to 4,296 characters</li>
        <li><strong>Binary/Byte</strong>: Up to 2,953 bytes</li>
      </ul>
      <p>For most uses — URLs, short text, contact info — even Version 1 or 2 is more than enough.</p>

      <h3>Why QR Codes Fail to Scan</h3>
      <p>The most common reasons QR codes don't work:</p>
      <ul>
        <li><strong>Insufficient contrast</strong>: Use pure black (#000000) on pure white (#FFFFFF). Gray from low-resolution scaling kills scans.</li>
        <li><strong>Quiet zone violation</strong>: The white border around the code isn't decorative. Minimum: 4 modules wide on all sides.</li>
        <li><strong>Too small</strong>: A QR code printed at 1cm square might not scan reliably, especially from a distance.</li>
        <li><strong>Curved surfaces</strong>: Printing on bottles or curved packaging distorts the modules.</li>
      </ul>

      <h3>Security: Malicious QR Codes</h3>
      <p>QR codes can encode malicious URLs. Someone could replace a legitimate QR code with one that sends you to a phishing site or initiates a payment. Always preview the URL before following it, especially for QR codes in public places where they could have been swapped.</p>

      <h3>Step-by-Step Guide</h3>
      <ol>
        <li><strong>Choose content type</strong> — Select URL for web links, Text for plain text, WiFi for network credentials, or Email for mailto links.</li>
        <li><strong>Enter your content</strong> — Fill in the relevant fields based on your type. For URLs, include the full https:// prefix.</li>
        <li><strong>Generate the QR code</strong> — Click Generate to create your QR code instantly.</li>
        <li><strong>Download as PNG</strong> — Right-click and save the image, or use the download button if available.</li>
      </ol>
      
      <h3>Tips & Best Practices</h3>
      <ul>
        <li><strong>Minimum size for print</strong> — For print materials, use at least 200x200 pixels (printed about 1 inch). Larger is always better for scanning reliability.</li>
        <li><strong>Test before printing</strong> — Always test your QR code with multiple phones before going to print. A failed print run is expensive!</li>
        <li><strong>Keep URLs short</strong> — Long URLs create dense, hard-to-scan QR codes. Use URL shorteners like bit.ly for cleaner codes.</li>
        <li><strong>Leave quiet zone</strong> — Keep white space around your QR code. The margin prevents accidental scans from adjacent elements.</li>
      </ul>
    </section>
    <section class="faq">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>What is a QR code?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>A QR (Quick Response) code is a two-dimensional barcode that can store URLs, text, contact info, and other data. Scan it with a smartphone camera to instantly access the encoded information.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>Is there a limit to QR code content?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>QR codes can store up to ~4,000 characters, but shorter content creates smaller, more scannable codes. For best results, keep URLs short and use URL shorteners if needed.</p>
        </div>
      </div>
    </section>

    <section class="related-tools">
      <h2>Related Tools</h2>
      <div class="related-tools-grid">
        <a href="/color-palette-generator" class="related-tool-card">
          <span class="related-icon">🎨</span>
          <span class="related-name">Color Palette Generator</span>
        </a>
        <a href="/url-encoder-decoder" class="related-tool-card">
          <span class="related-icon">🔗</span>
          <span class="related-name">URL Encoder/Decoder</span>
        </a>
        <a href="/password-generator" class="related-tool-card">
          <span class="related-icon">🔑</span>
          <span class="related-name">Password Generator</span>
        </a>
        <a href="/base64-encoder-decoder" class="related-tool-card">
          <span class="related-icon">🔐</span>
          <span class="related-name">Base64 Encoder/Decoder</span>
        </a>
      </div>
    </section>
  </section>

  <script is:inline>
    function updatePlaceholder() {
      var type = document.getElementById('qrType').value;
      document.getElementById('urlFields').style.display = type === 'url' ? '' : 'none';
      document.getElementById('textFields').style.display = type === 'text' ? '' : 'none';
      document.getElementById('wifiFields').style.display = type === 'wifi' ? '' : 'none';
      document.getElementById('emailFields').style.display = type === 'email' ? '' : 'none';
    }
    
    function generateQR() {
      var type = document.getElementById('qrType').value;
      var size = document.getElementById('qrSize').value;
      var data = '';
      
      if (type === 'url') {
        data = document.getElementById('urlInput').value.trim();
      } else if (type === 'text') {
        data = document.getElementById('textInput').value.trim();
      } else if (type === 'wifi') {
        var ssid = document.getElementById('wifiSSID').value.trim();
        var pass = document.getElementById('wifiPass').value.trim();
        var enc = document.getElementById('wifiEnc').value;
        data = 'WIFI:T:' + enc + ';S:' + ssid + ';P:' + pass + ';;';
      } else if (type === 'email') {
        var addr = document.getElementById('emailAddr').value.trim();
        var subject = document.getElementById('emailSubject').value.trim();
        data = subject ? 'mailto:' + addr + '?subject=' + encodeURIComponent(subject) : 'mailto:' + addr;
      }
      
      if (!data) {
        alert('Please enter content to generate QR code');
        return;
      }
      
      var qrUrl = 'https://api.qrserver.com/v1/create-qr-code/?size=' + size + 'x' + size + '&data=' + encodeURIComponent(data);
      document.getElementById('qrImage').src = qrUrl;
      document.getElementById('qrResult').style.display = 'block';
    }
    
    function downloadQR() {
      var img = document.getElementById('qrImage');
      var link = document.createElement('a');
      link.download = 'qrcode.png';
      link.href = img.src;
      link.click();
    }
  </script>
</BaseLayout>
