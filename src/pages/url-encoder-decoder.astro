---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "URL Encoder/Decoder";
const pageUrl = "https://toolmixr.com/url-encoder-decoder";

const structuredData = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": pageTitle,
    "url": pageUrl,
    "description": "Free online URL encoder and decoder. Encode or decode URLs and query parameters instantly.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is URL encoding?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "URL encoding converts special characters into percent-encoded format (e.g., space becomes %20). This ensures URLs remain valid when they contain characters that have special meaning in URL syntax."
        }
      },
      {
        "@type": "Question",
        "name": "What's the difference between encodeURI and encodeURIComponent?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "encodeURI encodes a full URL but preserves characters like :, /, ?, &, = that are part of URL structure. encodeURIComponent encodes everything, including those characters — use it for individual query parameter values."
        }
      },
      {
        "@type": "Question",
        "name": "When should I URL-encode?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Always encode values you are putting into query parameters. For example, if a search term contains spaces or special characters, encode it before appending to a URL."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://toolmixr.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": pageTitle,
        "item": pageUrl
      }
    ]
  }
]);
---

<BaseLayout 
  title={pageTitle} 
  description="Free online URL encoder and decoder. Encode or decode URLs and query parameters instantly."
  structuredData={structuredData}
>
  <section class="tool-page">
    <h1>🔗 URL Encoder / Decoder</h1>
    <p class="subtitle">Encode or decode URLs and query parameters instantly</p>
    <div class="share-bar">
      <span class="share-label">Share:</span>
      <a class="share-btn share-twitter" href="#" onclick="shareTwitter(event)" title="Share on Twitter">𝕏</a>
      <a class="share-btn share-facebook" href="#" onclick="shareFacebook(event)" title="Share on Facebook">f</a>
      <a class="share-btn share-linkedin" href="#" onclick="shareLinkedIn(event)" title="Share on LinkedIn">in</a>
      <a class="share-btn share-reddit" href="#" onclick="shareReddit(event)" title="Share on Reddit">R</a>
      <button class="share-btn share-copy" onclick="copyPageLink(event)" title="Copy link">🔗</button>
    </div>
    
    <div class="tool-box">
      <div class="form-group">
        <label for="input">Input</label>
        <textarea id="input" rows="6" placeholder="Enter URL or encoded string..."></textarea>
      </div>
      
      <div style="display:flex;gap:12px;flex-wrap:wrap;" id="actionBtns">
        <button class="btn btn-primary action-btn" onclick="encodeURL(this)">Encode URL</button>
        <button class="btn btn-secondary action-btn" onclick="decodeURL(this)">Decode URL</button>
        <button class="btn btn-secondary action-btn" onclick="encodeComponent(this)">Encode Component</button>
        <button class="btn btn-secondary action-btn" onclick="decodeComponent(this)">Decode Component</button>
        <button class="btn btn-secondary" onclick="clearAll()">Clear</button>
      </div>
      
      <div class="output-box" id="output" style="display:none;margin-top:20px;">
        <button class="copy-btn" onclick="copyOutput()">Copy</button>
        <pre id="code"></pre>
      </div>
    

    <section class="guide">
      <h2>How to Use the URL Encoder/Decoder</h2>
      <p>Encode or decode URLs and their query parameters. URLs can only contain certain characters, so special characters must be encoded. This tool handles both full URLs and individual URL components.</p>
      
      <h3>Step-by-Step Guide</h3>
      <ol>
        <li><strong>Enter your URL or encoded string</strong> — Paste a complete URL or just the part you need to encode/decode.</li>
        <li><strong>Choose your operation</strong> — Select Encode URL, Decode URL, Encode Component, or Decode Component.</li>
        <li><strong>Review the result</strong> — See the transformed URL in the output area.</li>
        <li><strong>Copy the result</strong> — Copy the encoded or decoded URL for use in your code or browser.</li>
      </ol>
      
      <h3>Tips & Best Practices</h3>
      <ul>
        <li><strong>Always encode query parameter values</strong> — Spaces become %20, ampersands are reserved characters. Encode values before adding to URLs.</li>
        <li><strong>Use encodeURIComponent for values only</strong> — It encodes everything including reserved URL characters (/, ?, &). Use encodeURI for full URLs.</li>
        <li><strong>Reserved characters to remember</strong> — ? (query), & (parameters), = (assignment), # (fragment), / (path). These have special meaning and should not be encoded in their context.</li>
        <li><strong>Decode when debugging</strong> — If you see garbled text with %20 and %3D, that is URL encoding. Decode to read the original values.</li>
      </ul>
    </section>
    <section class="faq">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <h3>What is URL encoding?</h3>
        <p>URL encoding converts special characters into percent-encoded format (e.g., space becomes %20). This ensures URLs remain valid when they contain characters that have special meaning in URL syntax.</p>
      </div>
      <div class="faq-item">
        <h3>What's the difference between encodeURI and encodeURIComponent?</h3>
        <p><code>encodeURI</code> encodes a full URL but preserves characters like :, /, ?, &, = that are part of URL structure. <code>encodeURIComponent</code> encodes everything, including those characters — use it for individual query parameter values.</p>
      </div>
      <div class="faq-item">
        <h3>When should I URL-encode?</h3>
        <p>Always encode values you're putting into query parameters. For example, if a search term contains spaces or special characters, encode it before appending to a URL.</p>
      </div>
    </section>

    <section class="related-tools">
      <h2>Related Tools</h2>
      <div class="related-tools-grid">
        <a href="/base64-encoder-decoder" class="related-tool-card">
          <span class="related-icon">🔐</span>
          <span class="related-name">Base64 Encoder/Decoder</span>
        </a>
        <a href="/json-formatter" class="related-tool-card">
          <span class="related-icon">{}</span>
          <span class="related-name">JSON Formatter</span>
        </a>
        <a href="/qr-code-generator" class="related-tool-card">
          <span class="related-icon">📱</span>
          <span class="related-name">QR Code Generator</span>
        </a>
        <a href="/robots-txt-generator" class="related-tool-card">
          <span class="related-icon">🤖</span>
          <span class="related-name">Robots.txt Generator</span>
        </a>
      </div>
    </section>
  </section>

  <script is:inline>
    function setActive(btn) {
      var btns = document.querySelectorAll('.action-btn');
      for (var i = 0; i < btns.length; i++) {
        btns[i].className = 'btn btn-secondary action-btn';
      }
      btn.className = 'btn btn-primary action-btn';
    }
    function encodeURL(btn) {
      setActive(btn);
      var input = document.getElementById('input').value;
      showOutput(encodeURI(input));
    }
    function decodeURL(btn) {
      setActive(btn);
      try { showOutput(decodeURI(document.getElementById('input').value)); }
      catch(e) { alert('Decoding failed: ' + e.message); }
    }
    function encodeComponent(btn) {
      setActive(btn);
      var input = document.getElementById('input').value;
      showOutput(encodeURIComponent(input));
    }
    function decodeComponent(btn) {
      setActive(btn);
      try { showOutput(decodeURIComponent(document.getElementById('input').value)); }
      catch(e) { alert('Decoding failed: ' + e.message); }
    }
    function showOutput(text) {
      document.getElementById('output').style.display = 'block';
      document.getElementById('code').textContent = text;
    }
    function clearAll() {
      document.getElementById('input').value = '';
      document.getElementById('output').style.display = 'none';
    }
    function copyOutput() {
      var code = document.getElementById('code').textContent;
      navigator.clipboard.writeText(code).then(function() {
        document.querySelector('.copy-btn').textContent = 'Copied!';
        setTimeout(function() { document.querySelector('.copy-btn').textContent = 'Copy'; }, 2000);
      });
    }
  </script>
</BaseLayout>
