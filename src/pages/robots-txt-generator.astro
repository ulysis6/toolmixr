---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "Robots.txt Generator - Create Crawl Rules for Search Engines";
const pageUrl = "https://toolmixr.com/robots-txt-generator";

const structuredData = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": pageTitle,
    "url": pageUrl,
    "description": "Free online robots.txt generator. Easily create a robots.txt file to control how search engines crawl and index your website.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is a robots.txt file?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A robots.txt file tells search engine crawlers which pages or sections of your site they can or cannot access. It must be placed in the root directory of your website."
        }
      },
      {
        "@type": "Question",
        "name": "Is robots.txt a security tool?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. Robots.txt is a directive, not a security measure. Malicious bots may ignore it. Never use robots.txt to hide sensitive pages — use proper authentication instead."
        }
      },
      {
        "@type": "Question",
        "name": "Where should I put my robots.txt file?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Place it at the root of your domain: https://example.com/robots.txt. It will not work in subdirectories."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://toolmixr.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": pageTitle,
        "item": pageUrl
      }
    ]
  }
]);
---

<BaseLayout 
  title={pageTitle} 
  description="Free online robots.txt generator. Easily create a robots.txt file to control how search engines crawl and index your website."
  structuredData={structuredData}
>
  <section class="tool-page">
  <nav class="breadcrumb">
    <a href="/">Home</a> <span class="breadcrumb-sep">›</span> <span>Robots.txt Generator</span>
  </nav>
  <div class="tool-header">
    <h1>🤖 Robots.txt Generator</h1>
    <div class="share-bar">
      <a class="share-btn share-twitter" href="#" onclick="shareTwitter(event)" title="Share on Twitter">𝕏</a>
      <a class="share-btn share-facebook" href="#" onclick="shareFacebook(event)" title="Share on Facebook">f</a>
      <a class="share-btn share-linkedin" href="#" onclick="shareLinkedIn(event)" title="Share on LinkedIn">in</a>
      <a class="share-btn share-reddit" href="#" onclick="shareReddit(event)" title="Share on Reddit">R</a>
      <button class="share-btn share-copy" onclick="copyPageLink(event)" title="Copy link">🔗</button>
    </div>
  </div>
  <p class="subtitle">Create a robots.txt file to control search engine crawling</p>
    
    <div class="tool-box">
      <h3 style="margin-bottom:16px;">User-agent Rules</h3>
      <div id="rules">
        <div class="rule-row" style="display:flex;gap:12px;margin-bottom:12px;flex-wrap:wrap;align-items:end;">
          <div class="form-group" style="flex:1;min-width:180px;margin-bottom:0;">
            <label>User-agent</label>
            <select class="ua-select">
              <option value="*">All Robots (*)</option>
              <option value="Googlebot">Googlebot</option>
              <option value="Bingbot">Bingbot</option>
              <option value="Slurp">Yahoo (Slurp)</option>
              <option value="DuckDuckBot">DuckDuckBot</option>
              <option value="Baiduspider">Baiduspider</option>
              <option value="YandexBot">YandexBot</option>
            </select>
          </div>
          <div class="form-group" style="flex:1;min-width:180px;margin-bottom:0;">
            <label>Action</label>
            <select class="action-select">
              <option value="allow">Allow</option>
              <option value="disallow">Disallow</option>
            </select>
          </div>
          <div class="form-group" style="flex:2;min-width:200px;margin-bottom:0;">
            <label>Path</label>
            <input type="text" class="path-input" placeholder="/path/ or /" />
          </div>
        </div>
      </div>
      
      <button class="btn btn-secondary" onclick="addRule()" style="margin-bottom:20px;">+ Add Rule</button>
      
      <div class="form-group">
        <label>Sitemap URL (optional)</label>
        <input type="url" id="sitemap" placeholder="https://example.com/sitemap.xml" />
      </div>
      
      <div class="form-group">
        <label>Crawl-delay (seconds, optional)</label>
        <input type="number" id="crawlDelay" placeholder="e.g. 10" min="0" />
      </div>
      
      <div style="display:flex;gap:12px;margin-top:8px;">
        <button class="btn btn-primary" onclick="generateRobots()">Generate robots.txt</button>
        <button class="btn btn-secondary" onclick="copyOutput()">📋 Copy</button>
      </div>
      
      <div class="output-box" id="output" style="display:none;">
        <button class="copy-btn" onclick="copyOutput()">Copy</button>
        <pre id="code"></pre>
      </div>
    </div>
    
    <section class="guide">
      <h2>Robots.txt: Your Site's Traffic Cop</h2>
      <p>The robots.txt file tells search engine crawlers where they can and cannot go on your site. It's not security — it's a polite request. Well-behaved crawlers follow it; malicious bots ignore it completely. Understanding its syntax and limitations is essential for every website owner.</p>
      
      <h3>Basic Syntax and Rules</h3>
      <p>Robots.txt uses a simple format:</p>
      <pre><code>User-agent: [crawler name]
Disallow: [path to block]
Allow: [path to permit]</code></pre>
      <p>Wildcards are supported: * matches any characters, $ matches end of URL. Comments start with #.</p>
      <p>A common misconception: paths are case-sensitive. /Private/ and /private/ are different paths.</p>

      <h3>The Security Myth</h3>
      <p>Robots.txt is NOT a security mechanism. Anyone can view your robots.txt file directly by visiting yourdomain.com/robots.txt. It's visible to everyone, including malicious actors.</p>
      <p>If you have truly sensitive pages (admin panels, private user data, internal documents), don't rely on robots.txt. Use authentication, password protection, or noindex meta tags. Treat robots.txt as a crawl efficiency tool, not a security tool.</p>

      <h3>Common Mistakes That Break SEO</h3>
      <ul>
        <li><strong>Blocking CSS and JavaScript</strong>: Googlebot needs to render pages like a browser. Blocking /css/ or /js/ directories causes rendering problems and can tank your rankings.</li>
        <li><strong>Incorrect wildcard usage</strong>: Disallow: /private* blocks /private, /private-page, /private-area. But Disallow: /private blocks only /private, not subdirectories.</li>
        <li><strong>Forgetting the sitemap</strong>: Add your sitemap location: Sitemap: https://yoursite.com/sitemap.xml</li>
        <li><strong>Case sensitivity</strong>: User-agent: Googlebot (not GOOGLEBOT)</li>
      </ul>

      <h3>Special Directives for Googlebot</h3>
      <p>Google supports additional directives beyond the standard robots.txt:</p>
      <ul>
        <li><strong>Crawl-delay</strong>: How many seconds between requests (but Google often ignores this)</li>
        <li><strong>Googlebot-Image</strong>: Target image crawlers specifically</li>
        <li><strong>Googlebot-News</strong>: For news-specific crawling</li>
      </ul>

      <h3>Testing Your Robots.txt</h3>
      <p>Always test your robots.txt before deploying:</p>
      <ul>
        <li><strong>Google Search Console</strong>: robots.txt tester shows errors and warnings</li>
        <li><strong>Fetch as Google</strong>: Test specific URLs to see if Googlebot can access them</li>
        <li><strong>Browser preview</strong>: View your robots.txt in a browser to see what's visible</li>
      </ul>

      <h3>Step-by-Step Guide</h3>
      <ol>
        <li><strong>Add user-agent rules</strong> — Click "Add Rule" to create directives for specific crawlers (like Googlebot) or use * for all crawlers.</li>
        <li><strong>Set Allow or Disallow</strong> — "Allow" tells crawlers they can access a path. "Disallow" tells them to stay away.</li>
        <li><strong>Configure paths</strong> — Enter the URL paths. Use / for root, /admin/ for specific folders. Wildcards like * are supported.</li>
        <li><strong>Add your sitemap URL</strong> — Include a reference to your XML sitemap to help crawlers find it.</li>
        <li><strong>Generate and download</strong> — Copy the generated code and save it as robots.txt in your website's root directory.</li>
      </ol>
      
      <h3>Tips & Best Practices</h3>
      <ul>
        <li><strong>Always allow CSS and JS</strong> — Googlebot needs to access your stylesheets and JavaScript to properly render pages. Never block these directories.</li>
        <li><strong>Block private/admin areas</strong> — Use disallow for /admin/, /wp-admin/, /private/, or any backend areas. But remember: robots.txt is not security!</li>
        <li><strong>Validate your file</strong> — Use Google's robots.txt tester in Search Console to verify your file works correctly.</li>
        <li><strong>Robots.txt is not a security tool</strong> — Anyone can view your robots.txt. Use proper authentication for truly sensitive content.</li>
      </ul>
    </section>
    
    <section class="faq">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>What is a robots.txt file?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>A robots.txt file tells search engine crawlers which pages or sections of your site they can or cannot access. It must be placed in the root directory of your website.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>Is robots.txt a security tool?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>No. Robots.txt is a directive, not a security measure. Malicious bots may ignore it. Never use robots.txt to hide sensitive pages — use proper authentication instead.</p>
        </div>
      </div>
      <div class="faq-item">
        <h3>Where should I put my robots.txt file?</h3>
        <p>Place it at the root of your domain: <code>https://example.com/robots.txt</code>. It will not work in subdirectories.</p>
      </div>
    </section>

    <section class="related-tools">
      <h2>Related Tools</h2>
      <div class="related-tools-grid">
        <a href="/sitemap-generator" class="related-tool-card">
          <span class="related-icon">🗺️</span>
          <span class="related-name">Sitemap Generator</span>
        </a>
        <a href="/meta-tag-generator" class="related-tool-card">
          <span class="related-icon">🏷️</span>
          <span class="related-name">Meta Tag Generator</span>
        </a>
        <a href="/og-image-generator" class="related-tool-card">
          <span class="related-icon">🖼️</span>
          <span class="related-name">OG Image Generator</span>
        </a>
        <a href="/url-encoder-decoder" class="related-tool-card">
          <span class="related-icon">🔗</span>
          <span class="related-name">URL Encoder/Decoder</span>
        </a>
      </div>
    </section>
  </section>

  <script is:inline>
    function addRule() {
      var container = document.getElementById('rules');
      var row = document.createElement('div');
      row.className = 'rule-row';
      row.style.cssText = 'display:flex;gap:12px;margin-bottom:12px;flex-wrap:wrap;align-items:end;';
      row.innerHTML = '<div class="form-group" style="flex:1;min-width:180px;margin-bottom:0;"><label>User-agent</label><select class="ua-select"><option value="*">All Robots (*)</option><option value="Googlebot">Googlebot</option><option value="Bingbot">Bingbot</option><option value="Slurp">Yahoo (Slurp)</option><option value="DuckDuckBot">DuckDuckBot</option><option value="Baiduspider">Baiduspider</option><option value="YandexBot">YandexBot</option></select></div><div class="form-group" style="flex:1;min-width:180px;margin-bottom:0;"><label>Action</label><select class="action-select"><option value="allow">Allow</option><option value="disallow">Disallow</option></select></div><div class="form-group" style="flex:2;min-width:200px;margin-bottom:0;"><label>Path</label><input type="text" class="path-input" placeholder="/path/ or /"></div><button class="btn btn-secondary" onclick="this.parentElement.remove()" style="padding:8px 12px;">✕</button>';
      container.appendChild(row);
    }
    
    function generateRobots() {
      var rules = document.querySelectorAll('.rule-row');
      var sitemap = document.getElementById('sitemap').value.trim();
      var crawlDelay = document.getElementById('crawlDelay').value.trim();
      var lines = [];
      var currentUA = '';
      
      rules.forEach(function(row) {
        var ua = row.querySelector('.ua-select').value;
        var action = row.querySelector('.action-select').value;
        var path = row.querySelector('.path-input').value.trim() || '/';
        
        if (ua !== currentUA) {
          if (currentUA) lines.push('');
          lines.push('User-agent: ' + ua);
          currentUA = ua;
        }
        lines.push(action.charAt(0).toUpperCase() + action.slice(1) + ': ' + path);
        if (crawlDelay && ua === currentUA) {
          lines.push('Crawl-delay: ' + crawlDelay);
        }
      });
      
      if (sitemap) {
        if (rules.length > 0) lines.push('');
        lines.push('Sitemap: ' + sitemap);
      }
      
      document.getElementById('output').style.display = 'block';
      document.getElementById('code').textContent = lines.join('\n');
    }
    
    function copyOutput() {
      var code = document.getElementById('code').textContent;
      navigator.clipboard.writeText(code).then(function() {
        document.querySelector('.copy-btn').textContent = 'Copied!';
        setTimeout(function() { document.querySelector('.copy-btn').textContent = 'Copy'; }, 2000);
      });
    }
  </script>
</BaseLayout>
