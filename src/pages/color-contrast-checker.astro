---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "Color Contrast Checker - WCAG AA/AAA Accessibility Check";
const pageUrl = "https://toolmixr.com/color-contrast-checker";
const structuredData = JSON.stringify([
  {"@context":"https://schema.org","@type":"WebApplication","name":pageTitle,"url":pageUrl,"description":"Check color contrast ratios for WCAG AA and AAA compliance. Enter foreground and background colors to get instant pass/fail results.","applicationCategory":"DeveloperApplication","operatingSystem":"Any","offers":{"@type":"Offer","price":"0","priceCurrency":"USD"}},
  {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://toolmixr.com"},{"@type":"ListItem","position":2,"name":pageTitle,"item":pageUrl}]}

import AffiliateBanner from '../components/AffiliateBanner.astro';]);
---

<BaseLayout title={pageTitle} description="Check text-background color contrast against WCAG AA and AAA standards. Get instant pass/fail results with ratio scores. Free accessibility tool." structuredData={structuredData}>
  <section class="tool-page">
    <nav class="breadcrumb"><a href="/">Home</a> <span class="breadcrumb-sep">›</span> <span>Color Contrast Checker</span></nav>
    <div class="tool-header"><h1>👁️ Color Contrast Checker</h1></div>
    <p class="subtitle">Check if your text meets WCAG AA and AAA accessibility standards. Instant pass/fail with ratio scores.</p>
    
    <div class="tool-box">
      <div style="display:flex;gap:20px;flex-wrap:wrap;">
        <div style="flex:1;min-width:250px;">
          <div class="form-group">
            <label>Text Color</label>
            <div style="display:flex;gap:8px;align-items:center;">
              <input type="color" id="fgColor" value="#333333" onchange="check()" style="width:48px;height:40px;padding:2px;border:1px solid var(--border);border-radius:6px;cursor:pointer;">
              <input type="text" id="fgHex" value="#333333" oninput="syncFg(this.value)" style="flex:1;" placeholder="#333333">
            </div>
          </div>
          <div class="form-group">
            <label>Background Color</label>
            <div style="display:flex;gap:8px;align-items:center;">
              <input type="color" id="bgColor" value="#FFFFFF" onchange="check()" style="width:48px;height:40px;padding:2px;border:1px solid var(--border);border-radius:6px;cursor:pointer;">
              <input type="text" id="bgHex" value="#FFFFFF" oninput="syncBg(this.value)" style="flex:1;" placeholder="#FFFFFF">
            </div>
          </div>
        </div>
        <div style="flex:1;min-width:280px;">
          <div id="preview" style="border:1px solid var(--border);border-radius:var(--radius);padding:40px 20px;text-align:center;font-size:20px;font-weight:600;transition:all 0.3s;">
            The quick brown fox jumps over the lazy dog.
          </div>
        </div>
      </div>
      
      <div id="results" style="margin-top:24px;">
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;">
          <div style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:20px;text-align:center;">
            <div style="font-size:13px;color:var(--text-secondary);margin-bottom:4px;">Contrast Ratio</div>
            <div style="font-size:32px;font-weight:700;color:var(--primary);" id="ratio">21:1</div>
          </div>
          <div style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:20px;text-align:center;">
            <div style="font-size:13px;color:var(--text-secondary);margin-bottom:4px;">WCAG AA (Normal Text)</div>
            <div style="font-size:24px;font-weight:700;" id="aa-normal"></div>
          </div>
          <div style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:20px;text-align:center;">
            <div style="font-size:13px;color:var(--text-secondary);margin-bottom:4px;">WCAG AA (Large Text)</div>
            <div style="font-size:24px;font-weight:700;" id="aa-large"></div>
          </div>
          <div style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:20px;text-align:center;">
            <div style="font-size:13px;color:var(--text-secondary);margin-bottom:4px;">WCAG AAA</div>
            <div style="font-size:24px;font-weight:700;" id="aaa"></div>
          </div>
        </div>
      </div>
    </div>

    <AffiliateBanner />
    
    <section class="guide" style="margin-top:40px;">
      <h2>WCAG Contrast Requirements</h2>
      <table class="legal-table">
        <thead><tr><th>Level</th><th>Normal Text</th><th>Large Text (≥18pt bold or ≥24pt)</th></tr></thead>
        <tbody>
          <tr><td><strong>AA</strong></td><td>4.5:1</td><td>3:1</td></tr>
          <tr><td><strong>AAA</strong></td><td>7:1</td><td>4.5:1</td></tr>
        </tbody>
      </table>
      <p style="margin-top:12px;color:var(--text-secondary);">AA is the minimum for accessibility compliance. AAA provides enhanced contrast for users with low vision. Most websites target AA compliance.</p>
    </section>

    <section class="faq" style="margin-top:40px;">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item"><button class="faq-question" onclick="toggleFaq(this)"><span>What is contrast ratio?</span><span class="faq-arrow">▸</span></button><div class="faq-answer"><p>Contrast ratio measures the difference in luminance between two colors. Higher ratios mean more contrast and better readability. The ratio ranges from 1:1 (identical colors) to 21:1 (black on white).</p></div></div>
      <div class="faq-item"><button class="faq-question" onclick="toggleFaq(this)"><span>What is WCAG?</span><span class="faq-arrow">▸</span></button><div class="faq-answer"><p>WCAG (Web Content Accessibility Guidelines) is the international standard for web accessibility. AA compliance is legally required in many jurisdictions. Meeting AA standards ensures your content is readable by users with visual impairments.</p></div></div>
      <div class="faq-item"><button class="faq-question" onclick="toggleFaq(this)"><span>Are my colors sent to a server?</span><span class="faq-arrow">▸</span></button><div class="faq-answer"><p>No. All calculations happen in your browser. Your colors never leave your device.</p></div></div>
    </section>
  </section>

  <script is:inline>
    function hexToRgb(hex) {
      hex = hex.replace('#','');
      if (hex.length === 3) hex = hex[0]+hex[0]+hex[1]+hex[1]+hex[2]+hex[2];
      return { r: parseInt(hex.slice(0,2),16), g: parseInt(hex.slice(2,4),16), b: parseInt(hex.slice(4,6),16) };
    }
    
    function luminance(rgb) {
      var s = ['r','g','b'].map(function(c) { var v = rgb[c]/255; return v <= 0.03928 ? v/12.92 : Math.pow((v+0.055)/1.055, 2.4); });
      return 0.2126*s[0] + 0.7152*s[1] + 0.0722*s[2];
    }
    
    function contrast(fg, bg) {
      var l1 = luminance(fg), l2 = luminance(bg);
      return (Math.max(l1,l2)+0.05)/(Math.min(l1,l2)+0.05);
    }
    
    function check() {
      var fg = hexToRgb(document.getElementById('fgHex').value || '#333333');
      var bg = hexToRgb(document.getElementById('bgHex').value || '#FFFFFF');
      document.getElementById('fgColor').value = document.getElementById('fgHex').value;
      document.getElementById('bgColor').value = document.getElementById('bgHex').value;
      var r = contrast(fg, bg);
      document.getElementById('ratio').textContent = r.toFixed(1) + ':1';
      var p = document.getElementById('preview');
      p.style.color = document.getElementById('fgHex').value;
      p.style.background = document.getElementById('bgHex').value;
      
      var badge = function(ok) { return ok ? '<span style="color:#10B981;">✅ PASS</span>' : '<span style="color:#EF4444;">❌ FAIL</span>'; };
      document.getElementById('aa-normal').innerHTML = badge(r >= 4.5);
      document.getElementById('aa-large').innerHTML = badge(r >= 3);
      document.getElementById('aaa').innerHTML = badge(r >= 7);
    }
    
    function syncFg(v) { document.getElementById('fgColor').value = v.match(/^#[0-9a-fA-F]{6}$/) ? v : '#000000'; check(); }
    function syncBg(v) { document.getElementById('bgColor').value = v.match(/^#[0-9a-fA-F]{6}$/) ? v : '#FFFFFF'; check(); }
    
    document.getElementById('fgColor').addEventListener('input', function() { document.getElementById('fgHex').value = this.value; check(); });
    document.getElementById('bgColor').addEventListener('input', function() { document.getElementById('bgHex').value = this.value; check(); });
    
    check();
  </script>
</BaseLayout>
