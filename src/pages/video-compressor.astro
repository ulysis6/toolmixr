---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "Video Compressor - Compress MP4 Free Online";
const pageUrl = "https://toolmixr.com/video-compressor";

const structuredData = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": pageTitle,
    "url": pageUrl,
    "description": "Free online video compressor. Compress MP4 files in your browser using FFmpeg WASM. No upload needed — your videos never leave your device.",
    "applicationCategory": "DesignApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is my video data sent to a server?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. All compression happens entirely in your browser using FFmpeg compiled to WebAssembly (WASM). Your videos never leave your device — no server upload, no cloud processing, no storage."
        }
      },
      {
        "@type": "Question",
        "name": "What is CRF and how does it affect quality?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "CRF (Constant Rate Factor) is FFmpeg's quality-based encoding mode. Lower CRF values produce better quality but larger files. CRF 18 is visually lossless, CRF 23 is the default, and CRF 28+ shows visible compression artifacts. Our quality slider maps 0-100% to CRF 51-18."
        }
      },
      {
        "@type": "Question",
        "name": "What video formats are supported?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "This tool supports MP4 input (H.264 encoded videos). The output is also an MP4 file with H.264 video and AAC audio. If your video is in another format, convert it to MP4 first."
        }
      },
      {
        "@type": "Question",
        "name": "Is there a file size limit?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Because processing happens entirely in your browser's memory, very large files may cause issues. We recommend compressing videos under 500 MB. Files larger than 500 MB will show a warning."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://toolmixr.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": pageTitle,
        "item": pageUrl
      }
    ]
  }
]);
---

