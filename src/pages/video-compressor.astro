  <script is:inline>
    var currentVideoData = null; // { name, originalSize, compressedSize, blob, crf, quality }

    function formatSize(bytes) {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
      return (bytes / 1048576).toFixed(2) + ' MB';
    }

    function updateQuality(val) {
      document.getElementById('qualityVal').textContent = val;
    }

    function setupDropZone() {
      var dropZone = document.getElementById('dropZone');
      var fileInput = document.getElementById('fileInput');

      dropZone.addEventListener('click', function() {
        fileInput.click();
      });

      dropZone.addEventListener('dragover', function(e) {
        e.preventDefault();
        dropZone.classList.add('drag-over');
      });

      dropZone.addEventListener('dragleave', function(e) {
        e.preventDefault();
        dropZone.classList.remove('drag-over');
      });

      dropZone.addEventListener('drop', function(e) {
        e.preventDefault();
        dropZone.classList.remove('drag-over');
        if (e.dataTransfer.files.length > 0) {
          handleFile(e.dataTransfer.files[0]);
        }
      });

      fileInput.addEventListener('change', function() {
        if (this.files.length > 0) {
          handleFile(this.files[0]);
        }
        this.value = '';
      });
    }

    function handleFile(file) {
      // Check file type
      if (!file.type.startsWith('video/') && !file.name.match(/\.mp4$/i)) {
        alert('Please select an MP4 video file.');
        return;
      }

      // Check file size — warn if > 500 MB
      if (file.size > 500 * 1024 * 1024) {
        var proceed = confirm(
          'Warning: This file is larger than 500 MB (' + formatSize(file.size) + ').\n\n' +
          'Processing very large files in the browser may cause memory issues or crashes.\n\n' +
          'Do you want to continue anyway?'
        );
        if (!proceed) return;
      }

      // Hide previous results
      document.getElementById('resultArea').style.display = 'none';
      document.getElementById('progressArea').style.display = 'none';

      // Show loading indicator
      var loadingEl = document.getElementById('loadingIndicator');
      loadingEl.style.display = 'block';
      document.getElementById('loadingText').textContent = 'Loading FFmpeg WASM (~30 MB)...';

      // Clear previous data
      currentVideoData = null;

      // Start compression process
      compressWithFFmpeg(file);
    }

    function compressWithFFmpeg(file) {
      var quality = parseInt(document.getElementById('qualitySlider').value);
      // Map quality 0-100 to CRF 51-18
      var crf = Math.round(51 - (quality / 100) * 33);
      var inputName = 'input.mp4';
      var outputName = 'output.mp4';

      var loadingEl = document.getElementById('loadingIndicator');
      var progressArea = document.getElementById('progressArea');
      var progressBar = document.getElementById('progressBar');
      var progressText = document.getElementById('progressText');

      // Check if FFmpeg is already loaded
      if (typeof FFmpegWASM === 'undefined' && typeof window.FFmpeg === 'undefined') {
        // Load FFmpeg WASM scripts dynamically
        loadFFmpegScripts(function() {
          startFFmpegProcessing(file, inputName, outputName, crf, quality, loadingEl, progressArea, progressBar, progressText);
        });
      } else {
        startFFmpegProcessing(file, inputName, outputName, crf, quality, loadingEl, progressArea, progressBar, progressText);
      }
    }

    function loadFFmpegScripts(callback) {
      var loadingText = document.getElementById('loadingText');
      var scriptsLoaded = 0;
      var totalScripts = 2;

      function onScriptLoad() {
        scriptsLoaded++;
        if (scriptsLoaded >= totalScripts) {
          loadingText.textContent = 'Initializing FFmpeg...';
          // Give a tick for initialization
          setTimeout(callback, 500);
        }
      }

      // Load ffmpeg.js
      var script1 = document.createElement('script');
      script1.src = 'https://unpkg.com/@ffmpeg/ffmpeg@0.12.10/dist/umd/ffmpeg.js';
      script1.onload = onScriptLoad;
      script1.onerror = function() {
        loadingText.textContent = 'Failed to load FFmpeg. Please check your connection and try again.';
      };
      document.head.appendChild(script1);

      // Load ffmpeg-core.js
      var script2 = document.createElement('script');
      script2.src = 'https://unpkg.com/@ffmpeg/core@0.12.6/dist/umd/ffmpeg-core.js';
      script2.onload = onScriptLoad;
      script2.onerror = function() {
        loadingText.textContent = 'Failed to load FFmpeg core. Please check your connection and try again.';
      };
      document.head.appendChild(script2);
    }

    function startFFmpegProcessing(file, inputName, outputName, crf, quality, loadingEl, progressArea, progressBar, progressText) {
      var loadingText = document.getElementById('loadingText');
      loadingText.textContent = 'Initializing FFmpeg engine...';

      try {
        var ffmpeg = new FFmpegWASM.FFmpeg();
        var ffmpegReady = false;

        // Set up progress callback
        ffmpeg.setProgress(function(progress) {
          var pct = Math.round(progress.percent * 100) / 100;
          if (pct > 0 && pct <= 100) {
            progressBar.style.width = Math.min(pct, 99) + '%';
            progressText.textContent = 'Compressing... ' + pct.toFixed(1) + '%';
          }
        });

        // Load FFmpeg
        ffmpeg.load().then(function() {
          ffmpegReady = true;
          loadingEl.style.display = 'none';
          progressArea.style.display = 'block';
          progressBar.style.width = '0%';
          progressText.textContent = 'Reading input file...';

          // Read the input file
          var reader = new FileReader();
          reader.onload = function(e) {
            var data = new Uint8Array(e.target.result);
            progressText.textContent = 'Writing file to FFmpeg virtual filesystem...';

            // Write input file to FFmpeg's virtual filesystem
            ffmpeg.writeFile(inputName, data).then(function() {
              progressText.textContent = 'Compressing video (CRF ' + crf + ')...';

              // Run FFmpeg command
              return ffmpeg.exec([
                '-i', inputName,
                '-c:v', 'libx264',
                '-crf', String(crf),
                '-preset', 'fast',
                '-c:a', 'aac',
                '-b:a', '128k',
                '-movflags', '+faststart',
                outputName
              ]);
            }).then(function() {
              progressText.textContent = 'Reading compressed output...';

              // Read the output file
              return ffmpeg.readFile(outputName);
            }).then(function(outputData) {
              progressBar.style.width = '100%';
              progressText.textContent = 'Done!';

              // Create blob from output
              var compressedBlob = new Blob([outputData.buffer], { type: 'video/mp4' });

              // Store result
              currentVideoData = {
                name: file.name.replace(/\.[^.]+$/, '-compressed.mp4'),
                originalSize: file.size,
                compressedSize: compressedBlob.size,
                blob: compressedBlob,
                crf: crf,
                quality: quality
              };

              // Show results
              renderResults();

              // Clean up FFmpeg virtual filesystem
              try { ffmpeg.deleteFile(inputName); } catch(e) {}
              try { ffmpeg.deleteFile(outputName); } catch(e) {}

            }).catch(function(err) {
              progressArea.style.display = 'none';
              loadingEl.style.display = 'none';
              alert('FFmpeg processing error: ' + (err.message || 'Unknown error. Please try a different video or quality setting.'));
            });
          };

          reader.onerror = function() {
            loadingEl.style.display = 'none';
            progressArea.style.display = 'none';
            alert('Failed to read the input file. Please try again.');
          };

          reader.readAsArrayBuffer(file);

        }).catch(function(err) {
          loadingText.textContent = 'Failed to initialize FFmpeg: ' + (err.message || 'Unknown error');
        });

      } catch (err) {
        loadingEl.style.display = 'none';
        progressArea.style.display = 'none';
        alert('FFmpeg initialization error: ' + (err.message || 'Unknown error. Please try refreshing the page.'));
      }
    }

    function renderResults() {
      if (!currentVideoData) return;

      var area = document.getElementById('resultArea');
      area.style.display = 'block';

      var ratio = currentVideoData.originalSize > 0
        ? ((1 - currentVideoData.compressedSize / currentVideoData.originalSize) * 100).toFixed(1)
        : 0;
      var ratioClass = parseFloat(ratio) >= 50 ? 'ratio-great' : 'ratio-good';

      document.getElementById('summaryBar').textContent =
        '1 video | Original: ' + formatSize(currentVideoData.originalSize) +
        ' → Compressed: ' + formatSize(currentVideoData.compressedSize) +
        ' | Saved: ' + ratio + '%' +
        ' | CRF: ' + currentVideoData.crf;

      var html =
        '<div class="file-info-card">' +
          '<span class="video-icon">🎬</span>' +
          '<div class="file-details">' +
            '<div class="file-name">' + currentVideoData.name + '</div>' +
            '<div class="file-meta">' +
              formatSize(currentVideoData.originalSize) + ' → ' + formatSize(currentVideoData.compressedSize) +
              ' <span class="video-item-ratio ' + ratioClass + '">-' + ratio + '%</span>' +
            '</div>' +
          '</div>' +
        '</div>';

      document.getElementById('videoResult').innerHTML = html;
      document.getElementById('progressArea').style.display = 'none';
    }

    function downloadVideo() {
      if (!currentVideoData || !currentVideoData.blob) return;
      var url = URL.createObjectURL(currentVideoData.blob);
      var a = document.createElement('a');
      a.href = url;
      a.download = currentVideoData.name;
      a.click();
      URL.revokeObjectURL(url);
    }

    function clearVideo() {
      currentVideoData = null;
      document.getElementById('resultArea').style.display = 'none';
      document.getElementById('videoResult').innerHTML = '';
      document.getElementById('summaryBar').textContent = '';
      document.getElementById('progressArea').style.display = 'none';
      document.getElementById('loadingIndicator').style.display = 'none';
    }

    setupDropZone();
  </script>
</BaseLayout>
