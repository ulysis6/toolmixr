---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "Color Palette Generator";
const pageUrl = "https://toolmixr.com/color-palette-generator";

const structuredData = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": pageTitle,
    "url": pageUrl,
    "description": "Free online color palette generator. Create beautiful color schemes for your web projects. Export as hex, RGB, or CSS.",
    "applicationCategory": "DesignApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is an analogous color scheme?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Analogous colors sit next to each other on the color wheel (e.g., blue, blue-green, green). They create harmonious, natural-looking palettes that are easy on the eyes."
        }
      },
      {
        "@type": "Question",
        "name": "What is a complementary color?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Complementary colors are directly opposite on the color wheel (e.g., blue and orange). They create high contrast and visual energy — great for call-to-action elements."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://toolmixr.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": pageTitle,
        "item": pageUrl
      }
    ]
  }
]);
---

<BaseLayout 
  title={pageTitle} 
  description="Free online color palette generator. Create beautiful color schemes for your web projects. Export as hex, RGB, or CSS."
  structuredData={structuredData}
>
  <section class="tool-page">
    <h1>🎨 Color Palette Generator</h1>
    <p class="subtitle">Generate beautiful color palettes for your projects</p>
    
    <div class="tool-box">
      <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:end;">
        <div class="form-group" style="flex:1;min-width:160px;margin-bottom:0;">
          <label for="baseColor">Base Color</label>
          <input type="color" id="baseColor" value="#4F46E5" style="width:100%;height:44px;border:1px solid var(--border);border-radius:var(--radius);cursor:pointer;" />
        </div>
        <div class="form-group" style="flex:1;min-width:160px;margin-bottom:0;">
          <label for="paletteType">Palette Type</label>
          <select id="paletteType">
            <option value="analogous">Analogous</option>
            <option value="complementary">Complementary</option>
            <option value="triadic">Triadic</option>
            <option value="split">Split Complementary</option>
            <option value="monochromatic">Monochromatic</option>
          </select>
        </div>
        <div style="margin-bottom:4px;">
          <button class="btn btn-primary" onclick="generatePalette()">Generate</button>
        </div>
        <div style="margin-bottom:4px;">
          <button class="btn btn-secondary" onclick="randomBase()">🎲 Random</button>
        </div>
      </div>
      
      <div id="paletteResult" style="margin-top:24px;">
        <div id="colorCards" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:16px;"></div>
      </div>
      
      <div style="margin-top:20px;">
        <h3 style="font-size:14px;margin-bottom:8px;">CSS Variables</h3>
        <div class="output-box" id="output" style="display:block;">
          <button class="copy-btn" onclick="copyOutput()">Copy</button>
          <pre id="code"></pre>
        </div>
      </div>
    </div>
    
    <section class="faq">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <h3>What is an analogous color scheme?</h3>
        <p>Analogous colors sit next to each other on the color wheel (e.g., blue, blue-green, green). They create harmonious, natural-looking palettes that are easy on the eyes.</p>
      </div>
      <div class="faq-item">
        <h3>What is a complementary color?</h3>
        <p>Complementary colors are directly opposite on the color wheel (e.g., blue and orange). They create high contrast and visual energy — great for call-to-action elements.</p>
      </div>
    </section>

    <section class="related-tools">
      <h2>Related Tools</h2>
      <div class="related-tools-grid">
        <a href="/qr-code-generator" class="related-tool-card">
          <span class="related-icon">📱</span>
          <span class="related-name">QR Code Generator</span>
        </a>
        <a href="/meta-tag-generator" class="related-tool-card">
          <span class="related-icon">🏷️</span>
          <span class="related-name">Meta Tag Generator</span>
        </a>
        <a href="/og-image-generator" class="related-tool-card">
          <span class="related-icon">🖼️</span>
          <span class="related-name">OG Image Generator</span>
        </a>
        <a href="/lorem-ipsum-generator" class="related-tool-card">
          <span class="related-icon">📄</span>
          <span class="related-name">Lorem Ipsum Generator</span>
        </a>
      </div>
    </section>
  </section>

  <script is:inline>
    function hexToHSL(hex) {
      var r = parseInt(hex.slice(1,3),16)/255;
      var g = parseInt(hex.slice(3,5),16)/255;
      var b = parseInt(hex.slice(5,7),16)/255;
      var max = Math.max(r,g,b), min = Math.min(r,g,b);
      var h=0, s=0, l=(max+min)/2;
      if(max!==min){
        var d=max-min;
        s=l>0.5?d/(2-max-min):d/(max+min);
        switch(max){
          case r: h=((g-b)/d+(g<b?6:0))/6; break;
          case g: h=((b-r)/d+2)/6; break;
          case b: h=((r-g)/d+4)/6; break;
        }
      }
      return [Math.round(h*360), Math.round(s*100), Math.round(l*100)];
    }
    
    function hslToHex(h, s, l) {
      s/=100; l/=100;
      var a=s*Math.min(l,1-l);
      function f(n){
        var k=(n+h/30)%12;
        var color=l-a*Math.max(Math.min(k-3,9-k,1),-1);
        return Math.round(255*color).toString(16).padStart(2,'0');
      }
      return '#' + f(0) + f(8) + f(4);
    }
    
    function generatePalette() {
      var hex = document.getElementById('baseColor').value;
      var type = document.getElementById('paletteType').value;
      var hsl = hexToHSL(hex);
      var h = hsl[0], s = hsl[1], l = hsl[2];
      
      var colors = [];
      switch(type) {
        case 'analogous':
          colors = [h, h + 30, h + 60, h + 90, h + 120];
          break;
        case 'complementary':
          colors = [h, h + 180, h + 170, h + 190, h + 160];
          break;
        case 'triadic':
          colors = [h, h + 120, h + 240, h + 110, h + 250];
          break;
        case 'split':
          colors = [h, h + 150, h + 210, h + 140, h + 220];
          break;
        case 'monochromatic':
          colors = [h, h, h, h, h];
          var ls = [10, 25, 50, 70, 90];
          var ss = [30, 50, 50, 40, 20];
          var colorCards = document.getElementById('colorCards');
          colorCards.innerHTML = colors.map(function(c, i) {
            var color = hslToHex(c, ss[i], ls[i]);
            var textColor = ls[i] > 50 ? '#000' : '#fff';
            var rgb = hexToRgb(color);
            return '<div style="background:' + color + ';padding:20px;border-radius:8px;color:' + textColor + ';text-align:center;"><div style="font-size:12px;opacity:0.8;">' + color.toUpperCase() + '</div><div style="font-size:11px;margin-top:4px;opacity:0.8;">rgb(' + rgb.r + ',' + rgb.g + ',' + rgb.b + ')</div></div>';
          }).join('');
          var css = ':root {\n  --color-1: ' + colors.map(function(c, i) { return hslToHex(c, ss[i], ls[i]); }).join(';\n  --color-2: ').toUpperCase() + ';\n}';
          document.getElementById('code').textContent = css;
          return;
      }
      
      colors = colors.map(function(c) { return (c % 360 + 360) % 360; });
      
      var colorCards = document.getElementById('colorCards');
      colorCards.innerHTML = colors.map(function(c) {
        var color = hslToHex(c, s, 45);
        var rgb = hexToRgb(color);
        return '<div style="background:' + color + ';padding:20px;border-radius:8px;color:#fff;text-align:center;"><div style="font-size:12px;opacity:0.8;">' + color.toUpperCase() + '</div><div style="font-size:11px;margin-top:4px;opacity:0.8;">rgb(' + rgb.r + ',' + rgb.g + ',' + rgb.b + ')</div></div>';
      }).join('');
      
      var css = ':root {\n  --color-1: ' + colors.map(function(c) { return hslToHex(c, s, 45).toUpperCase(); }).join(';\n  --color-2: ') + ';\n}';
      document.getElementById('code').textContent = css;
    }
    
    function hexToRgb(hex) {
      var result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
      return result ? {
        r: parseInt(result[1], 16),
        g: parseInt(result[2], 16),
        b: parseInt(result[3], 16)
      } : {r:0,g:0,b:0};
    }
    
    function randomBase() {
      var letters = '0123456789ABCDEF';
      var color = '#';
      for (var i = 0; i < 6; i++) {
        color += letters[Math.floor(Math.random() * 16)];
      }
      document.getElementById('baseColor').value = color;
      generatePalette();
    }
    
    function copyOutput() {
      var code = document.getElementById('code').textContent;
      navigator.clipboard.writeText(code).then(function() {
        document.querySelector('.copy-btn').textContent = 'Copied!';
        setTimeout(function() { document.querySelector('.copy-btn').textContent = 'Copy'; }, 2000);
      });
    }
    
    generatePalette();
  </script>
</BaseLayout>
