---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "Sitemap Generator";
const pageUrl = "https://toolmixr.com/sitemap-generator";

const structuredData = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": pageTitle,
    "url": pageUrl,
    "description": "Free online XML sitemap generator. Create sitemaps for your website to help search engines discover and index your pages.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is an XML sitemap?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "An XML sitemap is a file that lists all the pages on your website, helping search engines like Google and Bing discover and crawl your content more efficiently."
        }
      },
      {
        "@type": "Question",
        "name": "Do I need a sitemap?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If your site is small (under 500 pages) with good internal linking, search engines can usually find all pages. Sitemaps become essential for large sites, new sites with few backlinks, or sites with isolated pages."
        }
      },
      {
        "@type": "Question",
        "name": "Where should I put my sitemap?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Place it at the root of your domain: https://example.com/sitemap.xml. Also reference it in your robots.txt file with: Sitemap: https://example.com/sitemap.xml"
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://toolmixr.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": pageTitle,
        "item": pageUrl
      }
    ]
  }
]);
---

<BaseLayout 
  title={pageTitle} 
  description="Free online XML sitemap generator. Create sitemaps for your website to help search engines discover and index your pages."
  structuredData={structuredData}
>
  <section class="tool-page">
  <nav class="breadcrumb">
    <a href="/">Home</a> <span class="breadcrumb-sep">›</span> <span>Sitemap Generator</span>
  </nav>
  <div class="tool-header">
    <h1>🗺️ Sitemap Generator</h1>
    <div class="share-bar">
      <a class="share-btn share-twitter" href="#" onclick="shareTwitter(event)" title="Share on Twitter">𝕏</a>
      <a class="share-btn share-facebook" href="#" onclick="shareFacebook(event)" title="Share on Facebook">f</a>
      <a class="share-btn share-linkedin" href="#" onclick="shareLinkedIn(event)" title="Share on LinkedIn">in</a>
      <a class="share-btn share-reddit" href="#" onclick="shareReddit(event)" title="Share on Reddit">R</a>
      <button class="share-btn share-copy" onclick="copyPageLink(event)" title="Copy link">🔗</button>
    </div>
  </div>
  <p class="subtitle">Create XML sitemaps for search engine indexing</p>
    
    <div class="tool-box">
      <div id="urls">
        <div class="url-row" style="display:flex;gap:12px;margin-bottom:12px;flex-wrap:wrap;align-items:end;">
          <div class="form-group" style="flex:3;min-width:250px;margin-bottom:0;">
            <label>Page URL *</label>
            <input type="url" class="url-input" placeholder="https://example.com/page" />
          </div>
          <div class="form-group" style="flex:1;min-width:120px;margin-bottom:0;">
            <label>Priority</label>
            <select class="priority-select">
              <option value="1.0">1.0</option>
              <option value="0.8" selected>0.8</option>
              <option value="0.6">0.6</option>
              <option value="0.5">0.5</option>
              <option value="0.4">0.4</option>
              <option value="0.2">0.2</option>
            </select>
          </div>
          <div class="form-group" style="flex:1;min-width:120px;margin-bottom:0;">
            <label>Frequency</label>
            <select class="freq-select">
              <option value="always">Always</option>
              <option value="hourly">Hourly</option>
              <option value="daily">Daily</option>
              <option value="weekly" selected>Weekly</option>
              <option value="monthly">Monthly</option>
              <option value="yearly">Yearly</option>
              <option value="never">Never</option>
            </select>
          </div>
        </div>
      </div>
      
      <button class="btn btn-secondary" onclick="addURL()" style="margin-bottom:20px;">+ Add URL</button>
      
      <div style="display:flex;gap:12px;">
        <button class="btn btn-primary" onclick="generateSitemap()">Generate Sitemap</button>
        <button class="btn btn-secondary" onclick="copyOutput()">📋 Copy</button>
      </div>
      
      <div class="output-box" id="output" style="display:none;margin-top:20px;">
        <button class="copy-btn" onclick="copyOutput()">Copy</button>
        <pre id="code"></pre>
      </div>
    </div>
    
    <section class="guide">
      <h2>How to Use the Sitemap Generator</h2>
      <p>Create an XML sitemap for your website to help search engines discover and index all your pages. Sitemaps are especially important for larger sites, new sites with few backlinks, and sites with dynamic content.</p>
      
      <h3>Step-by-Step Guide</h3>
      <ol>
        <li><strong>Add your page URLs</strong> — Click "Add URL" to enter each page you want indexed. Include your homepage and all important pages.</li>
        <li><strong>Set priority levels</strong> — Use 1.0 for your most important pages (homepage, main categories), 0.8 for subpages, 0.6 for individual articles.</li>
        <li><strong>Choose change frequency</strong> — Set how often each page changes: always, hourly, daily, weekly, monthly, yearly, or never.</li>
        <li><strong>Generate XML</strong> — Click Generate to create your XML sitemap with proper formatting.</li>
        <li><strong>Download and upload</strong> — Save the file as sitemap.xml and upload it to your website's root directory.</li>
      </ol>
      
      <h3>Tips & Best Practices</h3>
      <ul>
        <li><strong>Include all important pages</strong> — Don't include pages with noindex tags or duplicate content. Only submit pages you want indexed.</li>
        <li><strong>Homepage gets highest priority</strong> — Always set your homepage to priority 1.0 and change frequency "daily" or "weekly."</li>
        <li><strong>Update regularly</strong> — Re-generate your sitemap whenever you add new content. Many CMSs have plugins to auto-generate sitemaps.</li>
        <li><strong>Submit to Google</strong> — Add your sitemap to Google Search Console for better indexing control and performance tracking.</li>
      </ul>
    </section>
    
    <section class="faq">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>What is an XML sitemap?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>An XML sitemap is a file that lists all the pages on your website, helping search engines like Google and Bing discover and crawl your content more efficiently.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>Do I need a sitemap?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>If your site is small (under 500 pages) with good internal linking, search engines can usually find all pages. Sitemaps become essential for large sites, new sites with few backlinks, or sites with isolated pages.</p>
        </div>
      </div>
      <div class="faq-item">
        <h3>Where should I put my sitemap?</h3>
        <p>Place it at the root of your domain: <code>https://example.com/sitemap.xml</code>. Also reference it in your robots.txt file with: <code>Sitemap: https://example.com/sitemap.xml</code></p>
      </div>
    </section>

    <section class="related-tools">
      <h2>Related Tools</h2>
      <div class="related-tools-grid">
        <a href="/robots-txt-generator" class="related-tool-card">
          <span class="related-icon">🤖</span>
          <span class="related-name">Robots.txt Generator</span>
        </a>
        <a href="/meta-tag-generator" class="related-tool-card">
          <span class="related-icon">🏷️</span>
          <span class="related-name">Meta Tag Generator</span>
        </a>
        <a href="/url-encoder-decoder" class="related-tool-card">
          <span class="related-icon">🔗</span>
          <span class="related-name">URL Encoder/Decoder</span>
        </a>
        <a href="/json-formatter" class="related-tool-card">
          <span class="related-icon">{}</span>
          <span class="related-name">JSON Formatter</span>
        </a>
      </div>
    </section>
  </section>

  <script is:inline>
    function addURL() {
      var container = document.getElementById('urls');
      var row = document.createElement('div');
      row.className = 'url-row';
      row.style.cssText = 'display:flex;gap:12px;margin-bottom:12px;flex-wrap:wrap;align-items:end;';
      row.innerHTML = '<div class="form-group" style="flex:3;min-width:250px;margin-bottom:0;"><label>Page URL *</label><input type="url" class="url-input" placeholder="https://example.com/page"></div><div class="form-group" style="flex:1;min-width:120px;margin-bottom:0;"><label>Priority</label><select class="priority-select"><option value="1.0">1.0</option><option value="0.8" selected>0.8</option><option value="0.6">0.6</option><option value="0.5">0.5</option><option value="0.4">0.4</option><option value="0.2">0.2</option></select></div><div class="form-group" style="flex:1;min-width:120px;margin-bottom:0;"><label>Frequency</label><select class="freq-select"><option value="always">Always</option><option value="hourly">Hourly</option><option value="daily">Daily</option><option value="weekly" selected>Weekly</option><option value="monthly">Monthly</option><option value="yearly">Yearly</option><option value="never">Never</option></select></div><button class="btn btn-secondary" onclick="this.parentElement.remove()" style="padding:8px 12px;">✕</button>';
      container.appendChild(row);
    }
    
    function generateSitemap() {
      var rows = document.querySelectorAll('.url-row');
      var today = new Date().toISOString().split('T')[0];
      var xml = '<?xml version="1.0" encoding="UTF-8"?>\n';
      xml += '<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">\n';
      
      rows.forEach(function(row) {
        var url = row.querySelector('.url-input').value.trim();
        var priority = row.querySelector('.priority-select').value;
        var freq = row.querySelector('.freq-select').value;
        if (url) {
          xml += '  <url>\n';
          xml += '    <loc>' + url + '</loc>\n';
          xml += '    <lastmod>' + today + '</lastmod>\n';
          xml += '    <changefreq>' + freq + '</changefreq>\n';
          xml += '    <priority>' + priority + '</priority>\n';
          xml += '  </url>\n';
        }
      });
      
      xml += '</urlset>';
      document.getElementById('output').style.display = 'block';
      document.getElementById('code').textContent = xml;
    }
    
    function copyOutput() {
      var code = document.getElementById('code').textContent;
      navigator.clipboard.writeText(code).then(function() {
        document.querySelector('.copy-btn').textContent = 'Copied!';
        setTimeout(function() { document.querySelector('.copy-btn').textContent = 'Copy'; }, 2000);
      });
    }
  </script>
</BaseLayout>
