---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "Lorem Ipsum Generator - Placeholder Text for Designers";
const pageUrl = "https://toolmixr.com/lorem-ipsum-generator";

const structuredData = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": pageTitle,
    "url": pageUrl,
    "description": "Free online lorem ipsum generator. Generate placeholder text for your designs and mockups.",
    "applicationCategory": "DesignApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is Lorem Ipsum?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Lorem Ipsum is dummy text used in printing, typesetting, and web design since the 1500s. It's derived from a Latin text by Cicero but scrambled to be nonsensical, so readers focus on the visual layout rather than the content."
        }
      },
      {
        "@type": "Question",
        "name": "Why use Lorem Ipsum instead of real text?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Using readable real text can distract reviewers from evaluating the design itself. Lorem Ipsum looks natural enough to show text flow but doesn't carry meaning, keeping the focus on layout and typography."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://toolmixr.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": pageTitle,
        "item": pageUrl
      }
    ]
  }
]);
---

<BaseLayout 
  title={pageTitle} 
  description="Free online lorem ipsum generator. Generate placeholder text for your designs and mockups."
  structuredData={structuredData}
>
  <section class="tool-page">
  <nav class="breadcrumb">
    <a href="/">Home</a> <span class="breadcrumb-sep">›</span> <span>Lorem Ipsum Generator</span>
  </nav>
  <div class="tool-header">
    <h1>📄 Lorem Ipsum Generator</h1>
    <div class="share-bar">
      <a class="share-btn share-twitter" href="#" onclick="shareTwitter(event)" title="Share on Twitter">𝕏</a>
      <a class="share-btn share-facebook" href="#" onclick="shareFacebook(event)" title="Share on Facebook">f</a>
      <a class="share-btn share-linkedin" href="#" onclick="shareLinkedIn(event)" title="Share on LinkedIn">in</a>
      <a class="share-btn share-reddit" href="#" onclick="shareReddit(event)" title="Share on Reddit">R</a>
      <button class="share-btn share-copy" onclick="copyPageLink(event)" title="Copy link">🔗</button>
    </div>
  </div>
  <p class="subtitle">Generate placeholder text for designs and mockups</p>
    
    <div class="tool-box">
      <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:end;">
        <div class="form-group" style="flex:1;min-width:120px;margin-bottom:0;">
          <label for="amount">Amount</label>
          <input type="number" id="amount" value="3" min="1" max="50" />
        </div>
        <div class="form-group" style="flex:1;min-width:160px;margin-bottom:0;">
          <label for="type">Type</label>
          <select id="type">
            <option value="paragraphs">Paragraphs</option>
            <option value="sentences">Sentences</option>
            <option value="words">Words</option>
          </select>
        </div>
        <div style="margin-bottom:4px;">
          <button class="btn btn-primary" onclick="generate()">Generate</button>
        </div>
      </div>
      
      <div style="margin-top:16px;display:flex;gap:12px;">
        <button class="btn btn-secondary" onclick="copyOutput()">📋 Copy</button>
      </div>
      
      <div id="result" style="margin-top:20px;padding:20px;background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);font-size:14px;line-height:1.8;color:var(--text-secondary);max-height:400px;overflow-y:auto;"></div>
    

    <section class="guide">
      <h2>The Strange History of Placeholder Text</h2>
      <p>Lorem Ipsum isn't just random gibberish — it has a 2,000-year history. The text comes from a 1st-century BC Roman treatise by Cicero called "De Finibus Bonorum et Malorum" (On the Ends of Good and Evil). A typesetter in the 1500s scrambled the Latin to create placeholder text for printers. Designers have been using it ever since.</p>
      
      <h3>The Original Lorem Ipsum</h3>
      <p>The most common Lorem Ipsum passage begins:</p>
      <blockquote><p>"Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."</p></blockquote>
      <p>Translation: "Lorem ipsum pain sit amet, consectetur adipiscing elit, but I labor and great pain to produce..." — it's talking about the pleasure of pursuing noetic (intellectual) goods. Ironic for placeholder text that's caused so much confusion.</p>

      <h3>Real Content vs. Placeholder Content</h3>
      <p>The debate about placeholder vs. real content in design:</p>
      <ul>
        <li><strong>Placeholders work when</strong>: Design hasn't been approved, content isn't written, showing visual hierarchy and layout</li>
        <li><strong>Real content works when</strong>: Content is available, you want designers to see real flow, accessibility testing is needed</li>
      </ul>
      <p>Many modern designers argue for real content because placeholder text doesn't show how actual headlines, body copy, and CTAs will look. Reading "Your Headline Here" doesn't help visualize the final product.</p>

      <h3>Alternatives to Lorem Ipsum</h3>
      <p>Some projects call for different approaches:</p>
      <ul>
        <li><strong>Corporate Ipsum</strong>: Business jargon placeholder ("Synergy is our core competency")</li>
        <li><strong>Hipsum</strong>: The hipster Lorem Ipsum ("Authentic selfies pug")</li>
        <li><strong>Samuel L. Ipsum</strong>: Movie quotes ("I have a bad feeling about this")</li>
        <li><strong>Fillerama</strong>: TV show quotes</li>
        <li><strong>Real content</strong>: Always preferable when available</li>
      </ul>

      <h3>The Modern Design Argument</h3>
      <p>Many contemporary designers advocate abandoning Lorem Ipsum entirely:</p>
      <ul>
        <li><strong>Content-first design</strong>: Start with real content to make real decisions about hierarchy, length, and layout</li>
        <li><strong>Accessibility</strong>: Screen readers read Lorem Ipsum to users, which is meaningless</li>
        <li><strong>Client communication</strong>: Clients can evaluate how the design actually works with real content</li>
      </ul>
      <p>The counter-argument: sometimes you genuinely don't have content yet, or you're testing design systems independent of specific content. In those cases, Lorem Ipsum is fine.</p>

      <h3>Step-by-Step Guide</h3>
      <ol>
        <li><strong>Choose what to generate</strong> — Select paragraphs, words, or sentences depending on your needs.</li>
        <li><strong>Set the quantity</strong> — Choose how many paragraphs, words, or sentences you need.</li>
        <li><strong>Click Generate</strong> — Instantly get realistic placeholder text that looks like real content.</li>
        <li><strong>Copy to clipboard</strong> — Use the copy button to paste directly into your design tool.</li>
      </ol>
      
      <h3>Tips & Best Practices</h3>
      <ul>
        <li><strong>Use for design mockups only</strong> — Never use Lorem Ipsum in production. Real content helps designers make better decisions about layout and hierarchy.</li>
        <li><strong>Match expected content type</strong> — Generate longer text for blog layouts, shorter snippets for cards, appropriate amounts for each design context.</li>
        <li><strong>Consider alternatives</strong> — Some projects benefit from real placeholder content like "Headline," "Lorem ipsum dolor sit amet..." to clearly indicate where real content will go.</li>
        <li><strong>Do not let Lorem Ipsum delay design</strong> — Even with placeholder text, you can establish type hierarchy, spacing, and layout. The goal is to visualize the final design.</li>
      </ul>
    </section>
    <section class="faq">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>What is Lorem Ipsum?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>Lorem Ipsum is dummy text used in printing, typesetting, and web design since the 1500s. It's derived from a Latin text by Cicero but scrambled to be nonsensical, so readers focus on the visual layout rather than the content.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)">
          <span>Why use Lorem Ipsum instead of real text?</span>
          <span class="faq-arrow">▸</span>
        </button>
        <div class="faq-answer">
          <p>Using readable real text can distract reviewers from evaluating the design itself. Lorem Ipsum looks natural enough to show text flow but doesn't carry meaning, keeping the focus on layout and typography.</p>
        </div>
      </div>
    </section>

    <section class="related-tools">
      <h2>Related Tools</h2>
      <div class="related-tools-grid">
        <a href="/word-counter" class="related-tool-card">
          <span class="related-icon">📝</span>
          <span class="related-name">Word Counter</span>
        </a>
        <a href="/color-palette-generator" class="related-tool-card">
          <span class="related-icon">🎨</span>
          <span class="related-name">Color Palette Generator</span>
        </a>
        <a href="/password-generator" class="related-tool-card">
          <span class="related-icon">🔐</span>
          <span class="related-name">Password Generator</span>
        </a>
      </div>
    </section>
  </section>

  <script is:inline>
    var words = [
      'lorem','ipsum','dolor','sit','amet','consectetur','adipiscing','elit','sed','do',
      'eiusmod','tempor','incididunt','ut','labore','et','dolore','magna','aliqua','enim',
      'ad','minim','veniam','quis','nostrud','exercitation','ullamco','laboris','nisi','aliquip',
      'ex','ea','commodo','consequat','duis','aute','irure','in','reprehenderit','voluptate',
      'velit','esse','cillum','fugiat','nulla','pariatur','excepteur','sint','occaecat','cupidatat',
      'non','proident','sunt','culpa','qui','officia','deserunt','mollit','anim','id',
      'est','laborum','vitae','elementum','curabitur','felis','sapien','varius','vel','porta',
      'ac','cursus','mauris','augue','neque','gravida','fermentum','praesent','semper','ligula',
      'pellentesque','habitant','morbi','tristique','senectus','netus','malesuada','fames','turpis','egestas'
    ];
    
    function randomWord() { return words[Math.floor(Math.random() * words.length)]; }
    
    function randomSentence() {
      var len = 8 + Math.floor(Math.random() * 12);
      var sentence = [];
      for (var i = 0; i < len; i++) sentence.push(randomWord());
      sentence[0] = sentence[0].charAt(0).toUpperCase() + sentence[0].slice(1);
      return sentence.join(' ') + '.';
    }
    
    function randomParagraph() {
      var count = 3 + Math.floor(Math.random() * 4);
      var sentences = [];
      for (var i = 0; i < count; i++) sentences.push(randomSentence());
      return sentences.join(' ');
    }
    
    function generate() {
      var amount = parseInt(document.getElementById('amount').value);
      var type = document.getElementById('type').value;
      var result = '';
      
      if (type === 'paragraphs') {
        var paras = [];
        for (var i = 0; i < amount; i++) paras.push(randomParagraph());
        result = paras.join('\n\n');
      } else if (type === 'sentences') {
        var sentences = [];
        for (var i = 0; i < amount; i++) sentences.push(randomSentence());
        result = sentences.join(' ');
      } else {
        var w = [];
        for (var i = 0; i < amount; i++) w.push(randomWord());
        result = w.join(' ');
      }
      
      var el = document.getElementById('result');
      if (type === 'paragraphs') {
        el.innerHTML = result.split('\n\n').map(function(p){ return '<p style="margin-bottom:12px;">' + p + '</p>'; }).join('');
      } else {
        el.innerHTML = '<p>' + result + '</p>';
      }
      el.dataset.text = result;
    }
    
    generate();
    
    function copyOutput() {
      var text = document.getElementById('result').dataset.text || '';
      navigator.clipboard.writeText(text).then(function() { alert('Copied!'); });
    }
  </script>
</BaseLayout>
